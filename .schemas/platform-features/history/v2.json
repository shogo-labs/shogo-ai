{
  "id": "6d0df197-a84e-4ec0-aab1-3d7d825d4e6e",
  "name": "platform-features",
  "format": "enhanced-json-schema",
  "createdAt": 1765197911179,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-persistence": {
    "backend": "postgres"
  },
  "$defs": {
    "FeatureSession": {
      "type": "object",
      "description": "Container for a platform feature development session",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "Short name for the feature (used as folder name)"
        },
        "intent": {
          "type": "string",
          "description": "Original ask in natural language"
        },
        "status": {
          "type": "string",
          "enum": [
            "discovery",
            "analysis",
            "classification",
            "design",
            "spec",
            "implementation",
            "testing",
            "complete"
          ],
          "x-renderer": "session-status-badge"
        },
        "affectedPackages": {
          "type": "array",
          "description": "Which packages this feature touches",
          "items": {
            "type": "string"
          }
        },
        "schemaName": {
          "type": "string",
          "description": "If this feature produces a schema, its name"
        },
        "initialAssessment": {
          "type": "object",
          "description": "Preliminary archetype assessment from discovery (not finalized until classification)",
          "properties": {
            "likelyArchetype": {
              "type": "string",
              "enum": [
                "service",
                "domain",
                "infrastructure",
                "hybrid"
              ],
              "x-renderer": "archetype-badge"
            },
            "indicators": {
              "type": "array",
              "description": "Evidence observed during discovery",
              "items": {
                "type": "string"
              }
            },
            "uncertainties": {
              "type": "array",
              "description": "What needs validation during classification",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "featureArchetype": {
          "type": "string",
          "description": "Validated archetype after classification (set by classification skill)",
          "enum": [
            "service",
            "domain",
            "infrastructure",
            "hybrid"
          ],
          "x-renderer": "archetype-badge"
        },
        "applicablePatterns": {
          "type": "array",
          "description": "Patterns applicable to this feature (set by classification skill)",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        },
        "project": {
          "type": "string",
          "description": "Loose ref to Project.id"
        }
      },
      "required": [
        "id",
        "name",
        "intent",
        "status",
        "createdAt"
      ],
      "x-original-name": "FeatureSession"
    },
    "Requirement": {
      "type": "object",
      "description": "A requirement derived from the feature intent",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "name": {
          "type": "string",
          "description": "Short slug-like identifier (e.g., 'auth-service-interface')"
        },
        "description": {
          "type": "string",
          "description": "Full requirement description"
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "could"
          ],
          "x-renderer": "priority-badge"
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "implemented"
          ],
          "x-renderer": "requirement-status-badge"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "session",
        "name",
        "description",
        "priority",
        "status"
      ],
      "x-original-name": "Requirement"
    },
    "DesignDecision": {
      "type": "object",
      "description": "A design decision made during feature development",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "name": {
          "type": "string",
          "description": "Short slug-like identifier (e.g., 'auth-state-location')"
        },
        "question": {
          "type": "string",
          "description": "What needed deciding"
        },
        "decision": {
          "type": "string",
          "description": "What we chose"
        },
        "rationale": {
          "type": "string",
          "description": "Why we chose it"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "session",
        "name",
        "question",
        "decision",
        "rationale"
      ],
      "x-original-name": "DesignDecision"
    },
    "ClassificationDecision": {
      "type": "object",
      "description": "Records the validated archetype classification with evidence-based rationale",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "validatedArchetype",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "initialAssessment": {
          "type": "string",
          "description": "Archetype from discovery (before validation)",
          "enum": [
            "service",
            "domain",
            "infrastructure",
            "hybrid"
          ],
          "x-renderer": "archetype-badge"
        },
        "validatedArchetype": {
          "type": "string",
          "description": "Final archetype after evidence-based validation",
          "enum": [
            "service",
            "domain",
            "infrastructure",
            "hybrid"
          ],
          "x-renderer": "archetype-badge"
        },
        "evidenceChecklist": {
          "type": "object",
          "description": "What evidence was checked and its values"
        },
        "rationale": {
          "type": "string",
          "description": "Why this archetype was chosen"
        },
        "correction": {
          "type": "string",
          "description": "If initial was wrong, what changed and why"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "session",
        "validatedArchetype",
        "rationale",
        "createdAt"
      ],
      "x-original-name": "ClassificationDecision"
    },
    "AnalysisFinding": {
      "type": "object",
      "description": "A finding from codebase analysis relevant to implementing a platform feature",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "name": {
          "type": "string",
          "description": "Short slug-like identifier (e.g., 'domain-store-pattern')"
        },
        "type": {
          "type": "string",
          "description": "Category of finding",
          "enum": [
            "pattern",
            "integration_point",
            "risk",
            "gap",
            "existing_test",
            "verification",
            "classification_evidence"
          ],
          "x-renderer": "finding-type-badge"
        },
        "description": {
          "type": "string",
          "description": "What was found"
        },
        "location": {
          "type": "string",
          "description": "File path, package, or module where this applies"
        },
        "relevantCode": {
          "type": "string",
          "description": "Code snippet or reference illustrating the finding"
        },
        "recommendation": {
          "type": "string",
          "description": "Suggested action based on this finding"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "session",
        "name",
        "type",
        "description",
        "location",
        "createdAt"
      ],
      "x-original-name": "AnalysisFinding"
    },
    "IntegrationPoint": {
      "type": "object",
      "description": "A specific location in the codebase where changes will be made",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "name": {
          "type": "string",
          "description": "Short semantic identifier (e.g., 'auth-types-definition')"
        },
        "filePath": {
          "type": "string",
          "description": "Relative file path within the package"
        },
        "package": {
          "type": "string",
          "description": "Package name (e.g., packages/mcp, apps/web)"
        },
        "targetFunction": {
          "type": "string",
          "description": "Specific function or class to modify (optional)"
        },
        "changeType": {
          "type": "string",
          "description": "Type of change required",
          "enum": [
            "add",
            "modify",
            "extend",
            "remove"
          ]
        },
        "description": {
          "type": "string",
          "description": "What needs to happen at this location"
        },
        "rationale": {
          "type": "string",
          "description": "Why this is the right place for this change"
        },
        "finding": {
          "type": "string",
          "description": "The analysis finding that identified this point",
          "x-arktype": "AnalysisFinding",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single",
          "x-reference-target": "AnalysisFinding"
        },
        "isGenerated": {
          "type": "boolean",
          "description": "Whether this is template-generated vs manual"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "session",
        "name",
        "filePath",
        "description",
        "createdAt"
      ],
      "x-original-name": "IntegrationPoint"
    },
    "TestCase": {
      "type": "object",
      "description": "A requirement-scoped acceptance test case",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "requirement": {
          "type": "string",
          "description": "Optional link to requirement for traceability",
          "x-arktype": "Requirement",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single",
          "x-reference-target": "Requirement"
        },
        "name": {
          "type": "string",
          "description": "Short slug-like identifier (e.g., 'valid-credentials-login')"
        },
        "description": {
          "type": "string",
          "description": "What this test verifies"
        },
        "given": {
          "type": "string",
          "description": "Preconditions"
        },
        "when": {
          "type": "string",
          "description": "Action being tested"
        },
        "then": {
          "type": "string",
          "description": "Expected outcome"
        },
        "status": {
          "type": "string",
          "enum": [
            "specified",
            "implemented",
            "passing"
          ],
          "x-renderer": "test-case-status-badge"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "session",
        "name",
        "description",
        "given",
        "when",
        "then",
        "status"
      ],
      "x-original-name": "TestCase"
    },
    "ImplementationTask": {
      "type": "object",
      "description": "A discrete unit of work to implement part of a platform feature",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "name": {
          "type": "string",
          "description": "Short slug-like identifier (e.g., 'create-auth-service')"
        },
        "integrationPoint": {
          "type": "string",
          "description": "The integration point this task addresses",
          "x-arktype": "IntegrationPoint",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single",
          "x-reference-target": "IntegrationPoint"
        },
        "requirement": {
          "type": "string",
          "description": "Reference to Requirement for traceability",
          "x-arktype": "Requirement",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single",
          "x-reference-target": "Requirement"
        },
        "description": {
          "type": "string",
          "description": "What this task accomplishes"
        },
        "acceptanceCriteria": {
          "type": "array",
          "description": "Conditions that must be met for task completion",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "description": "Tasks that must complete before this one",
          "items": {
            "type": "string"
          },
          "x-mst-type": "reference",
          "x-reference-type": "array",
          "x-arktype": "ImplementationTask",
          "x-reference-target": "ImplementationTask"
        },
        "status": {
          "type": "string",
          "description": "Current task status",
          "enum": [
            "planned",
            "in_progress",
            "complete",
            "blocked"
          ],
          "x-renderer": "task-status-badge"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "session",
        "name",
        "description",
        "acceptanceCriteria",
        "status",
        "createdAt"
      ],
      "x-original-name": "ImplementationTask"
    },
    "TestSpecification": {
      "type": "object",
      "description": "A task-scoped test specification in Given/When/Then format",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "scenario",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "task": {
          "type": "string",
          "description": "The implementation task this test validates",
          "x-arktype": "ImplementationTask",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "ImplementationTask"
        },
        "requirement": {
          "type": "string",
          "description": "Reference to Requirement for traceability",
          "x-arktype": "Requirement",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single",
          "x-reference-target": "Requirement"
        },
        "scenario": {
          "type": "string",
          "description": "Brief description of what this test verifies (used as filename)"
        },
        "given": {
          "type": "array",
          "description": "Preconditions for the test",
          "items": {
            "type": "string"
          }
        },
        "when": {
          "type": "string",
          "description": "Action being tested"
        },
        "then": {
          "type": "array",
          "description": "Expected outcomes",
          "items": {
            "type": "string"
          }
        },
        "testType": {
          "type": "string",
          "description": "Level of testing",
          "enum": [
            "unit",
            "integration",
            "acceptance"
          ],
          "x-renderer": "test-type-badge"
        },
        "targetFile": {
          "type": "string",
          "description": "File path where this test should be implemented"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "task",
        "scenario",
        "given",
        "when",
        "then",
        "testType",
        "createdAt"
      ],
      "x-original-name": "TestSpecification"
    },
    "ImplementationRun": {
      "type": "object",
      "description": "A single execution run of the implementation skill",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "id",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "session": {
          "type": "string",
          "x-arktype": "FeatureSession",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "FeatureSession"
        },
        "status": {
          "type": "string",
          "description": "Current run status",
          "enum": [
            "in_progress",
            "blocked",
            "complete",
            "failed"
          ],
          "x-renderer": "run-status-badge"
        },
        "currentTaskId": {
          "type": "string",
          "description": "Task currently being executed"
        },
        "completedTasks": {
          "type": "array",
          "description": "IDs of successfully completed tasks",
          "items": {
            "type": "string"
          }
        },
        "failedTasks": {
          "type": "array",
          "description": "IDs of tasks that failed/blocked",
          "items": {
            "type": "string"
          }
        },
        "startedAt": {
          "type": "number"
        },
        "completedAt": {
          "type": "number"
        },
        "lastError": {
          "type": "string",
          "description": "Most recent error message if any"
        }
      },
      "required": [
        "id",
        "session",
        "status",
        "startedAt"
      ],
      "x-original-name": "ImplementationRun"
    },
    "TaskExecution": {
      "type": "object",
      "description": "Execution record for a single task attempt",
      "x-persistence": {
        "strategy": "entity-per-file",
        "partitionKey": "run",
        "nested": true
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "run": {
          "type": "string",
          "description": "Reference to ImplementationRun",
          "x-arktype": "ImplementationRun",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "ImplementationRun"
        },
        "task": {
          "type": "string",
          "description": "Reference to ImplementationTask",
          "x-arktype": "ImplementationTask",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "ImplementationTask"
        },
        "status": {
          "type": "string",
          "description": "Current execution status",
          "enum": [
            "pending",
            "test_written",
            "test_failing",
            "implementing",
            "test_passing",
            "failed"
          ],
          "x-renderer": "execution-status-badge"
        },
        "testFilePath": {
          "type": "string",
          "description": "Path to generated test file"
        },
        "implementationFilePath": {
          "type": "string",
          "description": "Path to implementation file"
        },
        "testOutput": {
          "type": "string",
          "description": "Output from test runner"
        },
        "retryCount": {
          "type": "number",
          "description": "Number of retry attempts"
        },
        "errorMessage": {
          "type": "string",
          "description": "Error message if failed"
        },
        "startedAt": {
          "type": "number"
        },
        "completedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "run",
        "task",
        "status",
        "startedAt"
      ],
      "x-original-name": "TaskExecution"
    }
  }
}