{
  "id": "82df2a29-8ae4-4a29-911e-8ca7cd8150de",
  "name": "platform-feature-spec",
  "format": "enhanced-json-schema",
  "createdAt": 1764798381622,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "AnalysisFinding": {
      "type": "object",
      "description": "A finding from codebase analysis relevant to implementing a platform feature",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique finding identifier",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "sessionId": {
          "type": "string",
          "description": "Reference to PlatformFeatureSession ID (cross-schema)",
          "enum": []
        },
        "type": {
          "type": "string",
          "description": "Category of finding",
          "enum": [
            "pattern",
            "integration_point",
            "risk",
            "gap",
            "existing_test",
            "verification"
          ]
        },
        "description": {
          "type": "string",
          "description": "What was found",
          "enum": []
        },
        "location": {
          "type": "string",
          "description": "File path, package, or module where this applies",
          "enum": []
        },
        "relevantCode": {
          "type": "string",
          "description": "Code snippet or reference illustrating the finding",
          "enum": []
        },
        "recommendation": {
          "type": "string",
          "description": "Suggested action based on this finding",
          "enum": []
        },
        "createdAt": {
          "type": "number",
          "description": "Finding creation timestamp (epoch ms)",
          "enum": []
        }
      },
      "required": [
        "id",
        "sessionId",
        "type",
        "description",
        "location",
        "createdAt"
      ],
      "x-original-name": "AnalysisFinding"
    },
    "IntegrationPoint": {
      "type": "object",
      "description": "A specific location in the codebase where changes will be made",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique integration point identifier",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "sessionId": {
          "type": "string",
          "description": "Reference to PlatformFeatureSession ID (cross-schema)",
          "enum": []
        },
        "finding": {
          "type": "string",
          "description": "The analysis finding that identified this point",
          "enum": [],
          "x-mst-type": "reference",
          "x-reference-type": "single"
        },
        "package": {
          "type": "string",
          "description": "Package name (e.g., packages/mcp, apps/web)",
          "enum": []
        },
        "filePath": {
          "type": "string",
          "description": "Relative file path within the package",
          "enum": []
        },
        "targetFunction": {
          "type": "string",
          "description": "Specific function or class to modify (optional)",
          "enum": []
        },
        "changeType": {
          "type": "string",
          "description": "Type of change required",
          "enum": [
            "add",
            "modify",
            "extend",
            "remove"
          ]
        },
        "description": {
          "type": "string",
          "description": "What needs to happen at this location",
          "enum": []
        },
        "rationale": {
          "type": "string",
          "description": "Why this is the right place for this change",
          "enum": []
        },
        "createdAt": {
          "type": "number",
          "description": "Creation timestamp (epoch ms)",
          "enum": []
        }
      },
      "required": [
        "id",
        "sessionId",
        "package",
        "filePath",
        "changeType",
        "description",
        "createdAt"
      ],
      "x-original-name": "IntegrationPoint"
    },
    "ImplementationTask": {
      "type": "object",
      "description": "A discrete unit of work to implement part of a platform feature",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique task identifier",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "sessionId": {
          "type": "string",
          "description": "Reference to PlatformFeatureSession ID (cross-schema)",
          "enum": []
        },
        "integrationPoint": {
          "type": "string",
          "description": "The integration point this task addresses",
          "enum": [],
          "x-mst-type": "reference",
          "x-reference-type": "single"
        },
        "requirementId": {
          "type": "string",
          "description": "Reference to Requirement ID (cross-schema, for traceability)",
          "enum": []
        },
        "description": {
          "type": "string",
          "description": "What this task accomplishes",
          "enum": []
        },
        "acceptanceCriteria": {
          "type": "array",
          "description": "Conditions that must be met for task completion",
          "enum": []
        },
        "dependencies": {
          "type": "array",
          "description": "Tasks that must complete before this one",
          "enum": [],
          "x-mst-type": "reference",
          "x-reference-type": "array"
        },
        "status": {
          "type": "string",
          "description": "Current task status",
          "enum": [
            "planned",
            "in_progress",
            "complete",
            "blocked"
          ]
        },
        "createdAt": {
          "type": "number",
          "description": "Creation timestamp (epoch ms)",
          "enum": []
        },
        "updatedAt": {
          "type": "number",
          "description": "Last update timestamp (epoch ms)",
          "enum": []
        }
      },
      "required": [
        "id",
        "sessionId",
        "integrationPoint",
        "description",
        "acceptanceCriteria",
        "status",
        "createdAt"
      ],
      "x-original-name": "ImplementationTask"
    },
    "TestSpecification": {
      "type": "object",
      "description": "A test case specification in Given/When/Then format",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique test spec identifier",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "sessionId": {
          "type": "string",
          "description": "Reference to PlatformFeatureSession ID (cross-schema)",
          "enum": []
        },
        "task": {
          "type": "string",
          "description": "The implementation task this test validates",
          "enum": [],
          "x-mst-type": "reference",
          "x-reference-type": "single"
        },
        "requirementId": {
          "type": "string",
          "description": "Reference to Requirement ID (cross-schema, for traceability)",
          "enum": []
        },
        "scenario": {
          "type": "string",
          "description": "Brief description of what this test verifies",
          "enum": []
        },
        "given": {
          "type": "array",
          "description": "Preconditions for the test",
          "enum": []
        },
        "when": {
          "type": "string",
          "description": "Action being tested",
          "enum": []
        },
        "then": {
          "type": "array",
          "description": "Expected outcomes",
          "enum": []
        },
        "testType": {
          "type": "string",
          "description": "Level of testing",
          "enum": [
            "unit",
            "integration",
            "acceptance"
          ]
        },
        "targetFile": {
          "type": "string",
          "description": "File path where this test should be implemented",
          "enum": []
        },
        "createdAt": {
          "type": "number",
          "description": "Creation timestamp (epoch ms)",
          "enum": []
        }
      },
      "required": [
        "id",
        "sessionId",
        "task",
        "scenario",
        "given",
        "when",
        "then",
        "testType",
        "createdAt"
      ],
      "x-original-name": "TestSpecification"
    },
    "ImplementationRun": {
      "type": "object",
      "description": "A single execution run of the implementation skill",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique run identifier",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "sessionId": {
          "type": "string",
          "description": "Reference to PlatformFeatureSession ID (cross-schema)",
          "enum": []
        },
        "status": {
          "type": "string",
          "description": "Current run status",
          "enum": [
            "in_progress",
            "blocked",
            "complete",
            "failed"
          ]
        },
        "currentTaskId": {
          "type": "string",
          "description": "Task currently being executed",
          "enum": []
        },
        "completedTasks": {
          "type": "array",
          "description": "IDs of successfully completed tasks",
          "enum": []
        },
        "failedTasks": {
          "type": "array",
          "description": "IDs of tasks that failed/blocked",
          "enum": []
        },
        "startedAt": {
          "type": "number",
          "description": "Run start timestamp (epoch ms)",
          "enum": []
        },
        "completedAt": {
          "type": "number",
          "description": "Run completion timestamp (epoch ms)",
          "enum": []
        },
        "lastError": {
          "type": "string",
          "description": "Most recent error message if any",
          "enum": []
        }
      },
      "required": [
        "id",
        "sessionId",
        "status",
        "startedAt"
      ],
      "x-original-name": "ImplementationRun"
    },
    "TaskExecution": {
      "type": "object",
      "description": "Execution record for a single task attempt",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique execution identifier",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "runId": {
          "type": "string",
          "description": "Reference to ImplementationRun",
          "enum": [],
          "x-mst-type": "reference",
          "x-reference-type": "single"
        },
        "taskId": {
          "type": "string",
          "description": "Reference to ImplementationTask",
          "enum": [],
          "x-mst-type": "reference",
          "x-reference-type": "single"
        },
        "status": {
          "type": "string",
          "description": "Current execution status",
          "enum": [
            "pending",
            "test_written",
            "test_failing",
            "implementing",
            "test_passing",
            "failed"
          ]
        },
        "testFilePath": {
          "type": "string",
          "description": "Path to generated test file",
          "enum": []
        },
        "implementationFilePath": {
          "type": "string",
          "description": "Path to implementation file",
          "enum": []
        },
        "testOutput": {
          "type": "string",
          "description": "Output from test runner",
          "enum": []
        },
        "retryCount": {
          "type": "number",
          "description": "Number of retry attempts",
          "enum": []
        },
        "errorMessage": {
          "type": "string",
          "description": "Error message if failed",
          "enum": []
        },
        "startedAt": {
          "type": "number",
          "description": "Execution start timestamp (epoch ms)",
          "enum": []
        },
        "completedAt": {
          "type": "number",
          "description": "Execution completion timestamp (epoch ms)",
          "enum": []
        }
      },
      "required": [
        "id",
        "runId",
        "taskId",
        "status",
        "startedAt"
      ],
      "x-original-name": "TaskExecution"
    }
  }
}