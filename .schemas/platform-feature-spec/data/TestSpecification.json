    "test-001": {
      "id": "test-001",
      "sessionId": "supabase-auth-001",
      "requirementId": "req-auth-006",
      "scenario": "MockAuthService.signUp creates user and session",
      "given": [
        "MockAuthService instance is created",
        "No user exists with email 'test@example.com'"
      ],
      "when": "signUp('test@example.com', 'password123') is called",
      "then": [
        "Returns AuthResult with user.email === 'test@example.com'",
        "Returns AuthResult with session.userId matching user.id",
        "user.emailVerified === false initially"
      ],
      "testType": "unit",
      "targetFile": "packages/state-api/tests/auth/mock-auth-service.test.ts",
      "createdAt": 1733419000000,
      "task": "task-002"
    },
