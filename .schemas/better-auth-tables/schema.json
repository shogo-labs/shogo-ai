{
  "id": "5fb779e3-aca4-4058-bbad-a61fe773c54c",
  "name": "better-auth-tables",
  "format": "enhanced-json-schema",
  "createdAt": 1767158466659,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique user identifier",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "User's display name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "emailVerified": {
          "type": "boolean",
          "description": "Whether the user's email has been verified"
        },
        "image": {
          "type": "string",
          "format": "uri",
          "description": "URL to user's profile image"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when user was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when user was last updated"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt",
        "updatedAt"
      ],
      "x-original-name": "User"
    },
    "Session": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique session identifier",
          "x-mst-type": "identifier"
        },
        "userId": {
          "$ref": "#/$defs/User",
          "x-reference-type": "single"
        },
        "token": {
          "type": "string",
          "description": "Session token for authentication"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when session expires"
        },
        "ipAddress": {
          "type": "string",
          "description": "IP address from which session was created"
        },
        "userAgent": {
          "type": "string",
          "description": "User agent string of the client"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when session was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when session was last updated"
        }
      },
      "required": [
        "id",
        "userId",
        "token",
        "expiresAt",
        "createdAt",
        "updatedAt"
      ],
      "x-original-name": "Session"
    },
    "Account": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique account identifier",
          "x-mst-type": "identifier"
        },
        "userId": {
          "$ref": "#/$defs/User",
          "x-reference-type": "single"
        },
        "accountId": {
          "type": "string",
          "description": "External account ID from the OAuth provider"
        },
        "providerId": {
          "type": "string",
          "description": "OAuth provider identifier (e.g., 'google', 'github')"
        },
        "accessToken": {
          "type": "string",
          "description": "OAuth access token"
        },
        "refreshToken": {
          "type": "string",
          "description": "OAuth refresh token"
        },
        "accessTokenExpiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when access token expires"
        },
        "refreshTokenExpiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when refresh token expires"
        },
        "scope": {
          "type": "string",
          "description": "OAuth scopes granted to this account"
        },
        "idToken": {
          "type": "string",
          "description": "OAuth ID token from provider (e.g., Google)"
        },
        "password": {
          "type": "string",
          "description": "Hashed password for credential-based auth"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when account was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when account was last updated"
        }
      },
      "required": [
        "id",
        "userId",
        "accountId",
        "providerId",
        "createdAt",
        "updatedAt"
      ],
      "x-original-name": "Account"
    },
    "Verification": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique verification identifier",
          "x-mst-type": "identifier"
        },
        "identifier": {
          "type": "string",
          "description": "The identifier being verified (e.g., email address)"
        },
        "value": {
          "type": "string",
          "description": "The verification token or code"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when verification expires"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when verification was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when verification was last updated"
        }
      },
      "required": [
        "id",
        "identifier",
        "value",
        "expiresAt",
        "createdAt",
        "updatedAt"
      ],
      "x-original-name": "Verification"
    }
  },
  "x-persistence": {
    "backend": "postgres"
  }
}