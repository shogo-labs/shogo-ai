{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user-schema",
  "x-persistence": {
    "backend": "sql"
  },
  "$defs": {
    "User": {
      "type": "object",
      "x-original-name": "User",
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "age": {
          "type": "integer"
        }
      },
      "required": [
        "id",
        "name"
      ]
    }
  }
}