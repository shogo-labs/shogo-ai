{
  "id": "412df770-a3b4-4cfd-846f-434dc7707484",
  "name": "component-builder",
  "format": "enhanced-json-schema",
  "createdAt": 1767839088233,
  "version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "component-builder",
  "$defs": {
    "ComponentDefinition": {
      "type": "object",
      "description": "A reusable UI component definition with metadata for registration and rendering",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable component name (e.g., 'String Display')"
        },
        "category": {
          "type": "string",
          "description": "Component category for organization and filtering",
          "enum": [
            "display",
            "input",
            "layout",
            "visualization"
          ],
          "x-renderer": "category-badge"
        },
        "description": {
          "type": "string",
          "description": "Documentation for the component's purpose and usage"
        },
        "propsSchema": {
          "type": "object",
          "description": "JSON Schema defining the component's props interface"
        },
        "implementationRef": {
          "type": "string",
          "description": "Key mapping to code-side component registry (e.g., 'StringDisplay', '@shogo/web/displays/StringDisplay')"
        },
        "previewRef": {
          "type": "string",
          "description": "Optional reference for catalog thumbnail or preview image"
        },
        "tags": {
          "type": "array",
          "description": "Tags for categorization and search (e.g., ['primitive', 'text', 'readonly'])"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "category",
        "implementationRef",
        "createdAt"
      ],
      "x-original-name": "ComponentDefinition"
    },
    "Registry": {
      "type": "object",
      "description": "A component registry that maps PropertyMetadata to ComponentDefinitions via bindings",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "Registry name (e.g., 'default', 'studio', 'domain-specific')"
        },
        "description": {
          "type": "string",
          "description": "Documentation for the registry's purpose and scope"
        },
        "extends": {
          "type": "string",
          "description": "Parent registry for inheritance chain (child bindings take priority)",
          "x-arktype": "Registry",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single",
          "x-reference-target": "Registry"
        },
        "fallbackComponent": {
          "type": "string",
          "description": "Component used when no bindings match",
          "x-arktype": "ComponentDefinition",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single",
          "x-reference-target": "ComponentDefinition"
        },
        "bindings": {
          "type": "array",
          "description": "Computed inverse: all RendererBindings pointing to this registry",
          "x-computed": true,
          "x-inverse": "RendererBinding.registry"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "createdAt"
      ],
      "x-original-name": "Registry"
    },
    "RendererBinding": {
      "type": "object",
      "description": "Binds a ComponentDefinition to a Registry via a MongoDB-style match expression",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "Descriptive binding name (e.g., 'string-enum-renderer', 'explicit-x-renderer')"
        },
        "registry": {
          "type": "string",
          "description": "The registry this binding belongs to",
          "x-arktype": "Registry",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "Registry"
        },
        "component": {
          "type": "string",
          "description": "The component to render when this binding matches",
          "x-arktype": "ComponentDefinition",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "ComponentDefinition"
        },
        "matchExpression": {
          "type": "object",
          "description": "MongoDB-style query evaluated against PropertyMetadata (e.g., {type: 'string', enum: {$exists: true}})"
        },
        "priority": {
          "type": "number",
          "description": "Resolution priority (higher wins). Convention: 200=explicit x-renderer, 100=computed/ref, 50=enum, 30=format, 10=type, 0=fallback"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "registry",
        "component",
        "matchExpression",
        "priority",
        "createdAt"
      ],
      "x-original-name": "RendererBinding"
    },
    "LayoutTemplate": {
      "type": "object",
      "description": "A slot-based layout template defining areas where components can be placed",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "Layout name (e.g., 'two-column', 'dashboard-grid', 'detail-panel')"
        },
        "description": {
          "type": "string",
          "description": "Documentation for the layout's structure and intended use"
        },
        "slots": {
          "type": "array",
          "description": "Slot definitions specifying available placement areas"
        },
        "defaultBindings": {
          "type": "object",
          "description": "Default slot-to-component mappings as {slotName: componentId}"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "slots",
        "createdAt"
      ],
      "x-original-name": "LayoutTemplate"
    },
    "Composition": {
      "type": "object",
      "description": "A concrete page or view composed from a LayoutTemplate with slot content and data bindings",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "Composition name (e.g., 'Feature Session Detail View', 'User Dashboard')"
        },
        "layout": {
          "type": "string",
          "description": "The LayoutTemplate this composition uses",
          "x-arktype": "LayoutTemplate",
          "x-mst-type": "reference",
          "x-reference-type": "single",
          "x-reference-target": "LayoutTemplate"
        },
        "slotContent": {
          "type": "array",
          "description": "Content placed in each slot"
        },
        "dataContext": {
          "type": "object",
          "description": "Shared data source definitions available to all slot components"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "layout",
        "slotContent",
        "createdAt"
      ],
      "x-original-name": "Composition"
    }
  },
  "x-persistence": {
    "backend": "memory"
  }
}