{
  "id": "248015c9-f1b7-4c68-b106-6878f8596e82",
  "name": "pos-app",
  "format": "enhanced-json-schema",
  "createdAt": 1764729558101,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Product": {
      "type": "object",
      "description": "Items available for sale",
      "properties": {
        "id": {
          "type": "string",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "enum": []
        },
        "sku": {
          "type": "string",
          "description": "Stock Keeping Unit - unique product code",
          "enum": []
        },
        "price": {
          "type": "number",
          "description": "Unit price in cents",
          "minimum": 0,
          "enum": []
        },
        "quantity": {
          "type": "integer",
          "description": "Current stock quantity",
          "minimum": 0,
          "enum": []
        },
        "category": {
          "type": "string",
          "enum": []
        },
        "active": {
          "type": "boolean",
          "enum": []
        }
      },
      "required": [
        "id",
        "name",
        "price"
      ],
      "x-original-name": "Product"
    },
    "Customer": {
      "type": "object",
      "description": "Customer information",
      "properties": {
        "id": {
          "type": "string",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "enum": []
        },
        "email": {
          "type": "string",
          "format": "email",
          "enum": []
        },
        "phone": {
          "type": "string",
          "enum": []
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "enum": []
        }
      },
      "required": [
        "id",
        "name"
      ],
      "x-original-name": "Customer"
    },
    "OrderItem": {
      "type": "object",
      "description": "A line item in an order",
      "properties": {
        "id": {
          "type": "string",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "productId": {
          "type": "string",
          "enum": [],
          "x-mst-type": "reference"
        },
        "productName": {
          "type": "string",
          "description": "Snapshot of product name at time of sale",
          "enum": []
        },
        "unitPrice": {
          "type": "number",
          "description": "Price per unit at time of sale (in cents)",
          "minimum": 0,
          "enum": []
        },
        "quantity": {
          "type": "integer",
          "minimum": 1,
          "enum": []
        }
      },
      "required": [
        "id",
        "productId",
        "productName",
        "unitPrice",
        "quantity"
      ],
      "x-original-name": "OrderItem"
    },
    "Order": {
      "type": "object",
      "description": "A sales transaction",
      "properties": {
        "id": {
          "type": "string",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "orderNumber": {
          "type": "string",
          "description": "Human-readable order number",
          "enum": []
        },
        "customerId": {
          "type": "string",
          "description": "Optional customer reference",
          "enum": [],
          "x-mst-type": "maybe-reference"
        },
        "items": {
          "type": "array",
          "enum": []
        },
        "subtotal": {
          "type": "number",
          "description": "Total before tax (in cents)",
          "minimum": 0,
          "enum": []
        },
        "taxAmount": {
          "type": "number",
          "description": "Tax amount (in cents)",
          "minimum": 0,
          "enum": []
        },
        "total": {
          "type": "number",
          "description": "Final total (in cents)",
          "minimum": 0,
          "enum": []
        },
        "paymentMethod": {
          "type": "string",
          "enum": [
            "cash",
            "card",
            "other"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "completed",
            "refunded",
            "cancelled"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "enum": []
        }
      },
      "required": [
        "id",
        "orderNumber",
        "items",
        "subtotal",
        "total",
        "status",
        "createdAt"
      ],
      "x-original-name": "Order"
    }
  }
}