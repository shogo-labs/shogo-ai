{
  "id": "3c948b02-54f2-4880-b8a6-eba46708d5b8",
  "name": "ai-sdk-chat-component",
  "format": "enhanced-json-schema",
  "createdAt": 1766002741083,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "ChatSession": {
      "type": "object",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": false
      },
      "properties": {
        "id": {
          "type": "string",
          "x-arktype": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "description": "User-friendly name for the chat session",
          "x-arktype": "string"
        },
        "claudeSessionId": {
          "type": "string",
          "description": "Session ID from Claude Code for multi-turn context",
          "x-arktype": "string | undefined"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "completed",
            "error"
          ],
          "x-arktype": "'active' | 'completed' | 'error'"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when session was created",
          "x-arktype": "number"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of last update",
          "x-arktype": "number | undefined"
        }
      },
      "required": [
        "id",
        "name",
        "status",
        "createdAt"
      ],
      "x-original-name": "ChatSession"
    }
  }
}