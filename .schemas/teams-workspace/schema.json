{
  "id": "93632e33-8753-4183-ab0a-f4c89a6a5208",
  "name": "teams-workspace",
  "format": "enhanced-json-schema",
  "createdAt": 1765353322923,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Organization": {
      "type": "object",
      "description": "Top-level container entity. All teams and memberships exist within an organization context.",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "slug"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "settings": {
          "type": "object"
        },
        "createdAt": {
          "type": "number"
        },
        "teams": {
          "type": "array",
          "x-arktype": "Team[]",
          "x-computed": true,
          "x-inverse": "organization"
        },
        "memberships": {
          "type": "array",
          "x-arktype": "Membership[]",
          "x-computed": true,
          "x-inverse": "organization"
        },
        "invitations": {
          "type": "array",
          "x-arktype": "Invitation[]",
          "x-computed": true,
          "x-inverse": "organization"
        }
      },
      "required": [
        "id",
        "name",
        "slug",
        "createdAt"
      ],
      "x-original-name": "Organization"
    },
    "Team": {
      "type": "object",
      "description": "Team within an organization. Supports nested hierarchies via self-reference.",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "name",
        "nested": true,
        "partitionKey": "organization"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "organization": {
          "type": "string",
          "x-arktype": "Organization",
          "x-mst-type": "reference",
          "x-reference-type": "single"
        },
        "parent": {
          "type": "string",
          "x-arktype": "Team",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single"
        },
        "createdAt": {
          "type": "number"
        },
        "children": {
          "type": "array",
          "x-arktype": "Team[]",
          "x-computed": true,
          "x-inverse": "parent"
        },
        "apps": {
          "type": "array",
          "x-arktype": "App[]",
          "x-computed": true,
          "x-inverse": "team"
        },
        "memberships": {
          "type": "array",
          "x-arktype": "Membership[]",
          "x-computed": true,
          "x-inverse": "team"
        },
        "invitations": {
          "type": "array",
          "x-arktype": "Invitation[]",
          "x-computed": true,
          "x-inverse": "team"
        }
      },
      "required": [
        "id",
        "name",
        "organization",
        "createdAt"
      ],
      "x-original-name": "Team"
    },
    "App": {
      "type": "object",
      "description": "First-class entity in permission chain. Apps belong to exactly one team.",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "slug",
        "nested": true,
        "partitionKey": "team"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "team": {
          "type": "string",
          "x-arktype": "Team",
          "x-mst-type": "reference",
          "x-reference-type": "single"
        },
        "settings": {
          "type": "object"
        },
        "createdAt": {
          "type": "number"
        },
        "memberships": {
          "type": "array",
          "x-arktype": "Membership[]",
          "x-computed": true,
          "x-inverse": "app"
        },
        "invitations": {
          "type": "array",
          "x-arktype": "Invitation[]",
          "x-computed": true,
          "x-inverse": "app"
        }
      },
      "required": [
        "id",
        "name",
        "slug",
        "team",
        "createdAt"
      ],
      "x-original-name": "App"
    },
    "Membership": {
      "type": "object",
      "description": "Polymorphic membership across org/team/app levels. Exactly one reference must be set.",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "userId"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "userId": {
          "type": "string",
          "description": "External reference to auth system user"
        },
        "organization": {
          "type": "string",
          "x-arktype": "Organization",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single"
        },
        "team": {
          "type": "string",
          "x-arktype": "Team",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single"
        },
        "app": {
          "type": "string",
          "x-arktype": "App",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single"
        },
        "role": {
          "type": "string",
          "enum": ["owner", "admin", "member", "viewer"],
          "description": "Permission role: owner > admin > member > viewer"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "userId",
        "role",
        "createdAt"
      ],
      "x-original-name": "Membership"
    },
    "Invitation": {
      "type": "object",
      "description": "Invitation to join org/team/app. Has expiration and status tracking.",
      "x-persistence": {
        "strategy": "entity-per-file",
        "displayKey": "email"
      },
      "properties": {
        "id": {
          "type": "string",
          "x-mst-type": "identifier"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "invitedBy": {
          "type": "string",
          "description": "userId of the inviter"
        },
        "organization": {
          "type": "string",
          "x-arktype": "Organization",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single"
        },
        "team": {
          "type": "string",
          "x-arktype": "Team",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single"
        },
        "app": {
          "type": "string",
          "x-arktype": "App",
          "x-mst-type": "maybe-reference",
          "x-reference-type": "single"
        },
        "role": {
          "type": "string",
          "enum": ["owner", "admin", "member", "viewer"],
          "description": "Permission role for the invitation"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "declined", "expired"]
        },
        "expiresAt": {
          "type": "number"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "email",
        "invitedBy",
        "role",
        "status",
        "expiresAt",
        "createdAt"
      ],
      "x-original-name": "Invitation"
    }
  }
}