{
  "id": "a7fe738f-826f-42f1-8b5a-04610b199d4b",
  "name": "app-builder-documentor",
  "format": "enhanced-json-schema",
  "createdAt": 1761868720738,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "DocumentationSession": {
      "type": "object",
      "description": "Root orchestrator for a documentation generation session",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier",
          "enum": []
        },
        "name": {
          "type": "string",
          "description": "Session name",
          "enum": []
        },
        "implementationSession": {
          "type": "string",
          "description": "Reference to Layer 2.5 ImplementationSession",
          "enum": [],
          "x-mst-type": "reference"
        },
        "discoverySession": {
          "type": "string",
          "description": "Reference to Layer 1 DiscoverySession for context",
          "enum": [],
          "x-mst-type": "reference"
        },
        "appSchemaName": {
          "type": "string",
          "description": "Name of the Layer 2 application schema",
          "enum": []
        },
        "requestedTypes": {
          "type": "array",
          "description": "Requested document types",
          "enum": [],
          "items": {
            "type": "string",
            "enum": []
          }
        },
        "currentPhase": {
          "type": "string",
          "description": "Current phase",
          "enum": [
            "contextualization",
            "alignment",
            "synthesis",
            "validation",
            "complete"
          ]
        },
        "workspacePath": {
          "type": "string",
          "description": "Workspace path for generated docs",
          "enum": []
        },
        "createdAt": {
          "type": "number",
          "description": "Unix timestamp",
          "enum": []
        },
        "completedAt": {
          "type": "number",
          "description": "Unix timestamp",
          "enum": []
        }
      },
      "required": [
        "id",
        "name",
        "implementationSession",
        "appSchemaName",
        "currentPhase",
        "workspacePath",
        "createdAt"
      ],
      "x-original-name": "DocumentationSession"
    },
    "DocumentationPlan": {
      "type": "object",
      "description": "Documentation plan created during alignment phase",
      "properties": {
        "id": {
          "type": "string",
          "enum": []
        },
        "session": {
          "type": "string",
          "description": "Reference to DocumentationSession",
          "enum": [],
          "x-mst-type": "reference"
        },
        "coverage": {
          "type": "object",
          "description": "OPAQUE: Which modules/interfaces/tests to document",
          "enum": []
        },
        "traceabilityPaths": {
          "type": "object",
          "description": "OPAQUE: Verified paths to requirements",
          "enum": []
        },
        "composedSkills": {
          "type": "array",
          "description": "Skills to invoke (e.g., artifacts-builder)",
          "enum": [],
          "items": {
            "type": "string",
            "enum": []
          }
        },
        "createdAt": {
          "type": "number",
          "enum": []
        }
      },
      "required": [
        "id",
        "session",
        "coverage",
        "traceabilityPaths",
        "createdAt"
      ],
      "x-original-name": "DocumentationPlan"
    },
    "DocumentEntity": {
      "type": "object",
      "description": "Unified document entity (architecture/API/guide/test/provenance)",
      "properties": {
        "id": {
          "type": "string",
          "enum": []
        },
        "session": {
          "type": "string",
          "description": "Reference to DocumentationSession",
          "enum": [],
          "x-mst-type": "reference"
        },
        "type": {
          "type": "string",
          "description": "Document type",
          "enum": [
            "architecture",
            "api-reference",
            "implementation-guide",
            "test-documentation",
            "provenance"
          ]
        },
        "title": {
          "type": "string",
          "enum": []
        },
        "content": {
          "type": "object",
          "description": "OPAQUE: Markdown, HTML, or other format",
          "enum": []
        },
        "references": {
          "type": "object",
          "description": "OPAQUE: Back-references to Layer 2.5/2/1 entities",
          "enum": []
        },
        "metadata": {
          "type": "object",
          "description": "OPAQUE: Format, audience, related docs",
          "enum": []
        },
        "createdAt": {
          "type": "number",
          "enum": []
        }
      },
      "required": [
        "id",
        "session",
        "type",
        "title",
        "content",
        "createdAt"
      ],
      "x-original-name": "DocumentEntity"
    },
    "Diagram": {
      "type": "object",
      "description": "Diagram specification (Mermaid or HTML artifact)",
      "properties": {
        "id": {
          "type": "string",
          "enum": []
        },
        "session": {
          "type": "string",
          "description": "Reference to DocumentationSession",
          "enum": [],
          "x-mst-type": "reference"
        },
        "type": {
          "type": "string",
          "description": "Diagram type",
          "enum": [
            "architecture",
            "dataflow",
            "test-coverage",
            "entity-relationship"
          ]
        },
        "format": {
          "type": "string",
          "description": "Diagram format",
          "enum": [
            "mermaid",
            "html-artifact"
          ]
        },
        "source": {
          "type": "object",
          "description": "OPAQUE: Diagram source code or spec",
          "enum": []
        },
        "references": {
          "type": "object",
          "description": "OPAQUE: Entities depicted in diagram",
          "enum": []
        },
        "createdAt": {
          "type": "number",
          "enum": []
        }
      },
      "required": [
        "id",
        "session",
        "type",
        "format",
        "source",
        "createdAt"
      ],
      "x-original-name": "Diagram"
    }
  }
}