{
  "id": "dd2a6618-0a68-47bd-85ff-d9e37cee4bcf",
  "name": "supabase-auth",
  "format": "enhanced-json-schema",
  "createdAt": 1765059164730,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "AuthUser": {
      "type": "object",
      "description": "User profile cached from Supabase Auth",
      "properties": {
        "id": {
          "type": "string",
          "description": "Supabase user UUID",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address",
          "enum": []
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created",
          "enum": []
        }
      },
      "required": [
        "id",
        "email",
        "createdAt"
      ],
      "x-original-name": "AuthUser"
    },
    "AuthSession": {
      "type": "object",
      "description": "Current authentication session state (singleton accessed via 'current' id)",
      "properties": {
        "id": {
          "type": "string",
          "description": "Always 'current' for singleton pattern",
          "enum": [],
          "x-mst-type": "identifier"
        },
        "user": {
          "$ref": "#/$defs/AuthUser",
          "x-reference-type": "single"
        },
        "lastRefreshedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the session was last verified with Supabase",
          "enum": []
        }
      },
      "required": [
        "id"
      ],
      "x-original-name": "AuthSession"
    }
  }
}