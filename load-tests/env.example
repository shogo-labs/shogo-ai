# Target Environment
# Note: API may be proxied through the web app, so these can point at the same host.
API_BASE_URL=https://app.example.com
WEB_BASE_URL=https://app.example.com

# Test Configuration
NUM_USERS=100
SPAWN_RATE=10
RUN_TIME=10m

# Test Credentials (created by setup script)
TEST_USER_PREFIX=loadtest-user
TEST_USER_PASSWORD=LoadTest123!

# Monitoring
PROMETHEUS_URL=http://prometheus-staging.shogo.ai
GRAFANA_URL=http://grafana-staging.shogo.ai

# Thresholds
MAX_RESPONSE_TIME_P95=2000
MAX_RESPONSE_TIME_P99=5000
MAX_ERROR_RATE=0.01

# Rate-limit bypass (must match LOAD_TEST_SECRET on the API server)
# When set, requests include X-Load-Test-Key header to skip rate limiting
LOAD_TEST_SECRET=

# Cleanup
CLEANUP_AFTER_TEST=true

# ---------------------------------------------------------------------------
# Multi-Region Load Test (used by scripts/run_multiregion.sh)
# ---------------------------------------------------------------------------

# Direct Kourier LB IPs for each production OCI region.
# Get these from terraform/environments/production-global/terraform.tfvars
# (us_lb_ip, eu_lb_ip, india_lb_ip).
US_HOST=
EU_HOST=
INDIA_HOST=

# Host header sent with every request when targeting a direct IP.
# Knative uses this to route traffic to the correct service.
HOST_HEADER=studio.shogo.ai

# Per-region user ID range (avoid signup collisions across parallel instances).
# The multiregion runner overrides these per-region:
#   US: 100000-199999, EU: 200000-299999, India: 300000-399999
USER_ID_MIN=200000
USER_ID_MAX=999999

# ---------------------------------------------------------------------------
# Cleanup (used by scripts/cleanup_loadtest.py)
# ---------------------------------------------------------------------------

# Super admin credentials for admin API access during cleanup
ADMIN_EMAIL=
ADMIN_PASSWORD=
