# Target Environment
# Note: API may be proxied through the web app, so these can point at the same host.
API_BASE_URL=https://app.example.com
WEB_BASE_URL=https://app.example.com

# Test Configuration
NUM_USERS=100
SPAWN_RATE=10
RUN_TIME=10m

# Test Credentials (created by setup script)
TEST_USER_PREFIX=loadtest-user
TEST_USER_PASSWORD=LoadTest123!

# Monitoring
PROMETHEUS_URL=http://prometheus-staging.shogo.ai
GRAFANA_URL=http://grafana-staging.shogo.ai

# Thresholds
MAX_RESPONSE_TIME_P95=2000
MAX_RESPONSE_TIME_P99=5000
MAX_ERROR_RATE=0.01

# Rate-limit bypass (must match LOAD_TEST_SECRET on the API server)
# When set, requests include X-Load-Test-Key header to skip rate limiting
LOAD_TEST_SECRET=

# Cleanup
CLEANUP_AFTER_TEST=true
