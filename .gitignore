**/.venv/
**/.venv.bak/

# output
out
dist
dist-client
*.tgz

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
# .env is a tracked symlink -> .env.local (for Docker Compose variable substitution)
# The actual secrets live in .env.local which remains ignored
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Turbo
.turbo

# Tool directories (Claude Code patterns)
_tmp/
.superdesign/
.cursor/
.codanna/
.codex/
.playwright-mcp/
.serena/

# Workspace files
*.code-workspace

# Schema session data (user-specific, generated at runtime)
# .schemas/*/data/
.schemas/*/workspaces/
!.data/
.data/*
!.data/.gitkeep

# Git worktrees (managed by git-gtr)
.worktrees/
# Terraform
.terraform/
*.tfstate
*.tfstate.*
# .terraform.lock.hcl - should be committed for version consistency
tfplan

# Kubernetes secrets (managed by GitHub Actions/Terraform, not committed)
k8s/**/secrets.yaml

apps/web/playwright-report/

apps/web/test-results/

workspaces/

.bun/
.npm/

/packages/sdk/examples/*/test-results
/packages/sdk/examples/*/playwright-report
/packages/sdk/examples/*/.output
/packages/sdk/examples/*/.nitro

# Vite/TanStack generated timestamp files (bust Docker cache)
app.config.timestamp*.js

# Chat export logs (auto-generated agent outputs)
shogo-chats/
