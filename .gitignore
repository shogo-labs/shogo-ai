# dependencies (bun install)
node_modules

# virtual environments
**/.venv/
**/.venv.bak/

# output
out
dist
dist-client
*.tgz

# code coverage
coverage
*.lcov
# …except the policy file consumed by scripts/run-all-tests.ts (see
# COVERAGE_EXCLUSIONS.md). It's policy, not generated output, and must
# be tracked so the strict gate has the same floors across machines.
!coverage/
coverage/*
!coverage/thresholds.json
!coverage/baselines/
!coverage/baselines/*
!coverage/coverage-tasks.json
!coverage/v5-inventory.json

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
# .env is a sanitized tracked example for local development
# Real secrets should live in .env.local, which remains ignored
.env
.env.production
.env.staging
.env.development.local
.env.test.local
.env.production.local
.env.local
.env.*.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Tool directories
_tmp/
.superdesign/
# Track shared Cursor project rules; ignore other .cursor noise
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.codanna/
.codex/
.playwright-mcp/
.serena/

# Workspace files
*.code-workspace

# Schema session data (user-specific, generated at runtime)
