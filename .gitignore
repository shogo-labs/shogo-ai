.schemas/*/workspaces/
!.data/
.data/*
!.data/.gitkeep

# Git worktrees (managed by git-gtr)
.worktrees/
# Terraform
.terraform/
*.tfstate
*.tfstate.*
# .terraform.lock.hcl - should be committed for version consistency
tfplan
*.auto.tfvars
terraform.tfvars
!terraform.tfvars.example

# Kubernetes secrets (managed by GitHub Actions/Terraform, not committed)
k8s/**/secrets.yaml

# Generated code (regenerated during build)
