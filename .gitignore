# dependencies (bun install)
node_modules

# virtual environments
**/.venv/
**/.venv.bak/

# output
out
dist
dist-client
*.tgz

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
# .env is a tracked symlink -> .env.local (for Docker Compose variable substitution)
# The actual secrets live in .env.local which remains ignored
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Turbo
.turbo

# Tool directories (Claude Code patterns)
_tmp/
.superdesign/
.cursor/
.codanna/
.codex/
.playwright-mcp/
.serena/

# Claude Code runtime artifacts (created by SDK, not tracked)
# Only .claude/skills/, .claude/agents/, and settings files are tracked
.claude/debug/
.claude/projects/
.claude/session-env/
.claude/shell-snapshots/
.claude/todos/
.claude/statsig/
.claude/plugins/
.claude/plans/
.claude.json
.claude.json.backup

# Config directories created by various tools (bun, node, etc.)
.config/

# Workspace files
*.code-workspace

# Schema session data (user-specific, generated at runtime)
# .schemas/*/data/
.schemas/*/workspaces/
!.data/
.data/*
!.data/.gitkeep

# Git worktrees (managed by git-gtr)
.worktrees/
# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
tfplan

# Kubernetes secrets (managed by GitHub Actions/Terraform, not committed)
k8s/**/secrets.yaml

apps/web/playwright-report/

apps/web/test-results/

workspaces/

.bun/
.npm/