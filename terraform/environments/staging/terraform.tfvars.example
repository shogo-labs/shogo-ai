# =============================================================================
# Terraform Variables Example - Staging
# Copy this file to terraform.tfvars and fill in the values
# =============================================================================
#
# BOOTSTRAP INSTRUCTIONS (for fresh deployment):
# 1. Set bootstrap_mode = true
# 2. Run: terraform apply (creates VPC, EKS, RDS, ElastiCache)
# 3. Set bootstrap_mode = false
# 4. Run: terraform apply (creates kubernetes resources, Knative, etc.)
# =============================================================================

# Bootstrap mode - set to true for initial deployment when EKS doesn't exist
# After EKS is created, set to false and re-apply to create kubernetes resources
bootstrap_mode = false

aws_region   = "us-east-1"
environment  = "staging"
project_name = "shogo"

# VPC Configuration (different CIDR from production)
vpc_cidr = "10.1.0.0/16"

# EKS Configuration (smaller than production for cost savings)
eks_cluster_version = "1.33"
node_instance_types = ["t3.medium"]
node_desired_size   = 1
node_min_size       = 1
node_max_size       = 5

# RDS Configuration (smaller than production)
rds_instance_class    = "db.t3.micro"
rds_allocated_storage = 20

# Redis Configuration
redis_node_type = "cache.t3.micro"

# Knative Configuration
knative_version = "1.20.0"
domain          = ""  # Optional: your domain (e.g., "shogo.ai")

# Application Secrets (REQUIRED - generate a random 32+ char string)
better_auth_secret = "your-staging-secret-key-at-least-32-characters"

# GitHub Actions CI/CD
github_org  = "your-github-username-or-org"
github_repo = "shogo-ai"

# =============================================================================
# Observability Configuration (SigNoz)
# =============================================================================

# Enable SigNoz K8s infrastructure monitoring
enable_signoz = true

# SigNoz OTLP endpoint (gRPC)
# Option 1: SigNoz Cloud (recommended for getting started)
#   US:    "ingest.us.signoz.cloud:443"
#   EU:    "ingest.eu.signoz.cloud:443"
#   India: "ingest.in.signoz.cloud:443"
#
# Option 2: Self-hosted in same cluster
#   "http://signoz-otel-collector.signoz.svc.cluster.local:4317"
#
# Option 3: External self-hosted
#   "https://your-signoz-domain.com:4317"
signoz_endpoint = ""  # REQUIRED if enable_signoz=true

# SigNoz Cloud ingestion key (only required for SigNoz Cloud)
# Get this from https://signoz.io/teams/ after signup
# Leave empty for self-hosted SigNoz
signoz_ingestion_key = ""

# Namespace for SigNoz collectors
signoz_namespace = "signoz"

# Feature toggles (logs disabled by default to reduce resource usage)
signoz_enable_logs    = false  # Container logs (can be verbose/expensive)
signoz_enable_events  = true   # K8s events (lightweight)
signoz_enable_metrics = true   # Node/pod metrics (essential)
