# =============================================================================
# Shogo AI - Local Development Environment Variables
# =============================================================================
# These are used when running apps locally with `bun run dev`
# For Docker dev mode, these are set in docker-compose.dev.yml
# =============================================================================

# Database (Docker postgres on port 5433)
DATABASE_URL=postgres://shogo:shogo_dev@localhost:5433/shogo

# API Server
API_PORT=8002
NODE_ENV=development

# BetterAuth
BETTER_AUTH_SECRET=shogo-local-dev-secret-32-chars-minimum-ok
BETTER_AUTH_URL=http://localhost:8002

# Redis
REDIS_URL=redis://localhost:6379

