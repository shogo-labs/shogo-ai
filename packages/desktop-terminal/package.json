{
  "name": "@shogo/desktop-terminal",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop-only renderer terminal pieces (DesktopPtyClient, ShogoTerminalSurface). Loaded LAZILY by apps/mobile pty-factory.ts when isDesktop() is true. Mobile/web must never reach this package.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "peerDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^18 || ^19"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shogo/pty-core": "workspace:*"
  },
  "devDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@types/react": "^19"
  }
}
