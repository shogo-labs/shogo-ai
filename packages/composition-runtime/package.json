{
  "name": "@shogo/composition-runtime",
  "version": "0.1.0",
  "description": "Composition rendering system - data-driven UI composition for Shogo apps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --external @shogo/state-api --external @shogo/app-core --external react --external react-dom --external mobx --external mobx-react-lite --external mobx-state-tree",
    "build:with-types": "bun run build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shogo/app-core": "workspace:*",
    "@shogo/state-api": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
