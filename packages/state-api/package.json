{
  "name": "@shogo/state-api",
  "version": "0.1.0",
  "description": "Schema-first reactive state management bridging arkType to MST with isomorphic execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./studio-core/domain": {
      "import": "./src/studio-core/domain.ts",
      "types": "./src/studio-core/domain.ts"
    },
    "./query/registry": {
      "import": "./src/query/registry.ts",
      "types": "./src/query/registry.ts"
    },
    "./query/backends/sql": {
      "import": "./src/query/backends/sql.ts",
      "types": "./src/query/backends/sql.ts"
    },
    "./query/execution/bun-postgres": {
      "import": "./src/query/execution/bun-postgres.ts",
      "types": "./src/query/execution/bun-postgres.ts"
    },
    "./query/execution/bun-sql": {
      "import": "./src/query/execution/bun-sql.ts",
      "types": "./src/query/execution/bun-sql.ts"
    },
    "./persistence/null": {
      "import": "./src/persistence/null.ts",
      "types": "./src/persistence/null.ts"
    },
    "./billing/domain": {
      "import": "./src/billing/domain.ts",
      "types": "./src/billing/domain.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ucast/core": "^1.10.2",
    "@ucast/js": "^3.0.4",
    "@ucast/mongo": "^2.4.3",
    "@ucast/sql": "^1.0.0-alpha.1",
    "arktype": "^2.0.0-beta.7",
    "jsondiffpatch": "^0.6.0",
    "mobx": "^6.13.5",
    "mobx-state-tree": "^6.0.1",
    "nodemailer": "^7.0.12",
    "nunjucks": "^3.2.4",
    "stripe": "^20.1.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^7.0.5",
    "@types/nunjucks": "^3.2.6",
    "@types/uuid": "^11.0.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
