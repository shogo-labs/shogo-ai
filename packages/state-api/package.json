{
  "name": "@shogo/state-api",
  "version": "0.1.0",
  "description": "Schema-first reactive state management bridging arkType to MST with isomorphic execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./query/execution/bun-postgres": {
      "import": "./src/query/execution/bun-postgres.ts",
      "types": "./src/query/execution/bun-postgres.ts"
    },
    "./query/execution/bun-sql": {
      "import": "./src/query/execution/bun-sql.ts",
      "types": "./src/query/execution/bun-sql.ts"
    },
    "./persistence/s3-sqlite": {
      "import": "./src/persistence/s3-sqlite.ts",
      "types": "./src/persistence/s3-sqlite.ts"
    },
    "./mcp-isolation": {
      "import": "./src/mcp-isolation/index.ts",
      "types": "./src/mcp-isolation/index.ts"
    },
    "./mcp-isolation/types": {
      "import": "./src/mcp-isolation/types.ts",
      "types": "./src/mcp-isolation/types.ts"
    },
    "./component-builder": {
      "import": "./src/component-builder/index.ts",
      "types": "./src/component-builder/index.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@ucast/core": "^1.10.2",
    "@ucast/js": "^3.0.4",
    "@ucast/mongo": "^2.4.3",
    "@ucast/sql": "^1.0.0-alpha.1",
    "arktype": "^2.0.0-beta.7",
    "jsondiffpatch": "^0.6.0",
    "mobx": "^6.13.5",
    "mobx-state-tree": "^6.0.1",
    "nunjucks": "^3.2.4",
    "stripe": "^20.1.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nunjucks": "^3.2.6",
    "@types/uuid": "^11.0.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
