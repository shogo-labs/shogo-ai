{
  "id": "equity-research-terminal",
  "name": "Equity Research Terminal",
  "description": "Public-market equity research workspace for stock screening, DCF valuation, earnings notes, and competitive analysis backed by Prisma and SQLite.",
  "category": "research",
  "icon": "LineChart",
  "tags": [
    "stocks",
    "equity-research",
    "screening",
    "dcf",
    "earnings",
    "competitive-analysis",
    "public-markets"
  ],
  "settings": {
    "heartbeatInterval": 3600,
    "heartbeatEnabled": true,
    "modelProvider": "anthropic",
    "modelName": "claude-sonnet-4-5",
    "quietHours": {
      "start": "22:00",
      "end": "07:00",
      "timezone": "UTC"
    },
    "webEnabled": true,
    "browserEnabled": true,
    "shellEnabled": true,
    "imageGenEnabled": false,
    "memoryEnabled": true,
    "quickActionsEnabled": true
  },
  "integrations": [
    {
      "categoryId": "notes",
      "description": "Archive research memos, source citations, and model assumptions"
    },
    {
      "categoryId": "communication",
      "description": "Send briefings, alerts, and review-ready summaries"
    }
  ],
  "techStack": "react-app"
}
