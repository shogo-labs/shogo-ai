{
  "name": "@shogo/agent-runtime",
  "version": "0.0.1",
  "license": "AGPL-3.0-or-later",
  "description": "Agent runtime - runs AI agent gateway with heartbeat, channels, and skills in per-agent pods",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun --packages external",
    "typecheck": "tsc --noEmit",
    "evals:fixtures": "bun run src/evals/extract-fixtures.ts",
    "evals:fixtures:check": "bun run src/evals/extract-fixtures.ts --check",
    "evals:run": "cd src/evals/dspy && python3 optimize.py",
    "evals:agent": "bun run src/evals/run-eval.ts",
    "evals:agent:local": "bun run src/evals/run-eval.ts --local",
    "evals:agent:canvas": "bun run src/evals/run-eval.ts --track canvas",
    "evals:agent:canvas-v2": "bun run src/evals/run-eval.ts --track canvas-v2",
    "evals:agent:edit-file": "bun run src/evals/run-eval.ts --track edit-file",
    "evals:agent:all": "bun run src/evals/run-eval.ts --track all",
    "evals:optimize": "cd src/evals/dspy && python3 optimize.py --track all --eval-model haiku --optimize-model sonnet --strategy bootstrap --no-cache",
    "evals:apply": "bun run src/evals/apply-optimizations.ts",
    "evals:pipeline": "bun run evals:optimize && bun run evals:apply",
    "generate-templates": "bun run src/template-generator/cli.ts",
    "generate-templates:force": "bun run src/template-generator/cli.ts --force",
    "generate-templates:dry": "bun run src/template-generator/cli.ts --dry-run",
    "migrate-canvas": "bun run src/migrate-canvas-to-code.ts",
    "migrate-canvas:all": "bun run src/migrate-canvas-to-code.ts --all",
    "test:pool-assign": "bun run ../../scripts/test-pool-assign.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@composio/core": "^0.6.5",
    "@hono/node-server": "^1.13.1",
    "@kubernetes/client-node": "^1.4.0",
    "@mariozechner/pi-agent-core": "^0.67.6",
    "@mariozechner/pi-ai": "^0.67.6",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@mozilla/readability": "^0.6.0",
    "@playwright/mcp": "^0.0.68",
    "@shogo-ai/sdk": "workspace:*",
    "@shogo/model-catalog": "workspace:*",
    "@shogo/shared-runtime": "workspace:*",
    "@sinclair/typebox": "^0.34.48",
    "@types/diff": "^8.0.0",
    "@vscode/ripgrep": "^1.17.1",
    "ai": "^6.0.73",
    "chromium-bidi": "^15.0.0",
    "diff": "^8.0.4",
    "hono": "^4.7.10",
    "imapflow": "^1.2.10",
    "ioredis": "^5.10.1",
    "linkedom": "^0.18.12",
    "nodemailer": "^8.0.1",
    "openai": "^6.25.0",
    "playwright-core": "^1.58.2",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tar": "^7.4.3",
    "tree-sitter-wasms": "^0.1.13",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^6.0.2",
    "unpdf": "^1.4.0",
    "web-tree-sitter": "0.25.10",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.0",
    "@types/turndown": "^5.0.6",
    "pyright": "^1.1.400",
    "typescript-language-server": "^5.1.3"
  }
}
