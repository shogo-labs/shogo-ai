{
  "name": "react-native-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "bun run server.tsx",
    "generate": "bun ./node_modules/@shogo-ai/sdk/bin/cli.mjs generate",
    "db:generate": "bun x --bun prisma generate",
    "db:migrate:dev": "bun x --bun prisma migrate dev",
    "db:migrate:deploy": "bun x --bun prisma migrate deploy",
    "db:push": "bun x --bun prisma db push",
    "db:reset": "bun x --bun prisma db push --force-reset --accept-data-loss",
    "db:studio": "bun x --bun prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@shogo-ai/sdk": "^1.2.2",
    "hono": "^4.0.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@prisma/internals": "^7.3.0",
    "@react-native/babel-preset": "0.76.5",
    "@react-native/metro-config": "0.76.5",
    "@react-native/typescript-config": "0.76.5",
    "@types/react": "^18.3.12",
    "prisma": "^7.3.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
