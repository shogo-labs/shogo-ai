{
  "id": "react-native",
  "name": "Custom Mobile App",
  "description": "Create an iPhone and Android app when you need deeper device-level control.",
  "tags": ["react-native", "mobile", "ios", "android", "metro", "typescript", "bare"],
  "target": "mobile",
  "seedsOwnTemplate": true,
  "runtime": {
    "devServer": "metro",
    "buildCommand": "",
    "templateApiPort": 3001
  },
  "capabilities": {
    "webEnabled": false,
    "browserEnabled": true,
    "shellEnabled": true,
    "heartbeatEnabled": false,
    "imageGenEnabled": true,
    "memoryEnabled": true,
    "quickActionsEnabled": false
  },
  "quickCommands": [
    {
      "id": "rn-clear-cache",
      "label": "Clear Metro Cache",
      "description": "Restart Metro with --reset-cache to flush the Metro cache",
      "command": "bun x react-native start --reset-cache",
      "category": "server",
      "timeout": 600000
    }
  ]
}
