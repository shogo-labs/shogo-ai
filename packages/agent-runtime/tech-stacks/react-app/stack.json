{
  "id": "react-app",
  "name": "React App",
  "description": "Build apps with Vite + React + TypeScript + Tailwind CSS + shadcn/ui. Includes a skill server backend with Prisma + SQLite for persistent data.",
  "tags": ["react", "vite", "tailwind", "shadcn", "typescript", "fullstack"],
  "target": "web",
  "runtime": {
    "devServer": "vite",
    "buildCommand": "vite build --watch",
    "templateApiPort": 3001
  },
  "capabilities": {
    "webEnabled": true,
    "browserEnabled": true,
    "shellEnabled": true,
    "heartbeatEnabled": true,
    "imageGenEnabled": true,
    "memoryEnabled": true,
    "quickActionsEnabled": true
  }
}
