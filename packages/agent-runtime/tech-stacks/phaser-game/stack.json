{
  "id": "phaser-game",
  "name": "2D Game",
  "description": "Create a simple 2D game that runs in a web browser.",
  "tags": ["2d", "games", "phaser", "sprites", "physics", "vite"],
  "target": "web",
  "runtime": {
    "devServer": "vite",
    "buildCommand": "vite build --watch",
    "templateApiPort": 3001
  },
  "capabilities": {
    "webEnabled": true,
    "browserEnabled": true,
    "shellEnabled": true,
    "heartbeatEnabled": false,
    "imageGenEnabled": true,
    "memoryEnabled": true,
    "quickActionsEnabled": true
  }
}
