{
  "id": "expo-three",
  "name": "3D Mobile Game",
  "description": "Build an interactive 3D game for iPhone and Android devices.",
  "tags": ["expo", "react-native", "threejs", "3d", "games", "gamedev", "expo-gl", "mobile"],
  "target": "mobile",
  "seedsOwnTemplate": true,
  "runtime": {
    "devServer": "metro",
    "buildCommand": "expo export --platform web --output-dir dist",
    "templateApiPort": 3001
  },
  "capabilities": {
    "webEnabled": true,
    "browserEnabled": true,
    "shellEnabled": true,
    "heartbeatEnabled": false,
    "imageGenEnabled": true,
    "memoryEnabled": true,
    "quickActionsEnabled": false
  },
  "quickCommands": [
    {
      "id": "expo-clear-cache",
      "label": "Clear Metro Cache",
      "description": "Restart Expo with --clear to flush the Metro cache",
      "command": "bun x expo start --clear",
      "category": "server",
      "timeout": 600000
    },
    {
      "id": "expo-prebuild",
      "label": "Expo Prebuild",
      "description": "Regenerate native iOS/Android projects from app.json",
      "command": "bun x expo prebuild",
      "category": "build",
      "timeout": 300000
    }
  ]
}
