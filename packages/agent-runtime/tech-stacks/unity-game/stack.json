{
  "id": "unity-game",
  "name": "Advanced Game Project",
  "description": "Build a larger 2D or 3D game for desktop or mobile. Best for full game-engine projects.",
  "tags": ["unity", "csharp", "3d", "2d", "games", "gamedev"],
  "target": "native",
  "seedsOwnTemplate": true,
  "runtime": {
    "devServer": "unity",
    "buildCommand": "dotnet build",
    "templateApiPort": 3001
  },
  "capabilities": {
    "webEnabled": true,
    "browserEnabled": false,
    "shellEnabled": true,
    "heartbeatEnabled": false,
    "imageGenEnabled": true,
    "memoryEnabled": true,
    "quickActionsEnabled": false
  },
  "quickCommands": [
    {
      "id": "dotnet-build",
      "label": "Rebuild",
      "description": "Build the .NET solution",
      "command": "dotnet build",
      "category": "build",
      "timeout": 300000
    },
    {
      "id": "dotnet-test",
      "label": "Run Tests",
      "description": "Run .NET test suite",
      "command": "dotnet test",
      "category": "test",
      "timeout": 300000
    }
  ]
}
