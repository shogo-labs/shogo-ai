{
  "id": "threejs-game",
  "name": "3D Game",
  "description": "Build an interactive 3D game that runs in a web browser.",
  "tags": ["3d", "games", "threejs", "webgl", "physics", "vite"],
  "target": "web",
  "runtime": {
    "devServer": "vite",
    "buildCommand": "vite build --watch",
    "templateApiPort": 3001
  },
  "capabilities": {
    "webEnabled": true,
    "browserEnabled": true,
    "shellEnabled": true,
    "heartbeatEnabled": false,
    "imageGenEnabled": true,
    "memoryEnabled": true,
    "quickActionsEnabled": true
  }
}
