{
  "name": "expo-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "build": "expo export --platform web --output-dir dist",
    "build:web": "expo export --platform web --output-dir dist",
    "typecheck": "tsc --noEmit",
    "start": "bun run server.tsx",
    "generate": "bun ./node_modules/@shogo-ai/sdk/bin/cli.mjs generate",
    "db:generate": "bun x --bun prisma generate",
    "db:migrate:dev": "bun x --bun prisma migrate dev",
    "db:migrate:deploy": "bun x --bun prisma migrate deploy",
    "db:push": "bun x --bun prisma db push",
    "db:reset": "bun x --bun prisma db push --force-reset --accept-data-loss",
    "db:studio": "bun x --bun prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@shogo-ai/sdk": "^0.4.0",
    "expo": "~51.0.0",
    "expo-router": "~3.5.0",
    "expo-status-bar": "~1.12.0",
    "hono": "^4.0.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@prisma/internals": "^7.3.0",
    "@types/react": "~18.2.45",
    "prisma": "^7.3.0",
    "typescript": "~5.3.3"
  }
}
