# syntax=docker/dockerfile:1.4
# =============================================================================
# Base Runtime Image (Debian slim)
# =============================================================================
# Slow-changing layer: system packages, CLI tools, and MCP server packages.
# Rebuilt only when these change.
#
# Build: DOCKER_BUILDKIT=1 docker build -t shogo-runtime-base -f packages/agent-runtime/Dockerfile.base .
# =============================================================================

FROM python:3.12-slim

WORKDIR /app

# System packages + Node 24 + Bun 1.3
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl bash git tar gzip ca-certificates gnupg unzip \
    chromium nss-plugin-pem fonts-freefont-ttf \
    ffmpeg imagemagick ripgrep \
    build-essential && \
    # Node 24 via nodesource
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    # Bun 1.3
    curl -fsSL https://bun.sh/install | BUN_INSTALL=/usr/local bash -s "bun-v1.3.11" && \
    # AWS CLI v2 (dpkg returns arm64, AWS expects aarch64)
    ARCH="$(uname -m)" && \
    curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-${ARCH}.zip" -o /tmp/awscli.zip && \
    unzip -q /tmp/awscli.zip -d /tmp && /tmp/aws/install && rm -rf /tmp/aws /tmp/awscli.zip && \
    # GitHub CLI
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | gpg --dearmor -o /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends gh && \
    # Stripe CLI (pinned to avoid GitHub API rate limits in CI)
    STRIPE_VER="1.40.0" && \
    STRIPE_ARCH="$(uname -m | sed 's/aarch64/arm64/' | sed 's/x86_64/x86_64/')" && \
    curl -fsSL "https://github.com/stripe/stripe-cli/releases/download/v${STRIPE_VER}/stripe_${STRIPE_VER}_linux_${STRIPE_ARCH}.tar.gz" \
      | tar -xz -C /usr/local/bin stripe && \
    # Cleanup
    apt-get purge -y gnupg unzip && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Create non-root user early (enables installing MCP packages as appuser)
RUN groupadd -g 1001 appgroup && \
    useradd -u 1001 -g appgroup -m -s /bin/bash appuser

# Install global Node packages and set ownership in single layer (no duplicate data)
RUN npm install -g typescript-language-server typescript pyright && \
    (chown -R appuser:appgroup /usr/local/lib/node_modules 2>/dev/null || true) && \
    (chown -R appuser:appgroup /usr/lib/node_modules 2>/dev/null || true)

# Install Python packages and set ownership in single layer (no duplicate data)
RUN pip install --no-cache-dir \
      openpyxl Pillow python-pptx pydub pandas numpy scipy PyPDF2 && \
    chown -R appuser:appgroup /usr/local/lib/python3.12

ENV SHELL=/bin/bash

# Install MCP server packages as appuser (avoids expensive chown -R on /app)
RUN mkdir -p /app/mcp-packages && chown appuser:appgroup /app/mcp-packages
USER appuser
RUN cd /app/mcp-packages && \
    npm init -y --silent 2>/dev/null && \
    npm install --omit=dev --no-audit --no-fund \
      @openbnb/mcp-server-airbnb@0.1.3 \
      mcp-fetch-node@latest \
      @modelcontextprotocol/server-filesystem@latest \
      @playwright/mcp@latest \
      mongodb-mcp-server@latest \
      @discourse/mcp@latest \
      mcp-server-linear@latest \
      mcp-server-sqlite@latest \
      @notionhq/notion-mcp-server@latest \
      mcp-server-stripe@latest \
      exa-mcp-server@latest \
      @sentry/mcp-server@latest \
    && rm -rf /app/mcp-packages/package.json /app/mcp-packages/package-lock.json
USER root

RUN mkdir -p /app/workspace /app/workspace/project /app/.schemas /app/.claude && \
    chown -R appuser:appgroup /app/workspace /app/.schemas /app/.claude
