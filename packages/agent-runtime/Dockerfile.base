# syntax=docker/dockerfile:1.4
# =============================================================================
# Base Runtime Image
# =============================================================================
# Slow-changing layer: system packages, Claude Code CLI, pre-built template
# archives, and MCP server packages. Rebuilt only when these change.
#
# Build: DOCKER_BUILDKIT=1 docker build -t runtime-base -f packages/agent-runtime/Dockerfile.base .
# =============================================================================

# =============================================================================
# Stage 1: template-deps — pre-install and pre-build app templates
# =============================================================================
# Dynamically discovers all templates in packages/sdk/examples/ that have a
# package.json. Skip directories listed in SKIP_TEMPLATES (e.g. expo-app which
# is an internal template not exposed via template_list).
# =============================================================================
FROM oven/bun:1.3-alpine AS template-deps

RUN apk add --no-cache pigz

WORKDIR /templates

ENV SKIP_TEMPLATES="expo-app"

COPY packages/sdk/examples ./examples

# Install dependencies for all discovered templates
RUN --mount=type=cache,target=/root/.bun/install/cache \
    for dir in /templates/examples/*/; do \
      template="$(basename "$dir")" ; \
      case " $SKIP_TEMPLATES " in *" $template "*) echo "=== Skipping: $template ===" ; continue ;; esac ; \
      [ -f "$dir/package.json" ] || continue ; \
      echo "=== Installing deps: $template ===" && \
      cd "$dir" && \
      if [ -f "bun.lock" ]; then \
        bun install --frozen-lockfile; \
      else \
        echo "    (no bun.lock — running bun install)" && bun install; \
      fi && \
      cd /templates; \
    done

# Build all templates (prisma generate + vite build where applicable)
RUN for dir in /templates/examples/*/; do \
      template="$(basename "$dir")" ; \
      case " $SKIP_TEMPLATES " in *" $template "*) continue ;; esac ; \
      [ -f "$dir/package.json" ] || continue ; \
      echo "=== Building: $template ===" && \
      cd "$dir" && \
      if [ -f "prisma/schema.prisma" ]; then \
        bunx --bun prisma generate 2>&1 || true; \
      fi && \
      if grep -q '"build"' package.json 2>/dev/null; then \
        bun run build 2>&1 || echo "Build skipped for $template"; \
      fi && \
      cd /templates; \
    done

# Archive each template into a .tar.gz (parallel compression with pigz)
RUN mkdir -p /templates/archives && \
    cd /templates/examples && \
    for dir in */; do \
      template="${dir%/}" ; \
      case " $SKIP_TEMPLATES " in *" $template "*) continue ;; esac ; \
      [ -f "$template/package.json" ] || continue ; \
      ( \
        tar cf - "$template" | pigz > /templates/archives/${template}.tar.gz && \
        echo "=== $template archived ($(du -h /templates/archives/${template}.tar.gz | cut -f1)) ===" \
      ) & \
    done && \
    wait && \
    rm -rf /templates/examples

# =============================================================================
# Stage 2: base — system packages, CLI tools, templates, MCP servers
# =============================================================================
FROM oven/bun:1.3-alpine

WORKDIR /app

RUN echo "https://dl-cdn.alpinelinux.org/alpine/v3.21/main" >> /etc/apk/repositories && \
    apk add --no-cache \
    curl bash git tar gzip \
    'nodejs>22' npm \
    chromium nss freetype harfbuzz ca-certificates ttf-freefont \
    aws-cli

ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN npm install -g @anthropic-ai/claude-code

ENV SHELL=/bin/bash

RUN addgroup -g 1001 -S appgroup && \
    adduser -u 1001 -S appuser -G appgroup

# Pre-install popular MCP server packages (all cloud-compatible catalog entries)
RUN mkdir -p /app/mcp-packages && \
    cd /app/mcp-packages && \
    npm init -y --silent 2>/dev/null && \
    npm install --omit=dev --no-audit --no-fund \
      @openbnb/mcp-server-airbnb@0.1.3 \
      mcp-fetch-node@latest \
      @modelcontextprotocol/server-postgres@latest \
      @modelcontextprotocol/server-filesystem@latest \
      @playwright/mcp@latest \
      mongodb-mcp-server@latest \
      @discourse/mcp@latest \
      @modelcontextprotocol/server-github@latest \
      @modelcontextprotocol/server-gitlab@latest \
      mcp-server-linear@latest \
      mcp-server-sqlite@latest \
      @modelcontextprotocol/server-slack@latest \
      @notionhq/notion-mcp-server@latest \
      mcp-server-stripe@latest \
      @modelcontextprotocol/server-brave-search@latest \
      exa-mcp-server@latest \
      @sentry/mcp-server@latest \
    && rm -rf /app/mcp-packages/package.json /app/mcp-packages/package-lock.json

# Template archives for app mode
COPY --chown=appuser:appgroup --from=template-deps /templates/archives ./packages/sdk/templates

RUN mkdir -p /app/workspace /app/workspace/project /app/.schemas /app/.claude && \
    chown -R appuser:appgroup /app /usr/local/lib/node_modules
