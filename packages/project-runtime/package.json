{
  "name": "@shogo/project-runtime",
  "version": "0.0.1",
  "license": "AGPL-3.0-or-later",
  "description": "Isolated project runtime - runs Claude Code agent + Vite in a per-project pod",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "benchmark:watch": "bun run scripts/benchmark-vite-watch.ts",
    "benchmark:test": "bash scripts/run-benchmark-test.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@hono/node-server": "^1.13.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@shogo/shared-runtime": "workspace:*",
    "ai": "^6.0.73",
    "arktype": "^2.0.0-beta.7",
    "fastmcp": "^3.19.2",
    "hono": "^4.7.10",
    "pg": "^8.13.0",
    "tar": "^7.4.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "typescript": "^5.8.3",
    "typescript-language-server": "^5.1.3"
  }
}
