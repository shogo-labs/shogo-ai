{
  "name": "@shogo/sdk",
  "version": "0.3.0",
  "description": "Shogo Platform SDK - Zero-boilerplate auth, database, and state management for TanStack Start apps",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "shogo": "./bin/shogo.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "import": "./dist/generators/index.js",
      "require": "./dist/generators/index.cjs"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "bin/**/*.ts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "mobx": "^6.15.0",
    "mobx-state-tree": "^7.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@prisma/internals": "^7.3.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@tanstack/react-start": ">=1.0.0",
    "mobx-react-lite": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-start": {
      "optional": true
    },
    "mobx-react-lite": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "shogo",
    "sdk",
    "typescript",
    "auth",
    "database",
    "tanstack",
    "mobx",
    "prisma",
    "code-generation"
  ],
  "author": "Shogo Team",
  "license": "MIT"
}
