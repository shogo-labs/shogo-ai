{
  "name": "@shogo-ai/sdk",
  "version": "0.4.0",
  "description": "Shogo Platform SDK - Zero-boilerplate auth and database for Shogo apps",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "require": "./dist/db/index.cjs"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "import": "./dist/email/index.js",
      "require": "./dist/email/index.cjs"
    },
    "./email/server": {
      "types": "./dist/email/server.d.ts",
      "import": "./dist/email/server.js",
      "require": "./dist/email/server.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "require": "./dist/agent/index.cjs"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "import": "./dist/generators/index.js",
      "require": "./dist/generators/index.cjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist/tools/index.cjs"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "require": "./dist/memory/index.cjs"
    },
    "./memory/server": {
      "types": "./dist/memory/server.d.ts",
      "import": "./dist/memory/server.js",
      "require": "./dist/memory/server.cjs"
    }
  },
  "bin": {
    "shogo": "./bin/cli.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "bin/cli.mjs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@shogo/shared-runtime": "workspace:*"
  },
  "devDependencies": {
    "@aws-sdk/client-ses": "^3.700.0",
    "@playwright/test": "^1.40.0",
    "@prisma/internals": "^7.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "better-sqlite3": "^11.10.0",
    "mobx": "^6.13.5",
    "mobx-state-tree": "^7.2.0",
    "nodemailer": "^8.0.3",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "nodemailer": ">=6.0.0",
    "@aws-sdk/client-ses": ">=3.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/adapter-libsql": "",
    "react": ">=18.0.0",
    "better-sqlite3": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "nodemailer": {
      "optional": true
    },
    "@aws-sdk/client-ses": {
      "optional": true
    },
    "@prisma/adapter-pg": {
      "optional": true
    },
    "@prisma/adapter-libsql": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "shogo",
    "sdk",
    "typescript",
    "auth",
    "database",
    "email",
    "smtp",
    "ses",
    "mcp",
    "memory",
    "elevenlabs",
    "rag"
  ],
  "author": "Shogo Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shogo-labs/shogo-ai.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/shogo-labs/shogo-ai/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/shogo-labs/shogo-ai/issues"
  }
}
