{
  "name": "form-builder",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch run server.tsx",
    "dev:client": "vite",
    "build": "vite build",
    "start": "bun run server.tsx",
    "generate": "bunx shogo generate",
    "db:generate": "bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:reset": "bunx --bun prisma db push --force-reset --accept-data-loss",
    "db:studio": "bunx --bun prisma studio",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@shogo-ai/sdk": "^0.3.0",
    "hono": "^4.0.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.0",
    "pg": "^8.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@prisma/internals": "^7.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^8.2.0",
    "prisma": "^7.3.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
