{
  "name": "expo-app",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --web --port ${PORT:-8081}",
    "build": "expo export --platform web --output-dir dist",
    "start": "bun run server.ts",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "db:generate": "bun x --bun prisma generate",
    "db:push": "bun x --bun prisma db push",
    "db:reset": "bun x --bun prisma db push --force-reset --accept-data-loss",
    "db:studio": "bun x --bun prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@shogo-ai/sdk": "workspace:*",
    "expo": "~56.0.8",
    "expo-constants": "~56.0.16",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-status-bar": "~56.0.4",
    "hono": "^4.0.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@prisma/internals": "^7.3.0",
    "@types/react": "~18.3.0",
    "prisma": "^7.3.0",
    "typescript": "^6.0.3"
  }
}
