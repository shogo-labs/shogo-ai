{
  "schema": "./prisma/schema.prisma",
  "outputs": [
    {
      "dir": "./src/generated",
      "generate": ["routes", "hooks", "types", "api-client", "auth"]
    },
    {
      "dir": ".",
      "generate": ["server"]
    },
    {
      "dir": "./src/lib",
      "generate": ["db"]
    },
    {
      "dir": ".",
      "generate": ["tests"]
    }
  ]
}
