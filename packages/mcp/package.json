{
  "name": "@shogo/mcp",
  "version": "0.1.0",
  "description": "MCP server for Claude integration with Shogo state management",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "bun build src/server.ts --outdir dist --target node --external @valibot/to-json-schema --external sury --external effect",
    "dev": "bun --env-file=../../.env.local --watch src/server-http.ts",
    "start": "bun src/server.ts",
    "start:http": "bun src/server-http.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.50",
    "@shogo/state-api": "workspace:*",
    "ai": "^5.0.115",
    "ai-sdk-provider-claude-code": "^2.2.4",
    "arktype": "^2.0.0-beta.7",
    "fastmcp": "^3.19.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  }
}
