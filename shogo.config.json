{
  "schema": "./prisma/schema.prisma",
  "models": [
    "User",
    "Workspace",
    "Project",
    "Folder",
    "Member",
    "Invitation",
    "StarredProject",
    "Notification",
    "BillingAccount",
    "Subscription",
    "UsageWallet",
    "UsageEvent",
    "ChatSession",
    "ChatMessage",
    "ToolCallLog",
    "FeatureSession",
    "WorkspaceGrant"
  ],
  "outputs": [
    {
      "dir": "./apps/api/src/generated",
      "generate": ["routes", "hooks", "admin-routes"],
      "perModel": true,
      "fileExtension": "ts"
    },
    {
      "dir": "./packages/domain-stores/src",
      "generate": ["types", "mst"],
      "perModel": true,
      "fileExtension": "ts"
    }
  ]
}
