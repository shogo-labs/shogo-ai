#!/usr/bin/env bash
#
# pre-commit: ensure Prisma migrations accompany any schema change.
#
# Intent: if you edit prisma/schema.prisma or prisma/schema.local.prisma, you
# must also stage a new migration file in the corresponding migrations dir.
# This catches the common "forgot to generate a migration" mistake before it
# hits main.
#
# As of 2026-05-21 the hook also runs scripts/check-desktop-schema-drift.ts
# when the desktop SQLite schema or any of its migrations change — that
# script wraps `prisma migrate diff --from-migrations --to-schema` (Prisma
# v7's rename of the old --to-schema-datamodel) and catches the "schema
# updated but no migration generated for it" failure mode. SQLite uses an
# in-memory shadow DB so no external connection is needed; the check runs
# in ~3s locally.
#
# To skip this check (e.g. comment-only reformatting of the schema), use
# `git commit --no-verify`.
#

set -euo pipefail

CLOUD_SCHEMA="prisma/schema.prisma"
CLOUD_MIGRATIONS="prisma/migrations"
LOCAL_SCHEMA="prisma/schema.local.prisma"
LOCAL_MIGRATIONS="apps/desktop/prisma/migrations"

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

check_schema() {
  local schema_path="$1"
  local migrations_path="$2"
  local label="$3"

  # Schema not staged? Nothing to check.
  if ! printf '%s\n' "$staged_files" | grep -qx "$schema_path"; then
    return 0
  fi

  echo "[pre-commit] ${label} schema change detected — verifying migration is staged..."

  # Look for a staged migration.sql under the matching migrations directory.
  if printf '%s\n' "$staged_files" | grep -qE "^${migrations_path}/[^/]+/migration\.sql$"; then
    echo "[pre-commit] ${label}: migration file staged alongside schema change — OK."
    return 0
  fi

  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  ERROR: ${label} schema changed without a migration!"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  echo "  Schema:     ${schema_path}"
  echo "  Migrations: ${migrations_path}/"
  echo ""
  echo "You have staged changes to ${schema_path} but no new migration"
  echo "file under ${migrations_path}/."
  echo ""
  if [ "$schema_path" = "$CLOUD_SCHEMA" ]; then
    echo "To generate one, run:"
    echo ""
    echo "    npx prisma migrate dev --name <descriptive_name>"
    echo ""
    echo "Then stage the new migration directory and commit again."
  else
    echo "Add a matching migration under ${migrations_path}/<timestamp>_<name>/"
    echo "(the desktop app applies these at startup in packaged builds)."
  fi
  echo ""
  echo "To skip this check (e.g. comment-only changes), use:"
  echo ""
  echo "    git commit --no-verify"
  echo ""
  return 1
}

rc=0
check_schema "$CLOUD_SCHEMA" "$CLOUD_MIGRATIONS" "Cloud" || rc=1
check_schema "$LOCAL_SCHEMA" "$LOCAL_MIGRATIONS" "Local" || rc=1

# When either schema changes, also verify the two stay in sync at the
# field level. Catches the common drift mode where a column is added to
# prisma/schema.prisma but the SQLite mirror is forgotten — which then
# crashes the API at runtime in local mode (see scripts/check-schema-parity.ts
# for details and the allow-list of intentional differences).
if printf '%s\n' "$staged_files" | grep -qxE "${CLOUD_SCHEMA}|${LOCAL_SCHEMA}"; then
  echo "[pre-commit] Schema change detected — checking PG ↔ SQLite parity..."
  if command -v bun >/dev/null 2>&1; then
    if ! bun scripts/check-schema-parity.ts --quiet; then
      rc=1
    fi
  else
    echo "[pre-commit] WARN: bun not on PATH — skipping schema parity check."
  fi
fi

# When a desktop SQLite migration is added or changed, replay the full
# history from scratch. Catches the failure mode where a migration is
# shipped without its prerequisite — e.g. an ALTER TABLE for which no
# earlier migration ever CREATE TABLEs the target. That bug silently
# bricks the packaged desktop app for every user on next launch (Prisma
# records the failure with finished_at=NULL and P3009 trips forever
# after). The replay is fast (~1s, in-memory SQLite via bun) so we can
# afford it on pre-commit when migrations are touched.
if printf '%s\n' "$staged_files" | grep -qE "^${LOCAL_MIGRATIONS}/[^/]+/migration\.sql$"; then
  echo "[pre-commit] Desktop SQLite migration changed — replaying full history..."
  if command -v bun >/dev/null 2>&1; then
    if ! bun scripts/check-migrations.ts --quiet; then
      rc=1
    fi
  else
    echo "[pre-commit] WARN: bun not on PATH — skipping migration replay check."
  fi
fi

# When the SQLite schema OR any desktop migration changes, also verify
# the migration history *actually produces* the schema. The replay
# above proves the migrations run, but doesn't notice when a model is
# added to schema.local.prisma without a corresponding CREATE TABLE —
# the exact failure mode that bricked v1.7.8 (marketplace tables in
# the schema, only follow-up ALTERs in the migration tree). Uses
# `prisma migrate diff --from-migrations --to-schema` under the hood;
# Prisma's in-memory shadow DB makes this fast (~3s).
#
# The script applies an allow-list of pre-existing drift so today's
# tech-debt doesn't break new PRs (run `bun run check:desktop-schema-drift`
# locally to see the full state). New drift on any table NOT on the
# allow-list fails the commit with a pointer to `bun run db:migrate:desktop`.
if printf '%s\n' "$staged_files" | grep -qxE "${LOCAL_SCHEMA}" \
   || printf '%s\n' "$staged_files" | grep -qE "^${LOCAL_MIGRATIONS}/[^/]+/migration\.sql$"; then
  echo "[pre-commit] Desktop SQLite schema or migration changed — checking drift..."
  if command -v bun >/dev/null 2>&1; then
    if ! bun scripts/check-desktop-schema-drift.ts --quiet; then
      rc=1
    fi
  else
    echo "[pre-commit] WARN: bun not on PATH — skipping schema drift check."
  fi
fi

exit $rc
