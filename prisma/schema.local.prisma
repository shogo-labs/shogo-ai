  extends           Registry?            @relation("RegistryExtends", fields: [extendsId], references: [id], onDelete: SetNull)
  extendedBy        Registry[]           @relation("RegistryExtends")
  fallbackComponent ComponentDefinition? @relation("FallbackComponent", fields: [fallbackComponentId], references: [id], onDelete: SetNull)
