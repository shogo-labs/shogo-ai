// Shogo AI - SQLite Prisma Schema (Local/Desktop Mode)
//
// This schema mirrors schema.prisma but targets SQLite for local mode.
// Key differences from the PostgreSQL schema:
// - provider = "sqlite"
// - String[] fields → String (JSON-encoded arrays)
// - @db.Text annotations removed (SQLite TEXT is the default)
//
// Generate with: bunx prisma generate --schema=prisma/schema.local.prisma
// Migrate with:  bunx prisma migrate dev --schema=prisma/schema.local.prisma

generator client {
  provider = "prisma-client"
  output   = "../apps/api/src/generated/prisma-sqlite"
}

datasource db {
  provider = "sqlite"
}

// =============================================================================
// BETTER-AUTH (Authentication)
// =============================================================================

model User {
  id                  String   @id @default(cuid())
  name                String?
  email               String   @unique
  emailVerified       Boolean  @default(false)
  image               String?
  role                String   @default("user")
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sessions             Session[]
  accounts             Account[]
  members              Member[]
  notifications        Notification[]
  starredProjects      StarredProject[]
  apiKeys              ApiKey[]
  creatorProfile       CreatorProfile?
  signupAttribution    SignupAttribution?
  creatorFollows       CreatorFollow[]      @relation("UserFollows")
  affiliate            Affiliate?
  affiliateAttribution AffiliateAttribution?
  projectAuthSignIns   ProjectAuthSignIn[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// =============================================================================
// STUDIO-CORE (Multi-tenancy & Project Management)
// =============================================================================

model Workspace {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  ssoSettings   String?
  instanceSize  String   @default("micro")
  // See packages/agent-runtime/src/composio.ts and
  // apps/api/src/routes/integrations.ts. New workspaces default to
  // "workspace" (one OAuth shared across the workspace); existing
  // workspaces are migrated to "project" to preserve current behavior.
  composioScope String   @default("workspace")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects               Project[]
  members                Member[]
  billingAccounts        BillingAccount[]
  invitations            Invitation[]
  inviteLinks            InviteLink[]
  folders                Folder[]
  subscriptions          Subscription[]
  instanceSubscription   InstanceSubscription?
  usageWallets           UsageWallet[]
  usageEvents            UsageEvent[]
  storageUsage           StorageUsage?
  starredProjects        StarredProject[]
  instances              Instance[]
  apiKeys                ApiKey[]
  meetings               Meeting[]
  voiceProjectConfigs    VoiceProjectConfig[]
  projectAgents          ProjectAgent[]
  agentCostMetrics       AgentCostMetric[]
  budgetAlerts           BudgetAlert[]
  modelExperiments       ModelExperiment[]
  subagentModelOverrides SubagentModelOverride[]
  agentEvalResults       AgentEvalResult[]
  agentEvalSets          AgentEvalSet[]
  grants                 WorkspaceGrant[]
  chatSessions           ChatSession[]
  modelVisibility        WorkspaceModelVisibility[]

  @@map("workspaces")
}

model Project {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  workspaceId        String
  tier               String    @default("starter")
  status             String    @default("draft")
  schemas            String    @default("[]")
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  folderId           String?
  publishedSubdomain String?   @unique
  publishedAt        DateTime?
  // Mirrors `PublishStatus` enum in schema.prisma; SQLite has no enum
  // support so we store the string. Allowed values: idle, building,
  // uploading, configuring, live, failed. Set by apps/api/src/routes/publish.ts.
  publishStatus      String    @default("idle")
  publishError       String?
  publishStatusAt    DateTime?
  // The exact git commit + annotated tag the current publish points at.
  // See prisma/schema.prisma for the canonical comment.
  publishedCommitSha String?
  publishedTag       String?
  accessLevel        String    @default("anyone")
  category           String?
  siteTitle          String?
  siteDescription    String?
  thumbnailUrl       String?
  templateId         String?
  knativeServiceName String?
  settings           String?
  lastMessageAt      DateTime?
  // External / IDE-style project mode. See prisma/schema.prisma for the
  // canonical comment.
  workingMode    String  @default("managed")
  runtimeEnabled Boolean @default(true)
  trustLevel     String  @default("trusted")

  // External-trigger routing. See prisma/schema.prisma for the canonical comment.
  preferredInstanceId     String?
  preferredInstancePolicy String  @default("pinned")

  // Cloud workspace sync mode. SQLite has no native enum type, so we
  // store it as TEXT with the same allowed values used by the PG enum:
  //   's3' | 'dual_shadow' | 'git_only'. The check constraint lives in
  //   the migration. See prisma/schema.prisma for the canonical comment.
  //   Default mirrors the PG schema (`git_only`); harmless on desktop
  //   where cloud sync is disabled (SHOGO_LOCAL_MODE).
  cloudSyncMode String @default("git_only")

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder                 Folder?                 @relation(fields: [folderId], references: [id], onDelete: SetNull)
  members                Member[]
  inviteLinks            InviteLink[]
  featureSessions        FeatureSession[]
  chatSessions           ChatSession[]
  usageEvents            UsageEvent[]
  checkpoints            ProjectCheckpoint[]
  githubConnection       GitHubConnection?
  starredBy              StarredProject[]
  agentConfig            AgentConfig?
  meetings               Meeting[]
  marketplaceListing     MarketplaceListing?
  voiceConfig            VoiceProjectConfig?
  agents                 ProjectAgent[]
  agentCostMetrics       AgentCostMetric[]
  modelExperiments       ModelExperiment[]
  subagentModelOverrides SubagentModelOverride[]
  agentEvalSets          AgentEvalSet[]
  projectFolders         ProjectFolder[]
  preferredInstance      Instance?               @relation("ProjectPreferredInstance", fields: [preferredInstanceId], references: [id], onDelete: SetNull)
  authConfig             ProjectAuthConfig?
  authSignIns            ProjectAuthSignIn[]
  attachedSessions       ChatSessionProject[]
  attachments            ProjectAttachment[]     @relation("ProjectAttachmentAnchor")
  attachedTo             ProjectAttachment[]     @relation("ProjectAttachmentTarget")
  customDomains          CustomDomain[]

  @@index([workspaceId])
  @@index([folderId])
  @@index([preferredInstanceId])
  @@map("projects")
}

/// Persistent project-to-project attachment. See prisma/schema.prisma for
/// the canonical comment.
model ProjectAttachment {
  id                String   @id @default(uuid())
  projectId         String
  attachedProjectId String
  attachMode        String   @default("readwrite")
  createdAt         DateTime @default(now())

  project  Project @relation("ProjectAttachmentAnchor", fields: [projectId], references: [id], onDelete: Cascade)
  attached Project @relation("ProjectAttachmentTarget", fields: [attachedProjectId], references: [id], onDelete: Cascade)

  @@unique([projectId, attachedProjectId])
  @@index([projectId])
  @@index([attachedProjectId])
  @@map("project_attachments")
}

/// External host folder linked to a project (workingMode='external').
/// See prisma/schema.prisma for the canonical comment.
model ProjectFolder {
  id           String    @id @default(uuid())
  projectId    String
  path         String
  isPrimary    Boolean   @default(false)
  addedAt      DateTime  @default(now())
  lastOpenedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_folders")
}

/// Bring-your-own custom domain for a published project (Cloudflare for
/// SaaS custom hostname). See prisma/schema.prisma for the canonical
/// comment. SQLite has no native enum, so `status` is TEXT with the same
/// allowed values as the PG `CustomDomainStatus` enum: pending, verifying,
/// active, failed.
model CustomDomain {
  id                 String    @id @default(uuid())
  projectId          String
  hostname           String    @unique
  status             String    @default("pending")
  cfCustomHostnameId String?
  sslStatus          String?
  lastError          String?
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("custom_domains")
}

/// Per-project sign-in allowlist. See prisma/schema.prisma for the
/// canonical comment. SQLite has no native String[] so the two list
/// columns are stored as JSON-encoded TEXT (`["alice@x.com",...]`).
model ProjectAuthConfig {
  id                       String   @id @default(uuid())
  projectId                String   @unique
  mode                     String   @default("anyone")
  allowedEmails            String   @default("[]")
  allowedDomains           String   @default("[]")
  requireEmailVerification Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_auth_configs")
}

/// Tracks (project, user) sign-ins via Shogo SDK auth. See
/// prisma/schema.prisma for the canonical comment.
model ProjectAuthSignIn {
  id            String   @id @default(uuid())
  projectId     String
  userId        String
  firstSignInAt DateTime @default(now())
  lastSignInAt  DateTime @default(now())
  signInCount   Int      @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId, lastSignInAt(sort: Desc)])
  @@map("project_auth_sign_ins")
}

model AgentConfig {
  id                 String    @id @default(uuid())
  projectId          String    @unique
  heartbeatInterval  Int       @default(1800)
  heartbeatEnabled   Boolean   @default(false)
  nextHeartbeatAt    DateTime?
  lastHeartbeatAt    DateTime?
  quietHoursStart    String?
  quietHoursEnd      String?
  quietHoursTimezone String?
  channels           String    @default("[]")
  modelProvider      String    @default("anthropic")
  modelName          String    @default("claude-haiku-4-5")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

// =============================================================================
// VERSION CONTROL (Checkpoints & GitHub Integration)
// =============================================================================

model ProjectCheckpoint {
  id            String   @id @default(uuid())
  projectId     String
  name          String?
  description   String?
  commitSha     String
  commitMessage String
  branch        String   @default("main")
  includesDb    Boolean  @default(false)
  filesChanged  Int      @default(0)
  additions     Int      @default(0)
  deletions     Int      @default(0)
  isAutomatic   Boolean  @default(false)
  createdBy     String?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([commitSha])
  @@map("project_checkpoints")
}

model GitHubConnection {
  id             String    @id @default(uuid())
  projectId      String    @unique
  repoOwner      String
  repoName       String
  repoFullName   String
  defaultBranch  String    @default("main")
  installationId Int?
  repoId         Int?
  isPrivate      Boolean   @default(true)
  syncEnabled    Boolean   @default(true)
  lastPushAt     DateTime?
  lastPullAt     DateTime?
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([repoFullName])
  @@map("github_connections")
}

model StarredProject {
  id          String   @id @default(uuid())
  userId      String
  projectId   String
  workspaceId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([userId])
  @@map("starred_projects")
}

model Member {
  id             String   @id @default(uuid())
  userId         String
  role           String   @default("member")
  workspaceId    String?
  projectId      String?
  isBillingAdmin Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([projectId])
  @@map("members")
}

model BillingAccount {
  id               String   @id @default(uuid())
  workspaceId      String
  stripeCustomerId String?
  taxId            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId])
  @@map("billing_accounts")
}

model Invitation {
  id          String    @id @default(uuid())
  email       String
  role        String    @default("member")
  workspaceId String?
  projectId   String?
  status      String    @default("pending")
  emailStatus String    @default("not_sent")
  emailSentAt DateTime?
  emailError  String?
  invitedBy   String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([workspaceId])
  @@map("invitations")
}

model InviteLink {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  projectId   String?
  workspaceId String?
  role        String    @default("member")
  createdBy   String
  enabled     Boolean   @default(true)
  expiresAt   DateTime?
  useCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([projectId])
  @@map("invite_links")
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  workspaceId String
  parentId    String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]  @relation("FolderHierarchy")
  projects  Project[]

  @@index([workspaceId])
  @@index([parentId])
  @@map("folders")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  metadata  String?
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@map("notifications")
}

/// Captures UTM parameters and referrer info at signup time. One row
/// per user. Mirrors prisma/schema.prisma SignupAttribution.
model SignupAttribution {
  id           String   @id @default(uuid())
  userId       String   @unique
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  referrer     String?
  landingPage  String?
  signupMethod String?
  sourceTag    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sourceTag])
  @@index([createdAt])
  @@map("signup_attributions")
}

// =============================================================================
// BILLING (Subscriptions & Usage)
// =============================================================================

model Subscription {
  id                   String   @id @default(uuid())
  workspaceId          String
  stripeSubscriptionId String   @unique
  stripeCustomerId     String
  planId               String
  // Number of paying seats. Basic is always 1; Pro/Business are per-seat.
  seats                Int      @default(1)
  status               String
  billingInterval      String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId])
  @@map("subscriptions")
}

/// Super-admin-managed credit grant. Each row gives a workspace a fixed
/// number of free seats (deducted from the Stripe seat quantity, with a
/// minimum of 1 paid seat) plus a monthly USD allotment that stacks on
/// top of any plan-included USD. Multiple active grants on the same
/// workspace are summed. Mirrors prisma/schema.prisma WorkspaceGrant.
///
/// `planId` optionally upgrades the workspace to a paid plan tier
/// (basic|pro|business|enterprise) for the duration of the grant when
/// no active paid subscription exists. See prisma/schema.prisma for
/// full semantics.
model WorkspaceGrant {
  id                 String    @id @default(uuid())
  workspaceId        String
  freeSeats          Int       @default(0)
  monthlyIncludedUsd Float     @default(0)
  planId             String?
  startsAt           DateTime  @default(now())
  expiresAt          DateTime?
  note               String?
  createdByUserId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  licenseKeys  LicenseKey[]

  @@index([workspaceId, expiresAt])
  @@map("workspace_grants")
}

/// Single-use license keys. Mirrors prisma/schema.prisma LicenseKey. See
/// that file for full semantics. Only `codeHash` is persisted (sha-256
/// of canonical plaintext); the plaintext is shown to the recipient at
/// issuance and never stored.
model LicenseKey {
  id                    String    @id @default(uuid())
  codeHash              String    @unique
  codePrefix            String
  batchId               String?
  planId                String
  monthlyIncludedUsd    Float     @default(0)
  freeSeats             Int       @default(0)
  durationDays          Int?
  expiresAt             DateTime?
  redeemedAt            DateTime?
  redeemedByWorkspaceId String?   @unique
  redeemedByUserId      String?
  redeemedGrantId       String?   @unique
  note                  String?
  createdByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  redeemedGrant WorkspaceGrant? @relation(fields: [redeemedGrantId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([redeemedAt])
  @@map("license_keys")
}

model UsageWallet {
  id                           String   @id @default(uuid())
  workspaceId                  String   @unique
  monthlyIncludedUsd           Float    @default(0)
  dailyIncludedUsd             Float    @default(0)
  monthlyIncludedAllocationUsd Float    @default(0)
  dailyUsedThisMonthUsd        Float    @default(0)
  overageEnabled               Boolean  @default(true)
  overageHardLimitUsd          Float?
  overageAccumulatedUsd        Float    @default(0)
  overageBilledUsd             Float    @default(0)
  // JSON-encoded per-period alert dedupe ledger (Json? on PG). See
  // prisma/schema.prisma UsageWallet.alertsSentThisPeriod.
  alertsSentThisPeriod         String?
  stripeMeteredItemId          String?
  anniversaryDay               Int
  lastDailyReset               DateTime
  lastMonthlyReset             DateTime
  fiveHourWindowStart          DateTime?
  fiveHourUsedUsd              Float    @default(0)
  weeklyWindowStart            DateTime?
  weeklyUsedUsd                Float    @default(0)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("usage_wallets")
}

model UsageEvent {
  id             String   @id @default(uuid())
  workspaceId    String
  projectId      String?
  memberId       String
  actionType     String
  actionMetadata String?
  rawUsd         Float?
  billedUsd      Float
  source         String
  balanceBefore  Float
  balanceAfter   Float
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([memberId])
  @@index([createdAt])
  @@map("usage_events")
}

// =============================================================================
// INSTANCE SIZES (Workspace Resource Tiers & Storage)
// =============================================================================

model InstanceSubscription {
  id                   String   @id @default(uuid())
  workspaceId          String   @unique
  stripeSubscriptionId String   @unique
  stripeCustomerId     String
  instanceSize         String
  status               String
  billingInterval      String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("instance_subscriptions")
}

model StorageUsage {
  id               String   @id @default(uuid())
  workspaceId      String   @unique
  totalBytes       BigInt   @default(0)
  projectCount     Int      @default(0)
  lastCalculatedAt DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("storage_usage")
}

// =============================================================================
// STUDIO-CHAT (Chat Sessions & Messages)
// =============================================================================

model ChatSession {
  id                  String   @id @default(uuid())
  name                String?
  inferredName        String
  // Allowed values mirror schema.prisma ContextType: feature, project,
  // general, workspace. SQLite has no enum support so we store the string.
  contextType         String
  contextId           String?
  // Set only for contextType == workspace (see schema.prisma).
  workspaceId         String?
  phase               String?
  claudeCodeSessionId String?
  cachedMessageCount  Int      @default(0)
  contextUsageTokens  Int      @default(0)
  contextWindowTokens Int      @default(0)
  isPinned            Boolean  @default(false)
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
  lastActiveAt        DateTime @default(now())

  project          Project?             @relation(fields: [contextId], references: [id], onDelete: Cascade)
  workspace        Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attachedProjects ChatSessionProject[]
  messages         ChatMessage[]
  toolCallLogs     ToolCallLog[]

  @@index([contextType, contextId])
  @@index([workspaceId])
  @@map("chat_sessions")
}

/// Projects attached to a workspace-scoped ChatSession (see schema.prisma).
model ChatSessionProject {
  id         String   @id @default(uuid())
  sessionId  String
  projectId  String
  attachMode String   @default("readwrite")
  createdAt  DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([sessionId, projectId])
  @@index([projectId])
  @@map("chat_session_projects")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  content   String
  imageData String?
  parts     String?
  createdAt DateTime @default(now())
  /// Which agent authored this row. "technical" (default, legacy rows) or
  /// "voice" (EZ Mode translator overlay thread).
  agent     String   @default("technical")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@index([sessionId, agent, createdAt])
  @@map("chat_messages")
}

model ToolCallLog {
  id            String   @id @default(uuid())
  chatSessionId String
  messageId     String
  toolName      String
  status        String
  args          String?
  result        String?
  duration      Int?
  createdAt     DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
  @@index([messageId])
  @@map("tool_call_logs")
}

// =============================================================================
// PLATFORM-FEATURES (Feature Development Pipeline)
// =============================================================================

model FeatureSession {
  id                 String   @id @default(cuid())
  name               String
  intent             String
  status             String   @default("discovery")
  affectedPackages   String   @default("[]")
  schemaName         String?
  initialAssessment  String?
  featureArchetype   String?
  applicablePatterns String   @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  projectId          String?

  project                 Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requirements            Requirement[]
  designDecisions         DesignDecision[]
  classificationDecisions ClassificationDecision[]
  analysisFindings        AnalysisFinding[]
  integrationPoints       IntegrationPoint[]
  testCases               TestCase[]
  implementationTasks     ImplementationTask[]
  implementationRuns      ImplementationRun[]

  @@index([projectId])
  @@index([status])
  @@map("feature_sessions")
}

model Requirement {
  id           String   @id @default(cuid())
  sessionId    String
  name         String
  description  String
  priority     String
  status       String   @default("proposed")
  auditVerdict String?
  auditNotes   String?
  createdAt    DateTime @default(now())

  session             FeatureSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  testCases           TestCase[]
  implementationTasks ImplementationTask[]
  testSpecifications  TestSpecification[]

  @@index([sessionId])
  @@map("requirements")
}

model DesignDecision {
  id        String   @id @default(cuid())
  sessionId String
  name      String
  question  String
  decision  String
  rationale String
  createdAt DateTime @default(now())

  session FeatureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("design_decisions")
}

model ClassificationDecision {
  id                 String   @id @default(cuid())
  sessionId          String
  initialAssessment  String?
  validatedArchetype String
  evidenceChecklist  String?
  rationale          String
  correction         String?
  createdAt          DateTime @default(now())

  session FeatureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("classification_decisions")
}

model AnalysisFinding {
  id             String   @id @default(cuid())
  sessionId      String
  name           String
  type           String
  description    String
  location       String
  relevantCode   String?
  recommendation String?
  createdAt      DateTime @default(now())

  session           FeatureSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  integrationPoints IntegrationPoint[]

  @@index([sessionId])
  @@index([type])
  @@map("analysis_findings")
}

model IntegrationPoint {
  id             String   @id @default(cuid())
  sessionId      String
  name           String
  filePath       String
  package        String?
  targetFunction String?
  changeType     String?
  description    String
  rationale      String?
  findingId      String?
  isGenerated    Boolean  @default(false)
  createdAt      DateTime @default(now())

  session             FeatureSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  finding             AnalysisFinding?     @relation(fields: [findingId], references: [id], onDelete: SetNull)
  implementationTasks ImplementationTask[]

  @@index([sessionId])
  @@index([findingId])
  @@map("integration_points")
}

model TestCase {
  id            String   @id @default(cuid())
  sessionId     String
  requirementId String?
  name          String
  description   String
  given         String
  when          String
  then          String
  status        String   @default("specified")
  createdAt     DateTime @default(now())

  session     FeatureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  requirement Requirement?   @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([requirementId])
  @@map("test_cases")
}

model ImplementationTask {
  id                 String   @id @default(cuid())
  sessionId          String
  name               String
  integrationPointId String?
  requirementId      String?
  description        String
  acceptanceCriteria String   @default("[]")
  status             String   @default("planned")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  session            FeatureSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  integrationPoint   IntegrationPoint?   @relation(fields: [integrationPointId], references: [id], onDelete: SetNull)
  requirement        Requirement?        @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  dependencies       TaskDependency[]    @relation("DependentTask")
  dependents         TaskDependency[]    @relation("BlockingTask")
  testSpecifications TestSpecification[]
  taskExecutions     TaskExecution[]

  @@index([sessionId])
  @@index([integrationPointId])
  @@index([requirementId])
  @@map("implementation_tasks")
}

model TaskDependency {
  id              String @id @default(cuid())
  dependentTaskId String
  blockingTaskId  String

  dependentTask ImplementationTask @relation("DependentTask", fields: [dependentTaskId], references: [id], onDelete: Cascade)
  blockingTask  ImplementationTask @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)

  @@unique([dependentTaskId, blockingTaskId])
  @@map("task_dependencies")
}

model TestSpecification {
  id            String   @id @default(cuid())
  taskId        String
  requirementId String?
  scenario      String
  given         String   @default("[]")
  when          String
  then          String   @default("[]")
  testType      String
  targetFile    String?
  createdAt     DateTime @default(now())

  task        ImplementationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requirement Requirement?       @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([requirementId])
  @@map("test_specifications")
}

model ImplementationRun {
  id             String    @id @default(cuid())
  sessionId      String
  status         String    @default("in_progress")
  currentTaskId  String?
  completedTasks String    @default("[]")
  failedTasks    String    @default("[]")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  lastError      String?

  session        FeatureSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  taskExecutions TaskExecution[]

  @@index([sessionId])
  @@map("implementation_runs")
}

model TaskExecution {
  id                     String    @id @default(cuid())
  runId                  String
  taskId                 String
  status                 String    @default("pending")
  testFilePath           String?
  implementationFilePath String?
  testOutput             String?
  retryCount             Int       @default(0)
  errorMessage           String?
  startedAt              DateTime  @default(now())
  completedAt            DateTime?

  run  ImplementationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  task ImplementationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([taskId])
  @@map("task_executions")
}

// =============================================================================
// COMPONENT-BUILDER (Dynamic UI System)
// =============================================================================

model ComponentDefinition {
  id                String   @id @default(cuid())
  name              String
  category          String
  description       String?
  propsSchema       String?
  implementationRef String
  previewRef        String?
  tags              String   @default("[]")
  supportedConfig   String   @default("[]")
  aiGuidance        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bindings       RendererBinding[]
  fallbackFor    Registry[]        @relation("FallbackComponent")
  componentSpecs ComponentSpec[]

  @@unique([implementationRef])
  @@map("component_definitions")
}

model Registry {
