// =============================================================================
// MARKETPLACE (Agent Marketplace & Creator Economy)
// SQLite: enums → String, String[] → String (JSON), Json? → String?, no @db.Text
// =============================================================================

model CreatorProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  displayName              String
  bio                      String?
  avatarUrl                String?
  websiteUrl               String?
  stripeCustomAccountId    String?
  payoutStatus             String    @default("not_setup")
  payoutDetailsSubmittedAt DateTime?
  verified                 Boolean   @default(false)
  totalEarningsInCents     Int       @default(0)
  pendingPayoutInCents     Int       @default(0)
  totalPaidOutInCents      Int       @default(0)
  creatorTier              String    @default("newcomer")
  reputationScore          Int       @default(0)
  totalAgentsPublished     Int       @default(0)
  totalInstalls            Int       @default(0)
  averageAgentRating       Float     @default(0)
  totalVersionsShipped     Int       @default(0)
  activeMaintenanceStreak  Int       @default(0)
  followerCount            Int       @default(0)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badges       CreatorBadge[]
  listings     MarketplaceListing[]
  transactions MarketplaceTransaction[] @relation("CreatorTransactions")
  followers    CreatorFollow[]

  @@index([creatorTier])
  @@index([reputationScore])
  @@map("creator_profiles")
}

model CreatorBadge {
  id        String   @id @default(cuid())
  creatorId String
  badgeType String
  earnedAt  DateTime @default(now())
  metadata  String?

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, badgeType])
  @@index([creatorId])
  @@map("creator_badges")
}

model CreatorFollow {
  id         String   @id @default(cuid())
  followerId String
  creatorId  String
  createdAt  DateTime @default(now())

  follower User           @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  creator  CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([followerId, creatorId])
  @@index([followerId])
  @@index([creatorId])
  @@map("creator_follows")
}

model MarketplaceListing {
  id                   String    @id @default(cuid())
  projectId            String    @unique
  creatorId            String
  slug                 String    @unique
  title                String
  shortDescription     String
  longDescription      String?
  category             String?
  tags                 String    @default("[]")
  iconUrl              String?
  screenshotUrls       String    @default("[]")
  pricingModel         String    @default("free")
  priceInCents         Int?
  monthlyPriceInCents  Int?
  annualPriceInCents   Int?
  installModel         String    @default("fork")
  status               String    @default("draft")
  currentVersion       String    @default("1.0.0")
  stripePriceId        String?
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  installCount         Int       @default(0)
  averageRating        Float     @default(0)
  reviewCount          Int       @default(0)
  publishedAt          DateTime?
  featuredAt           DateTime?
  // Phase 7 admin review queue.
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  project      Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      CreatorProfile              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  versions     MarketplaceListingVersion[]
  installs     MarketplaceInstall[]
  reviews      MarketplaceReview[]
  transactions MarketplaceTransaction[]

  @@index([creatorId])
  @@index([status])
  @@index([category])
  @@index([pricingModel])
  @@index([installCount])
  @@index([averageRating])
  @@index([publishedAt])
  @@map("marketplace_listings")
}

model MarketplaceListingVersion {
  id                String  @id @default(cuid())
  listingId         String
  version           String
  changelog         String?
  // Phase 7 audit pipeline. SQLite has no enum/Json — auditStatus is one of
  // 'none' | 'pending' | 'passed' | 'flagged' | 'errored'; auditFindings is
  // a JSON-encoded string. See prisma/schema.prisma for the shape.
  auditStatus   String  @default("none")
  auditedAt     DateTime?
  auditedBy     String?
  auditFindings String?
  auditModel    String?

  // S3-backed workspace snapshot — see prisma/schema.prisma for the
  // narrative. Local SQLite stores the JSON snapshot as a String column
  // for backward compatibility; the new S3 fields are mirrored as
  // String? / Int? for installs that talk to a remote API.
  workspaceSnapshot         String?
  workspaceSnapshotKey      String?
  workspaceSnapshotBytes    Int?
  workspaceSnapshotChecksum String?

  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, version])
  @@index([listingId])
  @@map("marketplace_listing_versions")
}

model MarketplaceInstall {
  id                   String   @id @default(cuid())
  listingId            String
  projectId            String
  workspaceId          String
  userId               String
  installModel         String
  installedVersion     String
  // Phase 6 drift detection. JSON-encoded manifest of relPath -> sha256.
  baselineManifest     String?
  stripeSubscriptionId String?
  status               String   @default("active")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  listing      MarketplaceListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviews      MarketplaceReview[]
  transactions MarketplaceTransaction[]

  @@index([listingId])
  @@index([userId])
  @@index([workspaceId])
  @@index([projectId])
  @@map("marketplace_installs")
}

model MarketplaceReview {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  installId String
  rating    Int
  title     String?
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  install MarketplaceInstall @relation(fields: [installId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
  @@map("marketplace_reviews")
}

model MarketplaceTransaction {
  id                    String   @id @default(cuid())
  listingId             String
  installId             String?
  buyerUserId           String
  creatorId             String
  type                  String
  amountInCents         Int
  platformFeeInCents    Int
  creatorAmountInCents  Int
  stripePaymentIntentId String?
  stripeTransferId      String?
  currency              String   @default("usd")
  status                String   @default("pending")
  createdAt             DateTime @default(now())

  listing MarketplaceListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  install MarketplaceInstall? @relation(fields: [installId], references: [id], onDelete: SetNull)
  creator CreatorProfile      @relation("CreatorTransactions", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([creatorId])
  @@index([buyerUserId])
  @@index([status])
  @@index([createdAt])
  @@map("marketplace_transactions")
}

// =============================================================================
// VOICE / TELEPHONY (Twilio + ElevenLabs)
// =============================================================================
// Mirrors prisma/schema.prisma. See that file for the canonical docs.

model VoiceProjectConfig {
  id                    String    @id @default(cuid())
  projectId             String    @unique
  workspaceId           String
  elevenlabsAgentId     String?
  twilioPhoneNumber     String?
  twilioPhoneSid        String?
  elevenlabsPhoneId     String?
  purchasedAt           DateTime?
  monthlyRateDebitedFor DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("voice_project_configs")
}

// ProjectAgent — see canonical docs in prisma/schema.prisma.
model ProjectAgent {
  id          String @id @default(cuid())
  projectId   String
  workspaceId String
  name        String

  systemPrompt   String?
  // SQLite: JSON-encoded string[] (mirrors the postgres JSONB).
  toolsAllowlist String?
  // SQLite: JSON-encoded ToolDescriptor[] (mirrors the postgres JSONB).
  tools          String?
  characterName  String?
  displayName    String?

  voiceId           String?
  firstMessage      String?
  elevenlabsAgentId String?

  model String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([workspaceId])
  @@map("project_agents")
}

model VoiceCallMeter {
  id              String    @id @default(cuid())
  projectId       String
  workspaceId     String
  conversationId  String?   @unique
  callSid         String?   @unique
  direction       String
  durationSeconds Int
  billedMinutes   Int
  usageEventId    String?   @unique
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime  @default(now())

  /// Post-call transcript payload from ElevenLabs, serialized as JSON
  /// (SQLite has no native Json). Populated from the
  /// `post_call_transcription` webhook; null for Twilio-only deliveries
  /// or calls that didn't reach EL.
  transcript        String?
  /// Optional single-sentence summary. EL returns one when enabled.
  transcriptSummary String?

  @@index([projectId])
  @@index([workspaceId])
  @@map("voice_call_meters")
}

// =============================================================================
// AGENT COST ANALYTICS
// =============================================================================

model AgentCostMetric {
  id                String   @id @default(uuid())
  workspaceId       String
  projectId         String?
  agentRunId        String?  @unique
  agentType         String
  model             String
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  cachedInputTokens Int      @default(0)
  toolCalls         Int      @default(0)
  creditCost        Float    @default(0)
  wallTimeMs        Int      @default(0)
  success           Boolean  @default(true)
  hitMaxTurns       Boolean  @default(false)
  loopDetected      Boolean  @default(false)
  escalated         Boolean  @default(false)
  responseEmpty     Boolean  @default(false)
  metadata          String?
  createdAt         DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([agentType])
  @@index([model])
  @@index([createdAt])
  @@map("agent_cost_metrics")
}

model SubagentModelOverride {
  id          String   @id @default(uuid())
  workspaceId String
  projectId   String?
  agentType   String
  model       String
  provider    String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, projectId, agentType])
  @@index([workspaceId])
  @@index([projectId])
  @@map("subagent_model_overrides")
}

model AgentEvalResult {
  id            String   @id @default(uuid())
  workspaceId   String?
  agentType     String
  model         String
  provider      String?
  suite         String
  totalCases    Int
  passedCases   Int
  passRate      Float
  avgWallTimeMs Int      @default(0)
  avgCreditCost Float    @default(0)
  commitSha     String?
  metadata      String?
  createdAt     DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([agentType, model, createdAt])
  @@index([workspaceId])
  @@map("agent_eval_results")
}

model AgentEvalSet {
  id          String   @id @default(uuid())
  workspaceId String
  projectId   String?
  agentType   String
  name        String
  description String?
  examples    String
  enabled     Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId, agentType])
  @@index([workspaceId, projectId])
  @@map("agent_eval_sets")
}

model BudgetAlert {
  id              String    @id @default(uuid())
  workspaceId     String
  name            String
  creditLimit     Float
  periodType      String    @default("monthly")
  enabled         Boolean   @default(true)
  autoThrottle    Boolean   @default(false)
  throttleToModel String?
  notifyEmail     Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("budget_alerts")
}

model ModelExperiment {
  id              String    @id @default(uuid())
  workspaceId     String
  projectId       String?
  name            String
  agentType       String
  modelA          String
  modelB          String
  status          String    @default("running")
  splitPercentage Int       @default(50)
  expectedEndAt   DateTime?
  totalRunsA      Int       @default(0)
  totalRunsB      Int       @default(0)
  totalCostA      Float     @default(0)
  totalCostB      Float     @default(0)
  totalTokensA    Int       @default(0)
  totalTokensB    Int       @default(0)
  successRateA    Float     @default(0)
  successRateB    Float     @default(0)
  avgLatencyMsA   Float     @default(0)
  avgLatencyMsB   Float     @default(0)
  escalationsA    Int       @default(0)
  escalationsB    Int       @default(0)
  loopDetectedA   Int       @default(0)
  loopDetectedB   Int       @default(0)
  hitMaxTurnsA    Int       @default(0)
  hitMaxTurnsB    Int       @default(0)
  responseEmptyA  Int       @default(0)
  responseEmptyB  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@index([workspaceId, agentType, status])
  @@map("model_experiments")
}

// =============================================================================
// AFFILIATE / MLM PROGRAM (SQLite mirror — see prisma/schema.prisma for docs)
// =============================================================================

model Affiliate {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  code                     String    @unique
  parentAffiliateId        String?
  depth                    Int       @default(1)
  status                   String    @default("active")
  stripeCustomAccountId    String?
  payoutStatus             String    @default("not_setup")
  payoutDetailsSubmittedAt DateTime?
  totalEarningsCents       Int       @default(0)
  pendingPayoutCents       Int       @default(0)
  totalPaidOutCents        Int       @default(0)
  commissionRateBps        Int?
  termsAcceptedAt          DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Affiliate?             @relation("AffiliateUpline", fields: [parentAffiliateId], references: [id], onDelete: SetNull)
  children     Affiliate[]            @relation("AffiliateUpline")
  clicks       AffiliateClick[]
  attributions AffiliateAttribution[]
  commissions  AffiliateCommission[]
  payouts      AffiliatePayout[]

  @@index([parentAffiliateId])
  @@index([status])
  @@map("affiliates")
}

model AffiliateClick {
  id          String   @id @default(cuid())
  affiliateId String
  visitorId   String
  landingPage String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  ipHash      String?
  userAgent   String?
  country     String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  affiliate    Affiliate              @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  attributions AffiliateAttribution[]

  @@index([visitorId, createdAt])
  @@index([affiliateId, createdAt])
  @@index([expiresAt])
  @@map("affiliate_clicks")
}

model AffiliateAttribution {
  id           String   @id @default(cuid())
  userId       String   @unique
  affiliateId  String
  visitorId    String?
  clickId      String?
  attributedAt DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliate Affiliate       @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  click     AffiliateClick? @relation(fields: [clickId], references: [id], onDelete: SetNull)

  @@index([affiliateId])
  @@map("affiliate_attributions")
}

model AffiliateCommission {
  id                  String   @id @default(cuid())
  affiliateId         String
  referredUserId      String
  referredWorkspaceId String?
  stripeInvoiceId     String?
  stripeChargeId      String?
  level               Int
  basisCents          Int
  rateBps             Int
  amountCents         Int
  status              String   @default("pending")
  eligibleAt          DateTime
  payoutId            String?
  createdAt           DateTime @default(now())

  affiliate Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  payout    AffiliatePayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@unique([stripeInvoiceId, affiliateId, level])
  @@index([affiliateId, status])
  @@index([eligibleAt, status])
  @@index([stripeChargeId])
  @@map("affiliate_commissions")
}

model AffiliatePayout {
  id               String    @id @default(cuid())
  affiliateId      String
  amountCents      Int
  stripePayoutId   String?
  stripeTransferId String?
  status           String    @default("pending")
  periodStart      DateTime
  periodEnd        DateTime
  paidAt           DateTime?
  failureReason    String?
  createdAt        DateTime  @default(now())

  affiliate   Affiliate             @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  commissions AffiliateCommission[]

  @@index([affiliateId, createdAt])
  @@index([status])
  @@map("affiliate_payouts")
}

model AffiliateCommissionTier {
  id           String  @id @default(cuid())
  level        Int     @unique
  rateBps      Int
  durationDays Int?
  secondaryRateBps Int?
  label        String?

  @@map("affiliate_commission_tiers")
}
