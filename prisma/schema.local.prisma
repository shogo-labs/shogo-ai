// =============================================================================
// ANALYTICS (Daily Digests)
// =============================================================================

model AnalyticsDigest {
  id     String   @id @default(uuid())
  date   DateTime
  period String   @default("24h")
  // Region that produced this digest. Mirrors the cloud schema so the
  // unique constraint stays consistent across cloud (PG) and desktop
  // (SQLite); desktop is single-region so the value is just a static
  // tag (`desktop`) when/if the desktop app ever writes a digest.
  region String

  funnelSignups        Int    @default(0)
  funnelOnboarded      Int    @default(0)
  funnelCreatedProject Int    @default(0)
  funnelSentMessage    Int    @default(0)
  funnelEngaged        Int    @default(0)
  avgMinToFirstProject Float?
  avgMinToFirstMessage Float?

  activeUsers    Int   @default(0)
  totalMessages  Int   @default(0)
  totalSessions  Int   @default(0)
  totalToolCalls Int   @default(0)
  totalSpendUsd  Float @default(0)

  templateStats    String?
  chunksProcessed  Int     @default(1)
  messagesAnalyzed Int     @default(0)
  aiInsights       String?

  createdAt DateTime @default(now())

  @@unique([date, period, region])
  @@map("analytics_digests")
}

