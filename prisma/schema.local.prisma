  registry  Registry            @relation(fields: [registryId], references: [id], onDelete: Cascade)
  component ComponentDefinition @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@index([registryId])
  @@index([componentId])
  @@index([registryId, priority])
  @@map("renderer_bindings")
}

model LayoutTemplate {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  slots           String   @default("[]")
  defaultBindings String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  compositions Composition[]

  @@map("layout_templates")
}

model Composition {
  id              String   @id @default(cuid())
  name            String
  description     String?
  layoutId        String
  slotContent     String   @default("[]")
  dataContext     String?
  providerWrapper String?
  providerConfig  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  layout LayoutTemplate @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([layoutId])
  @@map("compositions")
}

model ComponentSpec {
  id                  String   @id @default(cuid())
  name                String
  intent              String
  componentType       String
  schemas             String   @default("[]")
  status              String   @default("draft")
  requirements        String?
  layoutDecisions     String?
  dataBindings        String?
  interactionPatterns String?
  reuseOpportunities  String?
  implementedAsId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  implementedAs ComponentDefinition? @relation(fields: [implementedAsId], references: [id], onDelete: SetNull)

  @@index([implementedAsId])
  @@map("component_specs")
}

// ============================================================================
// Platform Settings (runtime-configurable by super admins)
// ============================================================================

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_settings")
}

// ============================================================================
// Workspace-scoped model visibility (workspace owner/admin curated).
// Zero rows = inherit all platform-visible models; >= 1 row = restrict to
// exactly those ids. See packages/api workspace-models.service.ts.
// ============================================================================
model WorkspaceModelVisibility {
  id          String   @id @default(uuid())
  workspaceId String
  modelId     String
  createdAt   DateTime @default(now())
  createdBy   String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, modelId])
  @@index([workspaceId])
  @@map("workspace_model_visibility")
}

// ============================================================================
// DB-defined model catalog (super-admin managed; augments the static
// MODEL_CATALOG shipped in code). See packages/agent/src/model-catalog.
// SQLite: Json? → String? (JSON-encoded), enums → String.
// ============================================================================

// Custom OpenAI-compatible (or Anthropic-compatible) third-party endpoints,
// e.g. MiMo / xiaomimimo. Native anthropic/openai providers use env keys and
// do NOT need a row here. The API key is stored encrypted-at-rest via
// apps/api/src/lib/secret-crypto.ts and is never returned in plaintext.
model ModelProvider {
  id              String   @id @default(uuid())
  label           String
  baseUrl         String
  protocol        String   @default("openai") // "openai" | "anthropic"
  authStyle       String   @default("bearer") // "bearer" | "api-key-header"
  encryptedApiKey String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedBy       String?

  models ModelDefinition[]

  @@map("model_providers")
}

// A model addable entirely from super admin. Mirrors the static ModelEntry
// shape plus per-token pricing. `provider` is one of the native providers
// ("anthropic" | "openai" | "google" | "openrouter" | "local") or "custom";
// when "custom", `providerId` links to a ModelProvider for routing.
model ModelDefinition {
  id               String  @id
  provider         String
  providerId       String?
  apiModel         String
  displayName      String
  shortDisplayName String
  tier             String  @default("standard") // "economy" | "standard" | "premium"
  family           String  @default("other") // "opus" | "sonnet" | "haiku" | "gpt" | "other"
  generation       String  @default("current") // "current" | "legacy"
  maxOutputTokens  Int     @default(64000)
  enabled          Boolean @default(true)
  sortOrder        Int?
  aliases          String? // JSON-encoded string[] of alias ids
  capabilities     String? // JSON-encoded { subagentOrchestration?: ... }

  // User-facing picker metadata.
  description    String? // Short blurb shown in the model picker info panel.
  contextWindow  Int? // Total context window in tokens (distinct from maxOutputTokens).
  reasoningEffort String? // "off" | "minimal" | "low" | "medium" | "high" | "xhigh"

  // Per-1M-token USD list prices (raw; markup applied at billing time).
  inputPerMillion       Float @default(0)
  cachedInputPerMillion Float @default(0)
  cacheWritePerMillion  Float @default(0)
  outputPerMillion      Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  customProvider ModelProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([providerId])
  @@map("model_definitions")
}

// ============================================================================
// Infrastructure Metrics
// ============================================================================

model InfraSnapshot {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())

  totalNodes     Int
  asgDesired     Int
  asgMax         Int
  totalPodSlots  Int
  usedPodSlots   Int
  totalCpuMillis Int
  usedCpuMillis  Int
  limitCpuMillis Int @default(0)

  warmAvailable Int
  warmTarget    Int
  warmAssigned  Int
  coldStarts    Int @default(0)

  totalProjects   Int
  readyProjects   Int
  runningProjects Int
  scaledToZero    Int

  orphansDeleted Int @default(0)
  idleEvictions  Int @default(0)

  @@index([timestamp])
  @@map("infra_snapshots")
}

// =============================================================================
// API KEYS
// =============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  workspaceId String
  userId      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  kind             String    @default("user")
  deviceId         String?
  deviceName       String?
  devicePlatform   String?
  deviceAppVersion String?
  lastSeenAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, deviceId])
  @@map("api_keys")
}

// =============================================================================
// REMOTE CONTROL (Instance Registry for Local Shogo Instances)
// =============================================================================

model Instance {
  id            String    @id @default(cuid())
  workspaceId   String
  /// User who paired this machine — derived from the API key used to
  /// register/heartbeat it (see resolveApiKey). Machines are scoped to
  /// their owner so the picker only lists the signed-in user's machines.
  /// Nullable for back-compat with rows registered before ownership
  /// tracking; such rows are reset by the add_instance_user_id migration
  /// and re-created (owned) on the next heartbeat.
  userId        String?
  name          String
  hostname      String
  os            String?
  arch          String?
  kind          String    @default("desktop")
  status        String    @default("offline")
  lastSeenAt    DateTime?
  wsRequestedAt DateTime?
  metadata      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  remoteActions     RemoteAction[]
  pushSubscriptions PushSubscription[]
  preferredByProjects Project[]        @relation("ProjectPreferredInstance")

  @@unique([workspaceId, userId, hostname])
  @@index([workspaceId])
  @@index([workspaceId, userId])
  @@index([workspaceId, kind])
  @@map("instances")
}

model RemoteAction {
  id         String   @id @default(cuid())
  instanceId String
  userId     String
  action     String
  path       String?
  method     String?
  summary    String?
  result     String?
  createdAt  DateTime @default(now())

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([userId])
  @@index([createdAt])
  @@map("remote_actions")
}

model PushSubscription {
  id         String   @id @default(cuid())
  instanceId String
  userId     String
  pushToken  String
  platform   String
  createdAt  DateTime @default(now())

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, pushToken])
  @@index([instanceId])
  @@map("push_subscriptions")
}

// =============================================================================
// EVAL RUNS (Agent eval tracking — local + K8s Job support)
// =============================================================================

model EvalRun {
  id          String    @id @default(cuid())
  track       String
  model       String
  workers     Int       @default(1)
  status      String    @default("pending")
  label       String?
  tags        String    @default("[]")
  triggeredBy String?
  pid         Int?
  jobName     String?
  error       String?
  summary     String?
  cost        String?
  byCategory  String?
  resources   String?
  progress    String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  results EvalRunResult[]

  @@index([status])
  @@index([createdAt])
  @@map("eval_runs")
}

model EvalRunResult {
  id              String   @id @default(cuid())
  runId           String
  evalId          String
  name            String
  category        String
  level           Int?
  passed          Boolean
  score           Int
  maxScore        Int
  percentage      Float
  durationMs      Int
  tokens          String?
  toolCallCount   Int      @default(0)
  failedToolCalls Int      @default(0)
  iterations      Int      @default(0)
  phaseScores     String?
  pipeline        String?
  pipelinePhase   Int?
  criteria        String?
  antiPatterns    String?
  errors          String?
  warnings        String?
  log             String?
  createdAt       DateTime @default(now())

