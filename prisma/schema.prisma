// =============================================================================
// API KEYS (for Shogo Local → Cloud proxy authentication)
// =============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  workspaceId String
  userId      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  // Device session metadata. `kind` is "user" for manually-created keys and
  // "device" for keys minted via the desktop cloud-login flow. Device keys
  // carry a stable deviceId so re-logging in from the same machine dedupes
  // instead of accumulating stale credentials. lastSeenAt is updated by
  // heartbeats and by validateProxyAuth on every authenticated call.
  kind             String    @default("user")
  deviceId         String?
  deviceName       String?
  devicePlatform   String?
  deviceAppVersion String?
  lastSeenAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, deviceId])
  @@map("api_keys")
}

// =============================================================================
// REMOTE CONTROL (Instance Registry for Local Shogo Instances)
// =============================================================================

model Instance {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String
  hostname      String
  os            String?
  arch          String?
  status        InstanceStatus @default(offline)
  lastSeenAt    DateTime?
  wsRequestedAt DateTime?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  remoteActions     RemoteAction[]
  pushSubscriptions PushSubscription[]

  @@unique([workspaceId, hostname])
  @@index([workspaceId])
  @@map("instances")
}

enum InstanceStatus {
  online
  offline
}

model RemoteAction {
  id         String   @id @default(cuid())
  instanceId String
  userId     String
  action     String
  path       String?
  method     String?
  summary    String?
  result     String?
  createdAt  DateTime @default(now())

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([userId])
  @@index([createdAt])
  @@map("remote_actions")
}

model PushSubscription {
  id         String   @id @default(cuid())
  instanceId String
  userId     String
  pushToken  String
  platform   String
  createdAt  DateTime @default(now())

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, pushToken])
  @@index([instanceId])
  @@map("push_subscriptions")
}

