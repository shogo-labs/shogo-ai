// Shogo AI - Prisma Schema
// Migrated from Enhanced JSON Schema (.schemas/*.json)
//
// This schema consolidates all domains:
// - studio-core: Workspace, Project, Member, etc.
// - platform-features: FeatureSession, Requirements, Tasks, etc.
// - billing: Subscription, UsageWallet, UsageEvent
// - studio-chat: ChatSession, ChatMessage, ToolCallLog
// - component-builder: ComponentDefinition, Registry, Bindings
// - better-auth: User, Session, Account, Verification

generator client {
  provider = "prisma-client"
  output   = "../apps/api/src/generated/prisma-pg"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// BETTER-AUTH (Authentication)
// =============================================================================

enum UserRole {
  user
  super_admin
}

model User {
  id                  String   @id @default(cuid())
  name                String?
  email               String   @unique
  emailVerified       Boolean  @default(false)
  image               String?
  role                UserRole @default(user)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  sessions             Session[]
  accounts             Account[]
  members              Member[]
  notifications        Notification[]
  starredProjects      StarredProject[]
  signupAttribution    SignupAttribution?
  apiKeys              ApiKey[]
  creatorProfile       CreatorProfile?
  creatorFollows       CreatorFollow[]      @relation("UserFollows")
  affiliate            Affiliate?
  affiliateAttribution AffiliateAttribution?
  projectAuthSignIns   ProjectAuthSignIn[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// =============================================================================
// STUDIO-CORE (Multi-tenancy & Project Management)
// =============================================================================

model Workspace {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  description   String?
  ssoSettings   Json?
  instanceSize  InstanceSize @default(micro)
  // Whether Composio OAuth connections are stored at workspace scope
  // (one auth per toolkit shared across every project) or project
  // scope (each project gets its own isolated connections). New
  // workspaces default to "workspace"; existing workspaces are
  // back-filled to "project" by the matching migration so behavior
  // for already-connected accounts is preserved.
  composioScope String       @default("workspace")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  projects               Project[]
  members                Member[]
  billingAccounts        BillingAccount[]
  invitations            Invitation[]
  inviteLinks            InviteLink[]
  folders                Folder[]
  subscriptions          Subscription[]
  instanceSubscription   InstanceSubscription?
  usageWallets           UsageWallet[]
  usageEvents            UsageEvent[]
  storageUsage           StorageUsage?
  starredProjects        StarredProject[]
  apiKeys                ApiKey[]
  instances              Instance[]
  meetings               Meeting[]
  voiceProjectConfigs    VoiceProjectConfig[]
  projectAgents          ProjectAgent[]
  agentCostMetrics       AgentCostMetric[]
  budgetAlerts           BudgetAlert[]
  modelExperiments       ModelExperiment[]
  subagentModelOverrides SubagentModelOverride[]
  agentEvalResults       AgentEvalResult[]
  agentEvalSets          AgentEvalSet[]
  grants                 WorkspaceGrant[]

  @@map("workspaces")
}

enum InstanceSize {
  micro
  small
  medium
  large
  xlarge
}

model Project {
  id                 String           @id @default(uuid())
  name               String
  description        String?
  workspaceId        String
  tier               ProjectTier      @default(starter)
  status             ProjectStatus    @default(draft)
  schemas            String[]         @default([])
  createdBy          String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  folderId           String?
  publishedSubdomain String?          @unique
  publishedAt        DateTime?
  // Tracks where in the publish pipeline this project currently is.
  // Updated by apps/api/src/routes/publish.ts at each step so a stuck
  // or cancelled HTTP request still leaves a recoverable trail in the
  // DB. `failed` carries the last error code in `publishError`.
  publishStatus      PublishStatus    @default(idle)
  publishError       String?
  publishStatusAt    DateTime?
  accessLevel        AccessLevel      @default(anyone)
  category           ProjectCategory?
  siteTitle          String?
  siteDescription    String?
  thumbnailUrl       String?
  templateId         String?
  knativeServiceName String?
  settings           Json?
  lastMessageAt      DateTime?
  // External / IDE-style project mode. `managed` keeps the historical
  // workspaces/<projectId> sandbox behavior. `external` points the project
  // at one or more folders on the user's machine (see ProjectFolder); the
  // Vite/Metro runtime + auto-checkpoints are disabled by default to match
  // VS Code / Cursor expectations.
  workingMode    String  @default("managed")
  runtimeEnabled Boolean @default(true)
  // VS Code Workspace Trust model. `restricted` blocks write/exec tools
  // until the user explicitly trusts the folder. Managed projects are
  // implicitly trusted (they live in our sandbox).
  trustLevel     String  @default("trusted")

  // External-trigger routing: when set, /api/projects/:id/agent-proxy/*
  // requests are relayed through the paired Instance's tunnel instead of
  // a cloud pod. Lets external services (Jira, Zapier, cron) hit one
  // stable URL per project regardless of where the agent actually runs.
  //   - `preferredInstanceId` references an Instance in the same workspace.
  //   - `preferredInstancePolicy` controls offline behavior:
  //       `pinned` (default) -> 503 if the instance is offline (caller retries).
  //       `prefer`           -> fall back to the cloud pod when offline.
  // See apps/api/src/lib/agent-proxy-resolver.ts for the resolution order.
  preferredInstanceId     String?
  preferredInstancePolicy String  @default("pinned")

  // Cloud workspace sync mode. Controls how the cloud agent-runtime pod
  // syncs the workspace back to durable storage.
  //   - `s3`          (default) — today's behavior. S3Sync writes both
  //                   layers; ProjectCheckpoint inserted by project-chat.ts.
  //   - `dual_shadow` — verification. S3Sync still authoritative; the pod
  //                   ALSO pushes commits via the smart-HTTP backend so the
  //                   post-receive hook writes ProjectCheckpoint rows. Used
  //                   to compare git-side vs S3-side checkpoints before
  //                   flipping a project to `git_only`.
  //   - `git_only`    — git is the primary writer for per-turn diffs. S3
  //                   Layer 2 stays suppressed but armed as an automatic
  //                   fallback if push fails repeatedly, and always writes
  //                   the cold-start snapshot at evict.
  // Operationally additive: existing projects keep `s3` semantics.
  // See apps/docs/docs/architecture/cloud-pod-sync.md.
  cloudSyncMode CloudSyncMode @default(s3)

  // Relations
  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder                 Folder?                 @relation(fields: [folderId], references: [id], onDelete: SetNull)
  members                Member[]
  inviteLinks            InviteLink[]
  featureSessions        FeatureSession[]
  chatSessions           ChatSession[]
  usageEvents            UsageEvent[]
  checkpoints            ProjectCheckpoint[]
  githubConnection       GitHubConnection?
  starredBy              StarredProject[]
  agentConfig            AgentConfig?
  meetings               Meeting[]
  marketplaceListing     MarketplaceListing?
  agentCostMetrics       AgentCostMetric[]
  modelExperiments       ModelExperiment[]
  subagentModelOverrides SubagentModelOverride[]
  agentEvalSets          AgentEvalSet[]
  voiceConfig            VoiceProjectConfig?
  agents                 ProjectAgent[]
  projectFolders         ProjectFolder[]
  preferredInstance      Instance?               @relation("ProjectPreferredInstance", fields: [preferredInstanceId], references: [id], onDelete: SetNull)
  authConfig             ProjectAuthConfig?
  authSignIns            ProjectAuthSignIn[]

  @@index([workspaceId])
  @@index([folderId])
  @@index([preferredInstanceId])
  @@map("projects")
}

/// External host folder linked to a project (workingMode='external').
/// One folder is `isPrimary` and hosts `<path>/.shogo/`. All folders are
/// available as agent path roots. See `assertAllowedPath()` in
/// packages/agent-runtime/src/gateway-tools.ts.
model ProjectFolder {
  id           String    @id @default(uuid())
  projectId    String
  path         String
  isPrimary    Boolean   @default(false)
  addedAt      DateTime  @default(now())
  lastOpenedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_folders")
}

/// Per-project sign-in allowlist for users authenticating via the Shogo
/// SDK (`shogo.auth` -> platform `/api/auth/*`). When the SDK forwards
/// `X-Shogo-Project-Id` on `/sign-in/*` and `/sign-up/email`, the Better
/// Auth before-hook in apps/api/src/auth.ts loads this config and either
/// allows the request or rejects with 403 `project_auth_not_allowed`.
///
/// Modes:
///   - `anyone`    — no project-level restriction (SDK allowlist disabled).
///   - `workspace` — only existing Member rows on the project's workspace
///                   (or holders of an active Invitation for it) may sign
///                   in. New sign-ups without an invite are rejected.
///   - `custom`    — allow if the email is in `allowedEmails` OR the
///                   email's domain (lowercased, no `@`) is in
///                   `allowedDomains`.
model ProjectAuthConfig {
  id                       String   @id @default(uuid())
  projectId                String   @unique
  mode                     String   @default("anyone") // "anyone" | "workspace" | "custom"
  allowedEmails            String[] @default([]) // exact-match, lowercased
  allowedDomains           String[] @default([]) // e.g. "acme.com", lowercased, no `@`
  requireEmailVerification Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_auth_configs")
}

/// Tracks every (project, user) pair that has signed in to a project via
/// the Shogo SDK auth path (header `X-Shogo-Project-Id`). Inserted on
/// first sign-in / sign-up by the Better Auth before-hook in
/// apps/api/src/auth.ts and updated on each subsequent sign-in. Powers
/// the Users panel under Studio Settings -> Auth & Database.
model ProjectAuthSignIn {
  id           String   @id @default(uuid())
  projectId    String
  userId       String
  firstSignInAt DateTime @default(now())
  lastSignInAt  DateTime @default(now())
  signInCount   Int      @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId, lastSignInAt(sort: Desc)])
  @@map("project_auth_sign_ins")
}

model AgentConfig {
  id                 String    @id @default(uuid())
  projectId          String    @unique
  heartbeatInterval  Int       @default(1800)
  heartbeatEnabled   Boolean   @default(false)
  nextHeartbeatAt    DateTime?
  lastHeartbeatAt    DateTime?
  quietHoursStart    String?
  quietHoursEnd      String?
  quietHoursTimezone String?
  channels           Json      @default("[]")
  modelProvider      String    @default("anthropic")
  modelName          String    @default("claude-haiku-4-5")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

/// Cloud workspace sync strategy. See Project.cloudSyncMode.
enum CloudSyncMode {
  s3
  dual_shadow
  git_only
}

enum ProjectTier {
  starter
  pro
  enterprise
  internal
}

enum ProjectStatus {
  draft
  active
  archived
}

enum AccessLevel {
  anyone
  authenticated
  private
}

// Step the publish pipeline has reached for this project. The pipeline
// (apps/api/src/routes/publish.ts) updates this in-line so Studio (and
// operators) can observe a frozen request without scraping logs.
enum PublishStatus {
  idle
  building
  uploading
  configuring
  live
  failed
}

enum ProjectCategory {
  app
  website
  tool
  game
}

// =============================================================================
// VERSION CONTROL (Checkpoints & GitHub Integration)
// =============================================================================

model ProjectCheckpoint {
  id            String   @id @default(uuid())
  projectId     String
  name          String? // User-provided name like "Before auth changes"
  description   String?
  commitSha     String // Git commit SHA
  commitMessage String
  branch        String   @default("main")
  includesDb    Boolean  @default(false)
  filesChanged  Int      @default(0)
  additions     Int      @default(0)
  deletions     Int      @default(0)
  isAutomatic   Boolean  @default(false) // Auto-checkpoint from AI operations
  createdBy     String?
  createdAt     DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([commitSha])
  @@map("project_checkpoints")
}

model GitHubConnection {
  id             String    @id @default(uuid())
  projectId      String    @unique
  repoOwner      String
  repoName       String
  repoFullName   String // owner/repo for convenience
  defaultBranch  String    @default("main")
  installationId Int? // GitHub App installation ID
  repoId         Int? // GitHub repository ID
  isPrivate      Boolean   @default(true)
  syncEnabled    Boolean   @default(true)
  lastPushAt     DateTime?
  lastPullAt     DateTime?
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([repoFullName])
  @@map("github_connections")
}

model StarredProject {
  id          String   @id @default(uuid())
  userId      String
  projectId   String
  workspaceId String
  createdAt   DateTime @default(now())

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([userId])
  @@map("starred_projects")
}

model Member {
  id             String     @id @default(uuid())
  userId         String
  role           MemberRole @default(member)
  workspaceId    String?
  projectId      String?
  isBillingAdmin Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([projectId])
  @@map("members")
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

model BillingAccount {
  id               String   @id @default(uuid())
  workspaceId      String
  stripeCustomerId String?
  taxId            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId])
  @@map("billing_accounts")
}

model Invitation {
  id          String           @id @default(uuid())
  email       String
  role        MemberRole       @default(member)
  workspaceId String?
  projectId   String?
  status      InvitationStatus @default(pending)
  emailStatus EmailStatus      @default(not_sent)
  emailSentAt DateTime?
  emailError  String?
  invitedBy   String?
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([workspaceId])
  @@map("invitations")
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
  cancelled
}

enum EmailStatus {
  not_sent
  sent
  failed
}

model InviteLink {
  id          String     @id @default(uuid())
  token       String     @unique @default(uuid())
  projectId   String?
  workspaceId String?
  role        MemberRole @default(member)
  createdBy   String
  enabled     Boolean    @default(true)
  expiresAt   DateTime?
  useCount    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([projectId])
  @@map("invite_links")
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  workspaceId String
  parentId    String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]  @relation("FolderHierarchy")
  projects  Project[]

  @@index([workspaceId])
  @@index([parentId])
  @@map("folders")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@map("notifications")
}

enum NotificationType {
  invitation_pending
  invitation_accepted
  member_joined
  member_left
  workspace_updated
}

// =============================================================================
// BILLING (Subscriptions & Usage)
// =============================================================================

model Subscription {
  id                   String             @id @default(uuid())
  workspaceId          String
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  planId               String
  // Number of paying seats. Basic is always 1; Pro/Business are per-seat.
  seats                Int                @default(1)
  status               SubscriptionStatus
  billingInterval      BillingInterval
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
  paused
}

enum BillingInterval {
  monthly
  annual
}

model UsageWallet {
  id                           String   @id @default(uuid())
  workspaceId                  String   @unique
  monthlyIncludedUsd           Float    @default(0)
  dailyIncludedUsd             Float    @default(0)
  monthlyIncludedAllocationUsd Float    @default(0)
  dailyUsedThisMonthUsd        Float    @default(0)
  overageEnabled               Boolean  @default(true)
  overageHardLimitUsd          Float?
  overageAccumulatedUsd        Float    @default(0)
  // USD already invoiced this period in $100 trust blocks. When
  // `overageAccumulatedUsd` crosses the next 100 dollar threshold past this
  // value, a new $100 invoice is created mid-cycle and this field bumps.
  // Resets to 0 each monthly allocation reset.
  overageBilledUsd             Float    @default(0)
  stripeMeteredItemId          String?
  anniversaryDay               Int
  lastDailyReset               DateTime
  lastMonthlyReset             DateTime
  // Rolling usage windows (time-gated "unlimited"). Each window starts on the
  // first metered action after the previous window elapsed and accumulates
  // marked-up USD of compute until it resets. `null` start = window not yet
  // opened. See `usage-plans.ts` (FIVE_HOUR_MS / SEVEN_DAY_MS) and
  // `ROLLING_WINDOW_LIMITS`.
  fiveHourWindowStart          DateTime?
  fiveHourUsedUsd              Float    @default(0)
  weeklyWindowStart            DateTime?
  weeklyUsedUsd                Float    @default(0)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("usage_wallets")
}

model UsageEvent {
  id             String      @id @default(uuid())
  workspaceId    String
  projectId      String?
  memberId       String
  actionType     String
  actionMetadata Json?
  rawUsd         Float?
  billedUsd      Float
  source         UsageSource
  balanceBefore  Float
  balanceAfter   Float
  createdAt      DateTime    @default(now())

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([memberId])
  @@index([createdAt])
  @@map("usage_events")
}

enum UsageSource {
  daily
  monthly
  overage
  window
}

/// Super-admin-managed credit grant. Each row gives a workspace a fixed
/// number of free seats (deducted from the Stripe seat quantity, with a
/// minimum of 1 paid seat) plus a monthly USD allotment that stacks on
/// top of any plan-included USD. Multiple active grants on the same
/// workspace are summed.
///
/// `planId` optionally upgrades the workspace to a paid plan tier
/// (basic|pro|business|enterprise) for the duration of the grant *when
/// no active paid Stripe subscription exists*. The wallet allocation
/// then uses `getMonthlyIncludedForPlan(planId, max(1, freeSeats)) +
/// monthlyIncludedUsd`, and the plan-gate helpers
/// (`hasPaidSubscription`, `hasAdvancedModelAccess`,
/// `isBusinessOrHigherPlan`) treat the workspace as on that plan.
/// `planId = null` keeps the legacy "free seats + monthly USD" only
/// behavior. If a paid subscription exists, the subscription's plan
/// always takes precedence (the grant's `planId` is ignored).
model WorkspaceGrant {
  id                 String    @id @default(uuid())
  workspaceId        String
  freeSeats          Int       @default(0)
  monthlyIncludedUsd Float     @default(0)
  planId             String?
  startsAt           DateTime  @default(now())
  expiresAt          DateTime?
  note               String?
  createdByUserId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  licenseKeys  LicenseKey[]

  @@index([workspaceId, expiresAt])
  @@map("workspace_grants")
}

/// Single-use license keys that promote a workspace to a paid plan by
/// minting a `WorkspaceGrant` on redemption. Issuance and redemption are
/// decoupled so we can pre-mint batches (e.g. for a launch), revoke or
/// expire unredeemed keys, and audit who redeemed what.
///
/// The plaintext code is shown to the recipient exactly once at issuance
/// and is never persisted; only `codeHash` (sha-256, hex-encoded) is
/// stored. `codePrefix` is the first 12 plaintext chars and is fine to
/// store/display because it doesn't expose enough entropy to brute-force
/// a redemption.
///
/// Single-use is enforced by `redeemedAt` + the `redeemedByWorkspaceId`
/// / `redeemedGrantId` unique constraints. The redeem path uses
/// `updateMany({ where: { codeHash, redeemedAt: null } })` so the row
/// lock serializes concurrent redemptions atomically.
model LicenseKey {
  id                    String         @id @default(uuid())
  /// sha-256 hex of the canonical (uppercased, trimmed) plaintext code.
  codeHash              String         @unique
  /// First 12 plaintext chars (e.g. `SHGO-PRO-XXX`). For admin lookup
  /// and CSV reconciliation only — never enough entropy to redeem.
  codePrefix            String
  /// Optional batch identifier, e.g. `hn-launch-2026`.
  batchId               String?
  /// Plan the redemption confers via the generated grant. One of
  /// `basic|pro|business|enterprise` (mirrors `WorkspaceGrant.planId`).
  planId                String
  /// Optional extra USD credit stacked into the generated grant.
  monthlyIncludedUsd    Float          @default(0)
  /// Optional extra free seats stacked into the generated grant.
  freeSeats             Int            @default(0)
  /// Length of the conferred grant in days. `null` = perpetual.
  durationDays          Int?
  /// If set, the key itself becomes invalid after this instant even if
  /// never redeemed. Independent from the grant's own expiry.
  expiresAt             DateTime?
  /// Set atomically on the first successful redemption.
  redeemedAt            DateTime?
  redeemedByWorkspaceId String?        @unique
  redeemedByUserId      String?
  /// `WorkspaceGrant.id` minted by the redemption, for audit + revoke.
  redeemedGrantId       String?        @unique
  note                  String?
