// =============================================================================
// VOICE / TELEPHONY (Twilio + ElevenLabs)
// =============================================================================
//
// VoiceProjectConfig stores ONLY Shogo-owned resource handles for Mode B
// (Shogo-hosted) telephony. No user-provided secrets are ever stored. Shogo's
// ElevenLabs API key and Twilio account credentials live in the API server's
// env (ELEVENLABS_API_KEY, TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN) and the
// corresponding agent / phone-number / phone-registration is provisioned on
// demand per project and tracked here.
//
// Mode A (bring-your-own keys) never touches this table.

model VoiceProjectConfig {
  id                    String    @id @default(cuid())
  projectId             String    @unique
  workspaceId           String
  elevenlabsAgentId     String?
  twilioPhoneNumber     String?
  twilioPhoneSid        String?
  elevenlabsPhoneId     String?
  purchasedAt           DateTime?
  monthlyRateDebitedFor DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("voice_project_configs")
}

// ProjectAgent is the unified persona record for a project — same row
// is reachable from both `useShogoVoice({ agentName })` and
// `useShogoChat({ agentName })`. Voice-capable agents have `voiceId`
// set (and lazily get `elevenlabsAgentId` populated on first signed-
// URL request); chat-only agents leave those null.
//
// Reconciled from `shogo.config.json#agents` via `shogo deploy` →
// POST /api/projects/:id/agents/sync.
//
// The legacy `VoiceProjectConfig.elevenlabsAgentId` column remains
// the fallback for the `default` agent of pre-migration projects;
// the sync endpoint backfills a `default` row on first deploy.

model ProjectAgent {
  id          String @id @default(cuid())
  projectId   String
  workspaceId String
  // Stable name keyed off `(projectId, name)`. `default` is special —
  // it's what `agentName === undefined` resolves to.
  name        String

  // Shared by both modalities.
  systemPrompt   String?
  // Allowlist of tool names — kept for backwards compatibility with
  // pre-tool-schemas deploys. New code reads `tools` (full descriptors)
  // instead. Backfilled into `tools` by the
  // `add_project_agents_tools` migration; will be dropped once the
  // dual-read window closes.
  toolsAllowlist Json?
  // Tool descriptors: array of { name, description?, inputSchema? }.
  // Source of truth as of `shogo deploy` v1.6+. The chat route
  // declares these to `streamText` and the voice sync forwards them
  // to ElevenLabs `createAgent`/`patchAgent` as `prompt.tools`.
  tools          Json?
  characterName  String?
  displayName    String?

  // Voice-only.
  voiceId           String?
  firstMessage      String?
  // Lazy-provisioned on first voice request when `voiceId` is set.
  elevenlabsAgentId String?

  // Chat-only.
  model String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([workspaceId])
  @@map("project_agents")
}

// VoiceCallMeter dedupes webhooks from ElevenLabs (post_call_transcription)
// and Twilio (statusCallback). First writer wins on (conversationId, callSid);
// subsequent webhooks are no-ops once `usageEventId` is set.

model VoiceCallMeter {
  id              String    @id @default(cuid())
  projectId       String
  workspaceId     String
  conversationId  String?   @unique
  callSid         String?   @unique
  direction       String
  durationSeconds Int
  billedMinutes   Int
  usageEventId    String?   @unique
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime  @default(now())

  /// Post-call transcript payload from ElevenLabs (array of turns).
  /// Populated from the `post_call_transcription` webhook; null for
  /// Twilio-only deliveries or calls that didn't reach EL.
  transcript        Json?
  /// Optional single-sentence summary. EL returns one when enabled.
  transcriptSummary String?

  @@index([projectId])
  @@index([workspaceId])
  @@map("voice_call_meters")
}

// =============================================================================
// AGENT COST ANALYTICS
// =============================================================================

model AgentCostMetric {
  id                String   @id @default(uuid())
  workspaceId       String
  projectId         String?
  /// Subagent run id (a-<label>-<hex>) — links runtime traces to cost metrics.
  agentRunId        String?  @unique
  agentType         String
  model             String
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  cachedInputTokens Int      @default(0)
  toolCalls         Int      @default(0)
  creditCost        Float    @default(0)
  wallTimeMs        Int      @default(0)
  /// Legacy field — true when the run promise resolved without throwing. Kept for backwards
  /// compatibility but DO NOT use as the primary success signal — use the multi-signal
  /// columns below. See cost-analytics.service.
  success           Boolean  @default(true)
  /// Run hit the configured maxTurns ceiling without producing a final answer.
  hitMaxTurns       Boolean  @default(false)
  /// Loop detector tripped during this run.
  loopDetected      Boolean  @default(false)
  /// Auto-router escalated to a higher-tier model mid-run (signal of insufficient capability).
  escalated         Boolean  @default(false)
  /// Final response was empty / whitespace / "Subagent failed:" prefix.
  responseEmpty     Boolean  @default(false)
  metadata          Json?
  createdAt         DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([agentType])
  @@index([model])
  @@index([createdAt])
  @@map("agent_cost_metrics")
}

// =============================================================================
// SUBAGENT MODEL OVERRIDES — user-controlled model per built-in sub-agent type
// =============================================================================
// Resolution precedence (highest first):
//   1. Explicit caller-supplied SubagentConfig.model
//   2. Project-level override          (workspaceId + projectId + agentType)
//   3. Workspace-level override        (workspaceId + projectId=NULL + agentType)
//   4. Built-in default from getBuiltinSubagentConfig()
// See packages/agent-runtime/src/subagent.ts → resolveSubagentModel().

model SubagentModelOverride {
  id          String   @id @default(uuid())
  workspaceId String
  /// NULL = workspace-default override; non-null = project-specific override.
  projectId   String?
  agentType   String
  model       String
  provider    String?
  /// User id of the admin who last set this override (nullable for system applies).
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// One override per (workspace, project?, agentType). Use upsert keyed on this.
  @@unique([workspaceId, projectId, agentType])
  @@index([workspaceId])
  @@index([projectId])
  @@map("subagent_model_overrides")
}

// =============================================================================
// AGENT EVAL RESULTS — eval-anchored ground truth for recommendations
// =============================================================================
// Populated by the nightly eval runner (run-eval --agent-type=<x> --model=<y>).
// Recommendations cite the latest pass-rate so the user sees why a swap is safe.

model AgentEvalResult {
  id            String   @id @default(uuid())
  workspaceId   String?
  agentType     String
  model         String
  provider      String?
  /// Eval suite identifier — e.g. "test-cases-subagent.ts:explore-suite".
  suite         String
  totalCases    Int
  passedCases   Int
  /// 0..1 ratio (passedCases / totalCases). Stored separately for fast sorting.
  passRate      Float
  avgWallTimeMs Int      @default(0)
  avgCreditCost Float    @default(0)
  /// Optional commit SHA the eval ran against — for reproducibility.
  commitSha     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([agentType, model, createdAt])
  @@index([workspaceId])
  @@map("agent_eval_results")
}

