// =============================================================================
// MARKETPLACE (Agent Marketplace & Creator Economy)
// =============================================================================

enum PayoutStatus {
  not_setup
  pending_verification
  verified
  requires_update
  disabled
}

enum CreatorTier {
  newcomer
  builder
  craftsman
  expert
  master
}

enum BadgeType {
  first_agent
  popular_10
  popular_100
  popular_1000
  top_rated
  five_star
  prolific_builder
  master_builder
  active_maintainer
  streak_3
  streak_6
  streak_12
  multi_category
  early_adopter
  verified_creator
}

enum PricingModel {
  free
  one_time
  subscription
}

enum InstallModel {
  fork
  linked
}

enum ListingStatus {
  draft
  in_review
  published
  suspended
  archived
}

enum InstallStatus {
  active
  cancelled
  expired
}

enum TransactionType {
  purchase
  subscription_payment
  refund
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

model CreatorProfile {
  id                      String       @id @default(cuid())
  userId                  String       @unique
  displayName             String
  bio                     String?
  avatarUrl               String?
  websiteUrl              String?
  stripeCustomAccountId   String?
  payoutStatus            PayoutStatus @default(not_setup)
  payoutDetailsSubmittedAt DateTime?
  verified                Boolean      @default(false)
  totalEarningsInCents    Int          @default(0)
  pendingPayoutInCents    Int          @default(0)
  totalPaidOutInCents     Int          @default(0)
  creatorTier             CreatorTier  @default(newcomer)
  reputationScore         Int          @default(0)
  totalAgentsPublished    Int          @default(0)
  totalInstalls           Int          @default(0)
  averageAgentRating      Float        @default(0)
  totalVersionsShipped    Int          @default(0)
  activeMaintenanceStreak Int          @default(0)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badges       CreatorBadge[]
  listings     MarketplaceListing[]
  transactions MarketplaceTransaction[] @relation("CreatorTransactions")

  @@index([creatorTier])
  @@index([reputationScore(sort: Desc)])
  @@map("creator_profiles")
}

model CreatorBadge {
  id        String    @id @default(cuid())
  creatorId String
  badgeType BadgeType
  earnedAt  DateTime  @default(now())
  metadata  Json?

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, badgeType])
  @@index([creatorId])
  @@map("creator_badges")
}

model MarketplaceListing {
  id                   String        @id @default(cuid())
  projectId            String        @unique
  creatorId            String
  slug                 String        @unique
  title                String
  shortDescription     String
  longDescription      String?       @db.Text
  category             String?
  tags                 String[]      @default([])
  iconUrl              String?
  screenshotUrls       String[]      @default([])
  pricingModel         PricingModel  @default(free)
  priceInCents         Int?
  monthlyPriceInCents  Int?
  annualPriceInCents   Int?
  installModel         InstallModel  @default(fork)
  status               ListingStatus @default(draft)
  currentVersion       String        @default("1.0.0")
  stripePriceId        String?
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  installCount         Int           @default(0)
  averageRating        Float         @default(0)
  reviewCount          Int           @default(0)
  publishedAt          DateTime?
  featuredAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      CreatorProfile           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  versions     MarketplaceListingVersion[]
  installs     MarketplaceInstall[]
  reviews      MarketplaceReview[]
  transactions MarketplaceTransaction[]

  @@index([creatorId])
  @@index([status])
  @@index([category])
  @@index([pricingModel])
  @@index([installCount(sort: Desc)])
  @@index([averageRating(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
  @@map("marketplace_listings")
}

model MarketplaceListingVersion {
  id                String   @id @default(cuid())
  listingId         String
  version           String
  changelog         String?  @db.Text
  workspaceSnapshot Json?

  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, version])
  @@index([listingId])
  @@map("marketplace_listing_versions")
}

model MarketplaceInstall {
  id                   String        @id @default(cuid())
  listingId            String
  projectId            String
  workspaceId          String
  userId               String
  installModel         InstallModel
  installedVersion     String
  stripeSubscriptionId String?
  status               InstallStatus @default(active)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  listing      MarketplaceListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviews      MarketplaceReview[]
  transactions MarketplaceTransaction[]

  @@index([listingId])
  @@index([userId])
  @@index([workspaceId])
  @@index([projectId])
  @@map("marketplace_installs")
}

model MarketplaceReview {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  installId String
  rating    Int
  title     String?
  body      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  install MarketplaceInstall @relation(fields: [installId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
  @@map("marketplace_reviews")
}

model MarketplaceTransaction {
  id                   String            @id @default(cuid())
  listingId            String
  installId            String?
  buyerUserId          String
  creatorId            String
  type                 TransactionType
  amountInCents        Int
  platformFeeInCents   Int
  creatorAmountInCents Int
  stripePaymentIntentId String?
  stripeTransferId     String?
  currency             String            @default("usd")
  status               TransactionStatus @default(pending)
  createdAt            DateTime          @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  install MarketplaceInstall? @relation(fields: [installId], references: [id], onDelete: SetNull)
  creator CreatorProfile     @relation("CreatorTransactions", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([creatorId])
  @@index([buyerUserId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("marketplace_transactions")
}

model EvalRunResult {
  id            String   @id @default(cuid())
  runId         String
  evalId        String
  name          String
  category      String
  level         Int?
  passed        Boolean
  score         Int
  maxScore      Int
  percentage    Float
  durationMs      Int
  tokens          Json?
  toolCallCount   Int       @default(0)
  failedToolCalls Int       @default(0)
  iterations      Int       @default(0)
  phaseScores     Json?
  pipeline        String?
  pipelinePhase   Int?
  criteria        Json?
  antiPatterns    Json?
  errors          Json?
  warnings        Json?
  log             String?  @db.Text
  createdAt       DateTime @default(now())

  run           EvalRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([evalId])
  @@map("eval_run_results")
}

// =============================================================================
// MEETINGS (Recording & Transcription)
// =============================================================================

model Meeting {
  id            String   @id @default(cuid())
  title         String?
  audioPath     String
  transcript    String?  @db.Text
  summary       String?  @db.Text
  duration      Int?
  status        String   @default("recording")
  projectId     String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@map("meetings")
}

// =============================================================================
// VOICE / TELEPHONY (Twilio + ElevenLabs)
// =============================================================================
//
// VoiceProjectConfig stores ONLY Shogo-owned resource handles for Mode B
// (Shogo-hosted) telephony. No user-provided secrets are ever stored. Shogo's
// ElevenLabs API key and Twilio account credentials live in the API server's
// env (ELEVENLABS_API_KEY, TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN) and the
// corresponding agent / phone-number / phone-registration is provisioned on
// demand per project and tracked here.
//
// Mode A (bring-your-own keys) never touches this table.

model VoiceProjectConfig {
  id                    String    @id @default(cuid())
  projectId             String    @unique
  workspaceId           String
  elevenlabsAgentId     String?
  twilioPhoneNumber     String?
  twilioPhoneSid        String?
  elevenlabsPhoneId     String?
  purchasedAt           DateTime?
  monthlyRateDebitedFor DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("voice_project_configs")
}

// VoiceCallMeter dedupes webhooks from ElevenLabs (post_call_transcription)
// and Twilio (statusCallback). First writer wins on (conversationId, callSid);
// subsequent webhooks are no-ops once `usageEventId` is set.

model VoiceCallMeter {
  id              String    @id @default(cuid())
  projectId       String
  workspaceId     String
  conversationId  String?   @unique
  callSid         String?   @unique
  direction       String
  durationSeconds Int
  billedMinutes   Int
  usageEventId    String?   @unique
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime  @default(now())

  /// Post-call transcript payload from ElevenLabs (array of turns).
  /// Populated from the `post_call_transcription` webhook; null for
  /// Twilio-only deliveries or calls that didn't reach EL.
  transcript      Json?
  /// Optional single-sentence summary. EL returns one when enabled.
  transcriptSummary String?

  @@index([projectId])
  @@index([workspaceId])
  @@map("voice_call_meters")
}
