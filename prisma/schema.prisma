model MarketplaceListing {
  id                   String        @id @default(cuid())
  projectId            String        @unique
  creatorId            String
  slug                 String        @unique
  title                String
  shortDescription     String
  longDescription      String?       @db.Text
  category             String?
  tags                 String[]      @default([])
  iconUrl              String?
  screenshotUrls       String[]      @default([])
  pricingModel         PricingModel  @default(free)
  priceInCents         Int?
  monthlyPriceInCents  Int?
  annualPriceInCents   Int?
  installModel         InstallModel  @default(fork)
  status               ListingStatus @default(draft)
  currentVersion       String        @default("1.0.0")
  stripePriceId        String?
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  installCount         Int           @default(0)
  averageRating        Float         @default(0)
  reviewCount          Int           @default(0)
  publishedAt          DateTime?
  featuredAt           DateTime?
  // Admin review queue (Phase 7). When the listing is rejected the admin's
  // reason is shown to the creator on the listing card; reviewedAt /
  // reviewedBy are populated on both approve and reject so we have an
  // auditable per-listing trail without standing up a separate review-event
  // table. See marketplace-audit.service for how findings flow in.
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  project      Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      CreatorProfile              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  versions     MarketplaceListingVersion[]
  installs     MarketplaceInstall[]
  reviews      MarketplaceReview[]
  transactions MarketplaceTransaction[]

  @@index([creatorId])
  @@index([status])
  @@index([category])
  @@index([pricingModel])
  @@index([installCount(sort: Desc)])
  @@index([averageRating(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
  @@map("marketplace_listings")
}

model MarketplaceListingVersion {
  id        String  @id @default(cuid())
  listingId String
  version   String
  changelog String? @db.Text

  // Workspace storage. Snapshots used to live in `workspaceSnapshot Json?`,
  // which doesn't scale past trivial templates (Postgres jsonb chokes on
  // multi-MB tarballs and JSON-encoded base64 wastes ~33% on every binary
  // file). Production storage is now S3 — `workspaceSnapshotKey` is the
  // tarball's object key under `${S3_WORKSPACES_BUCKET}/marketplace/`,
  // `workspaceSnapshotBytes` is the compressed size for UI display +
  // future per-listing quotas, and `workspaceSnapshotChecksum` is a
  // sha256 of the tarball for integrity verification at download time.
  // The legacy `workspaceSnapshot Json?` column stays for one release
  // as a read-fallback; the boot-time backfiller materializes those
  // rows into S3, after which a follow-up migration drops the column.
  workspaceSnapshot         Json?
  workspaceSnapshotKey      String?
  workspaceSnapshotBytes    Int?
  workspaceSnapshotChecksum String?

  // Phase 7 audit pipeline. Each version row carries its own audit state
  // because we re-audit on every new version. `auditedBy` is either the
  // sentinel string `'haiku-auto'` or an admin userId when a human re-runs
  // the audit. `auditFindings` is an array of
  //   { severity: 'secret' | 'non_generic' | 'info',
  //     file: string, line?: number, snippet?: string,
  //     reason: string, suggestion?: string }
  // Findings are advisory — submission to admin review is never blocked.
  auditStatus   AuditStatus @default(none)
  auditedAt     DateTime?
  auditedBy     String?
  auditFindings Json?
  auditModel    String?

  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, version])
  @@index([listingId])
  @@map("marketplace_listing_versions")
}

model MarketplaceInstall {
  id                   String        @id @default(cuid())
  listingId            String
  projectId            String
  workspaceId          String
  userId               String
  installModel         InstallModel
  installedVersion     String
  // Per-file sha256 manifest captured at install + after each apply-update.
  // Shape: { "<relPath>": "<sha256-hex>", ... }. Used by Phase 6 drift
  // detection: applyUpdate compares the current on-disk manifest to this
  // baseline and refuses to overwrite when files diverge unless the user
  // passes { force: true }. See marketplace-manifest.service.ts.
  baselineManifest     Json?
  stripeSubscriptionId String?
  status               InstallStatus @default(active)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  listing      MarketplaceListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviews      MarketplaceReview[]
  transactions MarketplaceTransaction[]

  @@index([listingId])
  @@index([userId])
  @@index([workspaceId])
  @@index([projectId])
  @@map("marketplace_installs")
}

model MarketplaceReview {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  installId String
  rating    Int
  title     String?
  body      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  install MarketplaceInstall @relation(fields: [installId], references: [id], onDelete: Cascade)

