model EvalRun {
  id            String    @id @default(cuid())
  track         String
  model         String
  workers       Int       @default(1)
  status        String    @default("pending")
  label         String?
  tags          String[]  @default([])
  triggeredBy   String?
  pid           Int?
  jobName       String?
  error         String?   @db.Text
  summary       Json?
  cost          Json?
  byCategory    Json?
  resources     Json?
  progress      Json?
  startedAt     DateTime?
  completedAt   DateTime?
