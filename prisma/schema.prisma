  @@index([sourceTag])
  @@index([createdAt])
  @@map("signup_attributions")
}

// =============================================================================
// API KEYS (for Shogo Local → Cloud proxy authentication)
// =============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  workspaceId String
  userId      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  // Device session metadata. `kind` is "user" for manually-created keys and
  // "device" for keys minted via the desktop cloud-login flow. Device keys
  // carry a stable deviceId so re-logging in from the same machine dedupes
  // instead of accumulating stale credentials. lastSeenAt is updated by
  // heartbeats and by validateProxyAuth on every authenticated call.
  kind             String    @default("user")
  deviceId         String?
  deviceName       String?
  devicePlatform   String?
  deviceAppVersion String?
  lastSeenAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, deviceId])
  @@map("api_keys")
}

// =============================================================================
// REMOTE CONTROL (Instance Registry for Local Shogo Instances)
// =============================================================================

model Instance {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String
  hostname      String
  os            String?
  arch          String?
  /// Connection kind: "desktop" = the Electron app, "cli-worker" = the
  /// `shogo worker` CLI installed on a dev box / CI runner. Set on
  /// register/heartbeat from the X-Shogo-Instance-Kind header. Defaults
  /// to "desktop" for back-compat with existing rows + clients that
  /// pre-date the header.
  kind          InstanceKind   @default(desktop)
  status        InstanceStatus @default(offline)
  lastSeenAt    DateTime?
  wsRequestedAt DateTime?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  remoteActions     RemoteAction[]
  pushSubscriptions PushSubscription[]
  preferredByProjects Project[]        @relation("ProjectPreferredInstance")

  @@unique([workspaceId, hostname])
  @@index([workspaceId])
  @@index([workspaceId, kind])
  @@map("instances")
}

enum InstanceStatus {
  online
  offline
}

enum InstanceKind {
  desktop
  cli_worker
}

model RemoteAction {
  id         String   @id @default(cuid())
  instanceId String
  userId     String
  action     String
  path       String?
  method     String?
  summary    String?
