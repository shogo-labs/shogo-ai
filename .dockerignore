# Dependencies - will be installed fresh in container
node_modules
**/node_modules

# Keep .schemas for domain definitions
!.schemas

# Build outputs
dist
**/dist
**/build

# Development files
.git
.gitignore
.env
.env.*
!.env.example

# IDE
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Test files
coverage
**/__tests__
*.test.ts
*.spec.ts

# Documentation
*.md
!packages/agent-runtime/src/bundled-skills/**/*.md
!packages/agent-runtime/src/bundled-claude-skills/**/*.md
docs/

# Terraform (not needed in container)
terraform/

