[copy]
  # Copy env files to new worktrees
  # Note: .env.local is NOT copied - it's generated by worktree-setup.sh with unique ports
  include = .env.local.template
  include = .env.test.local
  include = apps/web/.env.local

  # Exclude secrets that shouldn't be auto-copied
  exclude = **/*.pem
  exclude = **/*.key

[hooks]
  # Generate .env.local with unique ports for Docker isolation
  postCreate = ./scripts/worktree-setup.sh
  # Install dependencies and build
  postCreate = bun install
  postCreate = bun run build
  # Clean up Docker resources before worktree deletion
  preRemove = ./scripts/worktree-cleanup.sh

[defaults]
  ai = claude
