# =============================================================================
# Shogo AI - Public Environment Example
# =============================================================================
# Copy values from this file into your local deployment environment. Do not
# commit real secrets. For local Docker development, prefer copying the values
# you need into `.env.local`.
#
# Required for a minimal self-hosted setup:
# - DATABASE_URL
# - PROJECTS_DATABASE_URL
# - REDIS_URL
# - BETTER_AUTH_SECRET
# - BETTER_AUTH_URL
# - ALLOWED_ORIGINS
# - EXPO_PUBLIC_API_URL
# - S3_ENDPOINT / S3_PUBLIC_ENDPOINT / S3_WORKSPACES_BUCKET
# - AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (or your cloud credential chain)
# - At least one AI provider key
# =============================================================================

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
APP_URL=http://localhost:8081
BETTER_AUTH_URL=http://localhost:8002
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173
EXPO_PUBLIC_API_URL=http://localhost:8002
EXPO_PUBLIC_LOCAL_MODE=false

# -----------------------------------------------------------------------------
# Core secrets
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AI_PROXY_SECRET=
PREVIEW_TOKEN_SECRET=
APP_NAME=Shogo AI

# -----------------------------------------------------------------------------
# Databases and cache
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://shogo:change-me@localhost:5432/shogo
PROJECTS_DATABASE_URL=postgres://project:change-me@localhost:5433/projects
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Storage (MinIO / S3)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_WORKSPACES_BUCKET=shogo-workspaces
S3_SCHEMA_BUCKET=shogo-schemas
S3_SCHEMA_PREFIX=schemas/
S3_FORCE_PATH_STYLE=true
S3_REGION=us-east-1
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
SCHEMA_STORAGE=s3

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
LOCAL_LLM_BASE_URL=
LOCAL_LLM_BASIC_MODEL=
LOCAL_LLM_ADVANCED_MODEL=
LOCAL_EMBEDDING_MODEL=
LOCAL_EMBEDDING_DIMENSIONS=

# -----------------------------------------------------------------------------
# Runtime / local development
# -----------------------------------------------------------------------------
SHOGO_LOCAL_MODE=false
PREWARM_CLAUDE_CODE=false
WORKSPACES_DIR=./workspaces
RUNTIME_BASE_PORT=5200
RUNTIME_MAX_COUNT=10
RUNTIME_HEALTH_INTERVAL=30000
RUNTIME_DOMAIN_SUFFIX=localhost
VITE_RUNTIME_BASE=5200
VITE_RUNTIME_END=5209
VITE_DEV_PORT=5173

# -----------------------------------------------------------------------------
# Local Docker port mapping
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=shogo
PORT_OFFSET=0
POSTGRES_PORT=5432
POSTGRES_PROJECTS_PORT=5433
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=8002
WEB_PORT=8081
SKIP_WORKSPACE_SEEDING=1
UID=1000
GID=1000

# -----------------------------------------------------------------------------
# OAuth / auth integrations
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GH_APP_ID=
GH_APP_CLIENT_ID=
GH_APP_CLIENT_SECRET=
GH_APP_PRIVATE_KEY=
GH_APP_WEBHOOK_SECRET=
GH_APP_SLUG=

