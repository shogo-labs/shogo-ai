# =============================================================================
# Shogo AI - Environment Configuration Template
# =============================================================================
# This file documents all environment variables for Docker Compose.
#
# IMPORTANT: Do not copy this file directly to .env.local
# Instead, run: ./scripts/worktree-setup.sh
# This generates .env.local with unique ports based on your branch name.
#
# For a public-facing, comprehensive variable reference, see `.env.example`.
#
# =============================================================================
# Git Worktree Isolation
# =============================================================================
# Each worktree gets unique ports to allow parallel Docker environments.
#
# Port offset calculation:
#   - main/master branch: offset 0 (base ports)
#   - Feature branches: hash(branch_name) % 9 + 1 → ×10 → 10, 20, 30...90
#
# Example port assignments:
#   main branch (offset 0):  web=3000, api=8002, postgres=5432
#   feat/auth (offset 30):   web=3030, api=8032, postgres=5462
#   feat/ui (offset 70):     web=3070, api=8072, postgres=5502
#
# =============================================================================

# =============================================================================
# DOCKER COMPOSE ISOLATION
# =============================================================================
# COMPOSE_PROJECT_NAME prefixes all containers, volumes, and networks
# Automatically set by worktree-setup.sh based on branch name
COMPOSE_PROJECT_NAME=shogo
PORT_OFFSET=0

# =============================================================================
# PORT CONFIGURATION
# =============================================================================
# All ports are: BASE_PORT + PORT_OFFSET

# Infrastructure
POSTGRES_PORT=5432
POSTGRES_PROJECTS_PORT=5433
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Application
API_PORT=8002
WEB_PORT=3000

# Vite runtime for project previews
VITE_RUNTIME_BASE=5200
VITE_RUNTIME_END=5209

# Vite dev server (for native development without Docker)
VITE_DEV_PORT=5173

# =============================================================================
# SERVICE URLs
# =============================================================================
# External URLs (browser access)
APP_URL=http://localhost:8081
VITE_API_URL=http://localhost:8002
VITE_BETTER_AUTH_URL=http://localhost:8002

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# External connection (from host to Docker)
DATABASE_URL=postgres://shogo:shogo_dev@localhost:5432/shogo
PROJECTS_DATABASE_URL=postgres://project:project_dev@localhost:5433/projects

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
BETTER_AUTH_SECRET=shogo-local-dev-secret-32-chars-minimum-ok
BETTER_AUTH_URL=http://localhost:3000
AI_PROXY_SECRET=
PREVIEW_TOKEN_SECRET=
# AES-256-GCM master key for encrypting provider API keys at rest.
# Only needed if you add custom providers locally. Native BYOK keys (OpenAI /
# Anthropic) entered in Available Models are mirrored to env in local mode, so
# they do NOT require this key. Generate with:
#   openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# Google OAuth (optional - configure in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# API KEYS (secrets - add your own)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# EZ MODE / VOICE OVERLAY (optional)
# =============================================================================
# Required to enable the "EZ Mode" voice+text translator overlay
# (apps/mobile/components/voice-mode). The API route
# /api/voice/signed-url mints short-lived ElevenLabs signed URLs from
# this key, and the browser runs a convai session against the shared
# agent id below. Leave blank to disable voice mode.
ELEVENLABS_API_KEY=
# Shared convai agent id for EZ Mode. Create one by running:
#   ELEVENLABS_API_KEY=... bun run packages/agent-runtime/scripts/create-voice-mode-agent.ts
# and paste the printed agent_id here.
ELEVENLABS_VOICE_MODE_AGENT_ID=
# Translator LLM override (default: claude-haiku-4-5). Uses the same
# AI_PROXY_URL / AI_PROXY_TOKEN / ANTHROPIC_API_KEY resolution as the
# rest of the API.
SHOGO_VOICE_TRANSLATOR_MODEL=

# =============================================================================
# STRIPE BILLING CONFIGURATION (optional)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Signing secret for the Connect webhook endpoint (events on connected
# accounts, e.g. account.updated). Separate from STRIPE_WEBHOOK_SECRET.
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=

# =============================================================================
# AFFILIATE / MLM PROGRAM (optional; off by default)
# =============================================================================
SHOGO_AFFILIATES_NATIVE=false
SHOGO_AFFILIATE_MAX_DEPTH=3
SHOGO_AFFILIATE_REFUND_HOLD_DAYS=30
SHOGO_AFFILIATE_MIN_PAYOUT_CENTS=5000
SHOGO_AFFILIATE_COOKIE_DAYS=60
SHOGO_INTERNAL_SECRET=

# =============================================================================
# OPENTELEMETRY / SIGNOZ (optional)
# =============================================================================
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable traces, metrics AND logs. Leave
# empty to disable. Logs are exported to <endpoint>/v1/logs, correlated with
# traces. For local Jaeger: http://localhost:4318 (traces only).
# For SigNoz Cloud: https://ingest.us.signoz.cloud:443
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=shogo-api
# Required for SigNoz Cloud (not needed for local Jaeger)
SIGNOZ_INGESTION_KEY=
# Set to "false" to stop mirroring API console.* output to OTLP logs (the API
# still writes to stdout regardless). Defaults to enabled when OTEL is on.
OTEL_LOGS_CONSOLE_BRIDGE=

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_SECURE=true
SMTP_FROM_EMAIL=noreply@updates.shogo.ai
SMTP_FROM_NAME="Shogo"
