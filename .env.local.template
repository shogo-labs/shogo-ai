# Shogo AI Environment Configuration
# Copy this file to .env.local and customize for your environment
# For worktrees, use different port values to avoid collisions

# =============================================================================
# PORT CONFIGURATION (for multi-worktree isolation)
# =============================================================================
# Default ports (main branch):
#   VITE_PORT=3000, API_PORT=8002, MCP_PORT=3100
#
# Recommended offset pattern for worktrees:
#   Worktree 1: +10 (3010, 8012, 3110)
#   Worktree 2: +20 (3020, 8022, 3120)
#   etc.

VITE_PORT=3000
API_PORT=8002
MCP_PORT=3100
VITE_MCP_PORT=3100

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL (production/shared)
# DATABASE_URL=postgresql://user:password@host:5432/database

# SQLite (local development alternative)
# SQLITE_URL=.data/db.local

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# 
VITE_BETTER_AUTH_URL=http://localhost:8002
# GOOGLE_CLIENT_ID=xxx
# GOOGLE_CLIENT_SECRET=xxx

# =============================================================================
# FUTURE: Docker / Container Configuration
# =============================================================================
# When running in Docker, these become container names:
# API_HOST=api
# MCP_HOST=mcp
# VITE_HOST=web
