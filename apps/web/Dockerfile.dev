# =============================================================================
# Shogo Web Frontend - Development Dockerfile
# =============================================================================
# For hot reloading during development with Vite HMR.
# Source code is mounted as a volume.
# Usage: docker compose -f docker-compose.yml -f docker-compose.dev.yml up
# =============================================================================

FROM oven/bun:1.3-alpine

WORKDIR /app

# Install curl for healthchecks
RUN apk add --no-cache curl

# Copy workspace root files
COPY package.json bun.lock ./
COPY tsconfig.base.json ./

# Copy package.json files for dependency resolution
COPY packages/state-api/package.json ./packages/state-api/
COPY packages/mcp/package.json ./packages/mcp/
COPY apps/web/package.json ./apps/web/
COPY apps/api/package.json ./apps/api/
COPY apps/desktop/package.json ./apps/desktop/

# Copy scripts needed for postinstall
COPY scripts ./scripts

# Install all dependencies
RUN bun install

# Copy source code (will be overridden by volume mounts in dev mode)
COPY packages/state-api ./packages/state-api
COPY packages/mcp ./packages/mcp
COPY apps/web ./apps/web

# Copy scripts directory (needed for list-skills.ts in dev command)
COPY scripts ./scripts

# Copy .claude/skills directory (needed for list-skills.ts)
COPY .claude/skills ./.claude/skills

# Environment defaults
ENV NODE_ENV=development
ENV VITE_PORT=5173
ENV VITE_API_URL=http://localhost:8002
ENV VITE_MCP_URL=http://localhost:3100
ENV VITE_BETTER_AUTH_URL=http://localhost:8002
ENV VITE_WORKSPACE=workspace

# Expose Vite dev server port (5173 = standard Vite port for e2e test compatibility)
EXPOSE 5173

# Health check for Vite dev server
HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=5 \
  CMD curl -sf http://localhost:5173 -o /dev/null || exit 1

# Run Vite dev server on port 5173
WORKDIR /app/apps/web
CMD ["bun", "run", "dev", "--host", "0.0.0.0", "--port", "5173"]
