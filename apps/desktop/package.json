{
  "name": "@shogo/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Shogo Desktop — build and run agents locally",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite build && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:staging": "electron-vite build && VITE_DEV_SERVER_URL=https://studio-staging.shogo.ai electron .",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
