# =============================================================================
# Shogo API Server - Development Dockerfile
# =============================================================================
# For hot reloading during development. Source code is mounted as a volume.
# Usage: docker compose -f docker-compose.yml -f docker-compose.dev.yml up
#
# Features:
# - Hot reloading via bun --watch
# - RuntimeManager for project previews (spawns Vite processes)
# - Prisma migrations on startup
# =============================================================================

FROM oven/bun:1.3-alpine

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache curl bash git

# Copy workspace root files
COPY package.json bun.lock ./
COPY tsconfig.base.json ./

# Copy Prisma schema (needed for migrations)
COPY prisma ./prisma

# Copy package.json files for dependency resolution
COPY packages/agent-runtime/package.json ./packages/agent-runtime/
COPY packages/shared-runtime/package.json ./packages/shared-runtime/
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/domain-stores/package.json ./packages/domain-stores/
COPY packages/shared-app/package.json ./packages/shared-app/
COPY packages/shared-ui/package.json ./packages/shared-ui/
COPY packages/ui-kit/package.json ./packages/ui-kit/
COPY packages/canvas-runtime/package.json ./packages/canvas-runtime/
COPY packages/model-catalog/package.json ./packages/model-catalog/
COPY apps/api/package.json ./apps/api/
COPY apps/mobile/package.json ./apps/mobile/

# Copy scripts needed for postinstall
COPY scripts ./scripts

# Install all dependencies
RUN bun install

# Generate Prisma client
RUN bunx prisma generate

# Copy source code (will be overridden by volume mounts in dev mode)
COPY apps/api ./apps/api
COPY templates/runtime-template ./templates/runtime-template

# Copy .schemas for MCP and RuntimeManager
COPY .schemas ./.schemas

# Copy entrypoint script to a location that won't be overwritten by volume mount
COPY apps/api/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Create required directories with proper permissions
RUN mkdir -p /app/workspaces /app/.claude /app/.schemas && \
    chmod 777 /app /app/.claude /app/workspaces /app/.schemas

# Environment defaults
ENV NODE_ENV=development
ENV API_PORT=8002
ENV HOME=/app
ENV WORKSPACES_DIR=/app/workspaces
ENV RUNTIME_BASE_PORT=5200
ENV RUNTIME_DOMAIN_SUFFIX=localhost

# Expose API port and Vite runtime ports for project previews
EXPOSE 8002
EXPOSE 5200-5219

# Health check
HEALTHCHECK --interval=10s --timeout=5s --start-period=10s --retries=5 \
  CMD curl -sf http://localhost:${API_PORT}/api/health || exit 1

# Run API server with watch mode (overridden in docker-compose.dev.yml)
WORKDIR /app/apps/api
ENTRYPOINT ["/entrypoint.sh"]
CMD ["bun", "--watch", "src/entry.ts"]
