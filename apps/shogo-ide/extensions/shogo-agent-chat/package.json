{
  "name": "shogo-agent-chat",
  "displayName": "Shogo Chat",
  "description": "Native Shogo IDE chat surface with rich typed IDE context, real Ask/Edit/Agent/Plan mode contracts, planner handoff, agent operation controls, Chat Debug payloads, and reviewed edit/run actions.",
  "version": "0.0.0-phase.10",
  "publisher": "shogo",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:shogo.agentChat",
    "onCommand:shogo.agentChat.open",
    "onCommand:shogo.agentChat.focusInput",
    "onCommand:shogo.agentChat.newChat",
    "onCommand:shogo.agentChat.openContextPicker",
    "onCommand:shogo.agentChat.addSelection",
    "onCommand:shogo.agentChat.addActiveFile",
    "onCommand:shogo.agentChat.explainSelection",
    "onCommand:shogo.agentChat.fixSelection"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Shogo Agent Chat can discuss selected context in restricted mode. File edits and commands require trust and the Desktop agent bridge."
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Read-only chat shell and context display work in virtual workspaces. Local file and terminal actions require a local Shogo Desktop bridge."
    }
  },
  "contributes": {
    "viewsContainers": {
      "auxiliarybar": [
        {
          "id": "shogo-agent-chat",
          "title": "Shogo Chat",
          "icon": "media/shogo.svg"
        }
      ]
    },
    "views": {
      "shogo-agent-chat": [
        {
          "id": "shogo.agentChat",
          "name": "Shogo",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "shogo.agentChat.open",
        "title": "Shogo: Open Chat",
        "category": "Shogo",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "shogo.agentChat.focusInput",
        "title": "Shogo: Focus Chat Input",
        "category": "Shogo",
        "icon": "$(edit)"
      },
      {
        "command": "shogo.agentChat.newChat",
        "title": "Shogo: New Chat",
        "category": "Shogo",
        "icon": "$(add)"
      },
      {
        "command": "shogo.agentChat.openContextPicker",
        "title": "Shogo: Attach Context...",
        "category": "Shogo",
        "icon": "$(references)"
      },
      {
        "command": "shogo.agentChat.addSelection",
        "title": "Shogo: Attach Selection",
        "category": "Shogo",
        "icon": "$(selection)"
      },
      {
        "command": "shogo.agentChat.addActiveFile",
        "title": "Shogo: Attach Active File",
        "category": "Shogo",
        "icon": "$(file-code)"
      },
      {
        "command": "shogo.agentChat.explainSelection",
        "title": "Shogo: Explain Selection",
        "category": "Shogo",
        "icon": "$(lightbulb)"
      },
      {
        "command": "shogo.agentChat.fixSelection",
        "title": "Shogo: Fix Selection",
        "category": "Shogo",
        "icon": "$(wrench)"
      }
    ],
    "configurationDefaults": {
      "workbench.secondarySideBar.defaultVisibility": "visible",
      "workbench.colorCustomizations": {
        "activityBar.background": "#0f0f10",
        "activityBar.foreground": "#f5f5f4",
        "activityBar.inactiveForeground": "#858585",
        "activityBar.activeBorder": "#f97316",
        "activityBarBadge.background": "#f97316",
        "activityBarBadge.foreground": "#111111",
        "sideBar.background": "#121212",
        "sideBar.foreground": "#d6d3d1",
        "sideBar.border": "#2a2420",
        "sideBarTitle.foreground": "#f5f5f4",
        "editor.background": "#0d0d0e",
        "editor.foreground": "#e7e5e4",
        "editorWidget.background": "#151515",
        "panel.background": "#101011",
        "panel.border": "#2a2420",
        "panelTitle.activeBorder": "#f97316",
        "statusBar.background": "#0f0f10",
        "statusBar.foreground": "#d6d3d1",
        "statusBar.border": "#2a2420",
        "statusBarItem.prominentBackground": "#f97316",
        "statusBarItem.prominentForeground": "#111111",
        "titleBar.activeBackground": "#121212",
        "titleBar.activeForeground": "#f5f5f4",
        "titleBar.inactiveBackground": "#101011",
        "titleBar.inactiveForeground": "#a8a29e",
        "tab.activeBackground": "#151515",
        "tab.activeForeground": "#f5f5f4",
        "tab.activeBorderTop": "#f97316",
        "tab.inactiveBackground": "#101011",
        "tab.inactiveForeground": "#a8a29e",
        "input.background": "#151515",
        "input.border": "#2f2924",
        "inputOption.activeBorder": "#f97316",
        "focusBorder": "#f97316aa",
        "button.background": "#f97316",
        "button.foreground": "#111111",
        "button.hoverBackground": "#fb923c",
        "button.secondaryBackground": "#24201d",
        "button.secondaryForeground": "#e7e5e4",
        "list.activeSelectionBackground": "#2a1c13",
        "list.activeSelectionForeground": "#f5f5f4",
        "list.hoverBackground": "#1d1713",
        "list.highlightForeground": "#fb923c",
        "terminal.ansiBrightYellow": "#fb923c"
      },
      "github.copilot.enable": {
        "*": false
      },
      "github.copilot.chat.enabled": false,
      "chat.disableAIFeatures": true,
      "chat.agent.enabled": false,
      "chat.agentsControl.enabled": false,
      "chat.titleBar.signIn.enabled": false,
      "shogo.agentChat.autoOpen": true
    },
    "configuration": {
      "title": "Shogo Agent Chat",
      "properties": {
        "shogo.agentChat.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open Shogo Chat when Shogo IDE starts."
        },
        "shogo.agentChat.bridgeUrl": {
          "type": "string",
          "default": "",
          "description": "Local Shogo Desktop agent backend URL. Shogo Desktop writes this automatically when launching Shogo IDE."
        },
        "shogo.agentChat.bridgeToken": {
          "type": "string",
          "default": "",
          "description": "Short-lived token for the local Shogo Desktop agent bridge."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "shogo.agentChat.open"
        },
        {
          "command": "shogo.agentChat.focusInput"
        },
        {
          "command": "shogo.agentChat.newChat"
        },
        {
          "command": "shogo.agentChat.openContextPicker"
        },
        {
          "command": "shogo.agentChat.addSelection"
        },
        {
          "command": "shogo.agentChat.addActiveFile"
        },
        {
          "command": "shogo.agentChat.explainSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "shogo.agentChat.fixSelection",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "shogo.agentChat.newChat",
          "when": "view == shogo.agentChat",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "shogo.agentChat.explainSelection",
          "when": "editorHasSelection",
          "group": "shogo@1"
        },
        {
          "command": "shogo.agentChat.fixSelection",
          "when": "editorHasSelection",
          "group": "shogo@2"
        },
        {
          "command": "shogo.agentChat.addSelection",
          "when": "editorHasSelection",
          "group": "shogo@3"
        },
        {
          "command": "shogo.agentChat.addActiveFile",
          "group": "shogo@4"
        },
        {
          "command": "shogo.agentChat.openContextPicker",
          "group": "shogo@5"
        }
      ]
    },
    "keybindings": [
      {
        "command": "shogo.agentChat.open",
        "key": "ctrl+alt+;",
        "mac": "cmd+alt+;"
      },
      {
        "command": "shogo.agentChat.focusInput",
        "key": "ctrl+alt+'",
        "mac": "cmd+alt+'"
      },
      {
        "command": "shogo.agentChat.addSelection",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorHasSelection"
      },
      {
        "command": "shogo.agentChat.explainSelection",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ]
  }
}
