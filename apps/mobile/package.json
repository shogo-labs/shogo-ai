{
  "name": "@shogo/mobile",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "main": "./index.js",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "dev:ios": "expo start --ios",
    "dev:android": "expo start --android",
    "build": "expo export --platform web",
    "typecheck": "echo 'Skipping: requires Expo native environment'",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build:android:dev": "eas build --platform android --profile development",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "build:android:local": "eas build --platform android --profile preview --local",
    "prebuild": "expo prebuild --clean",
    "eas-build-post-install": "cd ../../packages/sdk && bun run build"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.99",
    "@better-auth/expo": "^1.4.19",
    "@expo/html-elements": "^0.10.1",
    "@expo/vector-icons": "^15.0.3",
    "@gluestack-ui/core": "^3.0.10",
    "@gluestack-ui/utils": "^3.0.11",
    "@legendapp/motion": "^2.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~7.11.0",
    "@shogo-ai/sdk": "workspace:*",
    "@shogo/domain-stores": "workspace:*",
    "@shogo/model-catalog": "workspace:*",
    "@shogo/shared-app": "workspace:*",
    "@shogo/shared-ui": "workspace:*",
    "@shogo/ui-kit": "workspace:*",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@ungap/structured-clone": "^1.3.0",
    "ai": "^6.0.97",
    "better-auth": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.0",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.0",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^55.0.8",
    "expo-linking": "~8.0.0",
    "expo-localization": "~17.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.8",
