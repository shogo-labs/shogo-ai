    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "html2canvas": "^1.4.1",
    "lucide-react-native": "^0.461.0",
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.1.1",
    "mobx-state-tree": "^6.0.1",
    "nativewind": "^4.1.23",
    "posthog-react-native": "^4.37.2",
    "react": "19.1.0",
    "react-aria": "^3.33.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.2",
