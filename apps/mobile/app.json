{
  "expo": {
    "name": "Shogo",
    "slug": "shogo",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/ic_playstore_legacy.png",
    "scheme": "shogo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.shogo.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ic_playstore_legacy.png"
      },
      "package": "ai.shogo.mobile",
      "softInputMode": "adjustResize"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/ic_playstore_legacy.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Shogo to access your photos so you can attach them to messages.",
          "cameraPermission": "Allow Shogo to use the camera so you can attach photos to messages."
        }
      ],
      "expo-document-picker",
      "expo-secure-store",
      "expo-web-browser",
      "expo-localization",
      ["@sentry/react-native/expo", {
        "organization": "shogo",
        "project": "shogo-mobile"
      }],
      "./plugins/withRemoveOrientationLocks"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1523dfce-1689-48f6-b921-68d992ff05c5"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/1523dfce-1689-48f6-b921-68d992ff05c5"
    }
  }
}
