# ─── Agent LLM (optional) ────────────────────────────────────────────────────
# Powers Explain / Refactor / +Tests in the editor breadcrumbs.
# Leave SHOGO_AGENT_PROVIDER as "stub" to use the built-in deterministic stubs.
# Set to "openai-compat" to call any OpenAI-compatible chat-completions API.

SHOGO_AGENT_PROVIDER=stub
# SHOGO_AGENT_PROVIDER=openai-compat

# ─ OpenAI ─
# SHOGO_AGENT_API_BASE=https://api.openai.com/v1
# SHOGO_AGENT_API_KEY=sk-...
# SHOGO_AGENT_MODEL=gpt-4o-mini

# ─ Groq ─
# SHOGO_AGENT_API_BASE=https://api.groq.com/openai/v1
# SHOGO_AGENT_API_KEY=gsk_...
# SHOGO_AGENT_MODEL=llama-3.3-70b-versatile

# ─ OpenRouter ─
# SHOGO_AGENT_API_BASE=https://openrouter.ai/api/v1
# SHOGO_AGENT_API_KEY=sk-or-...
# SHOGO_AGENT_MODEL=anthropic/claude-3.5-sonnet

# ─ Ollama (local, no key) ─
# SHOGO_AGENT_API_BASE=http://localhost:11434/v1
# SHOGO_AGENT_MODEL=llama3.2

# Optional
# SHOGO_AGENT_TIMEOUT_MS=30000
