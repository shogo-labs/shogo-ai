{
  "name": "shogo-ai",
  "private": true,
  "packageManager": "bun@1.2.20",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "web:dev": "bun run --cwd apps/web dev",
    "web:nohmr": "bun run --cwd apps/web dev:nohmr",
    "web:build": "bun run --cwd apps/web build",
    "web:preview": "bun run --cwd apps/web preview",
    "api:dev": "bun --watch apps/api/src/server.ts",
    "api:start": "bun apps/api/src/server.ts",
    "mcp:http": "bun run packages/mcp/src/server-http.ts",
    "mcp:stdio": "bun run packages/mcp/src/server.ts",
    "mcp:dev": "bun run --cwd packages/mcp dev",
    "docker:compose": "docker compose",
    "docker:dev:compose": "bun docker:compose -- -f docker-compose.yml -f docker-compose.dev.yml",
    "docker:dev:up": "bun docker:dev:compose -- up -d",
    "docker:dev:build": "bun docker:dev:compose -- up --build -d",
    "docker:dev:down": "bun docker:dev:compose -- down",
    "docker:dev:logs": "bun docker:dev:compose -- logs -f",
    "docker:dev:clean": "bun docker:dev:compose -- down -v",
    "docker:dev:cycle": "bun docker:dev:down && bun docker:dev:build",
    "docker:infra": "bun docker:compose -- up -d postgres redis minio minio-init",
    "docker:infra:down": "bun docker:compose -- down",
    "db:init": "bun apps/api/scripts/init-database.ts",
    "docker:prod": "bun docker:compose -- up -d",
    "docker:prod:build": "bun docker:compose -- up --build -d",
    "docker:prod:down": "bun docker:compose -- down",
    "docker:prod:clean": "bun docker:prod:down -- -v",
    "docker:prod:cycle": "bun docker:prod:down && bun docker:prod:build"
  },
  "devDependencies": {
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15"
  }
}