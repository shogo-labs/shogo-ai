{
  "name": "shogo-ai",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": ["packages/*", "apps/api", "apps/mobile"],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "web:dev": "cd apps/mobile && npx expo start --web",
    "web:build": "cd apps/mobile && npx expo export --platform web",
    "api:dev": "PREWARM_CLAUDE_CODE=false bun --watch apps/api/src/entry.ts",
    "api:start": "bun apps/api/src/server.ts",
    "dev:all": "mkdir -p logs && concurrently -n api,web -c green,magenta \"bun run api:dev 2>&1 | tee logs/api.log\" \"bun run web:dev 2>&1 | tee logs/web.log\"",
    "dev:backend": "mkdir -p logs && bun run api:dev 2>&1 | tee logs/api.log",
    "dev:start": "./scripts/docker-dev-start.sh",
    "dev:infra": "./scripts/docker-dev-start.sh --infra",
    "dev:clean": "./scripts/docker-dev-start.sh --clean",
    "docker:infra": "docker compose up -d postgres postgres-projects redis minio minio-init",
    "docker:infra:down": "docker compose down",
    "docker:infra:clean": "docker compose down -v",
    "docker:infra:logs": "docker compose logs -f",
    "db:init": "bun apps/api/scripts/init-database.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "generate:domain": "bun run scripts/generate-domain.ts",
    "generate:auth": "bun run scripts/generate-better-auth.ts",
    "generate:routes": "bun run packages/sdk/bin/shogo.ts generate",
    "generate:all": "bun run generate:domain && bun run generate:auth && bun run generate:routes",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:reset": "npx prisma migrate reset",
    "docker:prod": "docker-compose up",
    "docker:prod:build": "docker-compose up --build",
    "docker:prod:down": "docker-compose down",
    "mobile:dev": "cd apps/mobile && npx expo start",
    "mobile:ios": "cd apps/mobile && npx expo start --ios",
    "mobile:android": "cd apps/mobile && npx expo start --android",
    "mobile:web": "cd apps/mobile && npx expo start --web",
    "desktop:build-web": "cd apps/mobile && EXPO_PUBLIC_LOCAL_MODE=true EXPO_PUBLIC_API_URL=http://localhost:8002 npx expo export --platform web",
    "desktop:dev": "SHOGO_LOCAL_MODE=true DATABASE_URL=file:./shogo-local.db bun x prisma generate && bun run desktop:build-web && cd apps/desktop && npx tsc && npx electron .",
    "desktop:dev:clean": "rm -rf \"$HOME/Library/Application Support/@shogo/desktop/data\" && bun run desktop:dev",
    "docs:dev": "bun run --cwd apps/docs dev",
    "docs:build": "bun run --cwd apps/docs build",
    "test:e2e:staging": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:staging:ui": "npx playwright test --config e2e/playwright.config.ts --ui",
    "postinstall": "[ -f scripts/patch-claude-sdk.ts ] && bun scripts/patch-claude-sdk.ts || true"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-async-generator-functions": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.28.6",
    "@babel/plugin-transform-object-rest-spread": "^7.28.6",
    "@babel/plugin-transform-optional-chaining": "^7.28.6",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.28.6",
    "@prisma/adapter-libsql": "^7.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^9.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.3.0",
    "react-native-worklets": "^0.7.4",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^7.3.0",
    "prisma-adapter-bun-sqlite": "^0.6.8"
  }
}
