{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    // SDK source-map paths.
    //
    // These redirect any `import ... from '@shogo-ai/sdk/...'` in
    // workspaces extending this config (apps/api, packages/ui-kit) to
    // the SDK's TypeScript source instead of its compiled `dist/`
    // output. Bun's TS-aware resolver picks these up automatically,
    // so editing a file in `packages/sdk/src/` triggers an immediate
    // restart of `apps/api` (via watch-api.ts) without needing
    // `tsup --watch` to repack the SDK.
    //
    // Workspaces that DO NOT extend this base config (apps/mobile,
    // packages/{sdk,agent-runtime,shared-runtime,...}) are unaffected
    // — they continue resolving through `node_modules/@shogo-ai/sdk`
    // to `dist/` exactly as before. Mobile gets HMR via Metro's
    // `unstable_conditionNames` opt-in to the `development` export
    // condition (see apps/mobile/metro.config.js).
    //
    // Published consumers on npm see only `dist/`; these paths are
    // monorepo-internal.
    "paths": {
      "@shogo-ai/sdk": ["packages/sdk/src/index.ts"],
      "@shogo-ai/sdk/db": ["packages/sdk/src/db/index.ts"],
      "@shogo-ai/sdk/email": ["packages/sdk/src/email/index.ts"],
      "@shogo-ai/sdk/email/server": ["packages/sdk/src/email/server.ts"],
      "@shogo-ai/sdk/react": ["packages/sdk/src/react/index.ts"],
      "@shogo-ai/sdk/agent": ["packages/sdk/src/agent/index.ts"],
      "@shogo-ai/sdk/generators": ["packages/sdk/src/generators/index.ts"],
      "@shogo-ai/sdk/tools": ["packages/sdk/src/tools/index.ts"],
      "@shogo-ai/sdk/tools/server": ["packages/sdk/src/tools/server.ts"],
      "@shogo-ai/sdk/memory": ["packages/sdk/src/memory/index.ts"],
      "@shogo-ai/sdk/memory/server": ["packages/sdk/src/memory/server.ts"],
      "@shogo-ai/sdk/voice": ["packages/sdk/src/voice/index.ts"],
      "@shogo-ai/sdk/voice/server": ["packages/sdk/src/voice/server.ts"],
      "@shogo-ai/sdk/voice/react": ["packages/sdk/src/voice/react/index.ts"],
      "@shogo-ai/sdk/voice/native": ["packages/sdk/src/voice/native/index.ts"],
      "@shogo-ai/sdk/voice/route": ["packages/sdk/src/voice/route/index.ts"],
      "@shogo-ai/sdk/voice/route/signed-url": ["packages/sdk/src/voice/route/signed-url.ts"],
      "@shogo-ai/sdk/voice/route/tts-preview": ["packages/sdk/src/voice/route/tts-preview.ts"],
      "@shogo-ai/sdk/voice/route/agent": ["packages/sdk/src/voice/route/agent.ts"],
      "@shogo-ai/sdk/voice/route/audio-tags": ["packages/sdk/src/voice/route/audio-tags.ts"],
      "@shogo-ai/sdk/cli/deploy": ["packages/sdk/src/cli/deploy.ts"],
      "@shogo-ai/sdk/cli/pkg": ["packages/sdk/src/cli/pkg.ts"],
      "@shogo-ai/sdk/logger": ["packages/sdk/src/logger.ts"],
      "@shogo-ai/sdk/instrumentation": ["packages/sdk/src/instrumentation.ts"],
      "@shogo-ai/sdk/stream-buffer": ["packages/sdk/src/stream-buffer.ts"],
      "@shogo-ai/sdk/chat-message": ["packages/sdk/src/chat-message.ts"],
      "@shogo-ai/core": ["packages/core/src/index.ts"],
      "@shogo-ai/core/logger": ["packages/core/src/logger.ts"],
      "@shogo-ai/core/instrumentation": ["packages/core/src/instrumentation.ts"],
      "@shogo-ai/core/stream-buffer": ["packages/core/src/stream-buffer.ts"],
      "@shogo-ai/core/chat-message": ["packages/core/src/chat-message.ts"],
      "@shogo-ai/agent": ["packages/agent/src/index.ts"],
      "@shogo-ai/agent/agent-loop": ["packages/agent/src/agent-loop.ts"],
      "@shogo-ai/agent/pi-adapter": ["packages/agent/src/pi-adapter.ts"],
      "@shogo-ai/agent/model-catalog": ["packages/agent/src/model-catalog/index.ts"],
      "@shogo-ai/agent/model-router": ["packages/agent/src/model-router/index.ts"],
      "@shogo-ai/agent/tool-orchestration": ["packages/agent/src/tool-orchestration.ts"],
      "@shogo-ai/agent/loop-detector": ["packages/agent/src/loop-detector.ts"],
      "@shogo-ai/agent/microcompact": ["packages/agent/src/microcompact.ts"],
      "@shogo-ai/agent/prefix-fingerprint": ["packages/agent/src/prefix-fingerprint.ts"],
      "@shogo-ai/agent/hooks": ["packages/agent/src/hooks/index.ts"],
      "@shogo-ai/db": ["packages/db/src/index.ts"],
      "@shogo-ai/email": ["packages/email/src/index.ts"],
      "@shogo-ai/email/server": ["packages/email/src/server.ts"],
      "@shogo-ai/voice": ["packages/voice/src/index.ts"],
      "@shogo-ai/voice/server": ["packages/voice/src/server.ts"],
      "@shogo-ai/voice/react": ["packages/voice/src/react/index.ts"],
      "@shogo-ai/voice/native": ["packages/voice/src/native/index.ts"],
      "@shogo-ai/voice/route": ["packages/voice/src/route/index.ts"],
      "@shogo-ai/voice/route/signed-url": ["packages/voice/src/route/signed-url.ts"],
      "@shogo-ai/voice/route/tts-preview": ["packages/voice/src/route/tts-preview.ts"],
      "@shogo-ai/voice/route/agent": ["packages/voice/src/route/agent.ts"],
      "@shogo-ai/voice/route/audio-tags": ["packages/voice/src/route/audio-tags.ts"],
      "@shogo-ai/cli": ["packages/cli/src/index.ts"],
      "@shogo-ai/cli/deploy": ["packages/cli/src/deploy.ts"],
      "@shogo-ai/cli/pkg": ["packages/cli/src/pkg.ts"],
      "@shogo-ai/sdk/model-catalog": ["packages/sdk/src/model-catalog/index.ts"],
      "@shogo-ai/sdk/loop-detector": ["packages/sdk/src/loop-detector.ts"],
      "@shogo-ai/sdk/microcompact": ["packages/sdk/src/microcompact.ts"],
      "@shogo-ai/sdk/prefix-fingerprint": ["packages/sdk/src/prefix-fingerprint.ts"],
      "@shogo-ai/sdk/tool-orchestration": ["packages/sdk/src/tool-orchestration.ts"],
      "@shogo-ai/sdk/hooks": ["packages/sdk/src/hooks/index.ts"],
      "@shogo-ai/sdk/model-router": ["packages/sdk/src/model-router/index.ts"],
      "@shogo-ai/sdk/pi-adapter": ["packages/sdk/src/pi-adapter.ts"],
      "@shogo-ai/sdk/agent-loop": ["packages/sdk/src/agent-loop.ts"]
    }
  }
}
