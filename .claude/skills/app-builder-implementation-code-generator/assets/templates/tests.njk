{#
Template: module_tests_json
Purpose: Project TestSpecification entities to JSON for generate_tests.py
Schema: app-builder-implementation-spec
View Data Source: module_tests (query view filtering by moduleId)

This template is domain-agnostic and works with any TestSpecification entities
from the app-builder-implementation-spec schema.

Expected template context variables:
- data: Array of TestSpecification entities from query view
- schema_name: Name of the Wavesmith schema
- view_name: Name of the view being executed
- timestamp: ISO timestamp of projection
- entity_count: Number of entities in data array
#}
{
  "module_id": "{{ data[0].module if data.length > 0 else '' }}",
  "generated_at": "{{ timestamp }}",
  "tests": [
    {% for test in data %}
    {
      "id": "{{ test.id }}",
      "test_name": "{{ test.testName }}",
      "test_type": "{{ test.testType }}",
      "tested_interface": "{{ test.testedInterface }}",
      "inputs": {{ test.inputs | dump | safe }},
      "expected_outputs": {{ test.expectedOutputs | dump | safe }},
      "description": {{ test.description | dump | safe }},
      "_source": "wavesmith://TestSpecification/{{ test.id }}",
      "_schema": "{{ schema_name }}",
      "_view": "{{ view_name }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "_metadata": {
    "count": {{ entity_count }},
    "schema": "{{ schema_name }}",
    "view": "{{ view_name }}",
    "generated_at": "{{ timestamp }}"
  }
}
