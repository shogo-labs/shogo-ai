{#
Template: module_interfaces_json
Purpose: Project InterfaceContract entities to JSON for generate_stubs.py
Schema: app-builder-implementation-spec
View Data Source: module_interfaces (query view filtering by moduleId)

This template is domain-agnostic and works with any InterfaceContract entities
from the app-builder-implementation-spec schema.

Expected template context variables:
- data: Array of InterfaceContract entities from query view
- schema_name: Name of the Wavesmith schema
- view_name: Name of the view being executed
- timestamp: ISO timestamp of projection
- entity_count: Number of entities in data array
#}
{
  "module_id": "{{ data[0].module if data.length > 0 else '' }}",
  "generated_at": "{{ timestamp }}",
  "interfaces": [
    {% for interface in data %}
    {
      "id": "{{ interface.id }}",
      "function_name": "{{ interface.functionName }}",
      "inputs": {{ interface.inputs | dump | safe }},
      "outputs": {{ interface.outputs | dump | safe }},
      "requirements": {{ interface.requirements | dump | safe }},
      "description": {{ interface.description | dump | safe }},
      "algorithm_strategy": {{ interface.algorithmStrategy | dump | safe }},
      "_source": "wavesmith://InterfaceContract/{{ interface.id }}",
      "_schema": "{{ schema_name }}",
      "_view": "{{ view_name }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "_metadata": {
    "count": {{ entity_count }},
    "schema": "{{ schema_name }}",
    "view": "{{ view_name }}",
    "generated_at": "{{ timestamp }}"
  }
}
